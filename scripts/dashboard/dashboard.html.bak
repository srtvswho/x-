ield": false, "has_price": true, "n_calls": 1, "priority": 2}, {"ticker": "AMD", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T10:02:56+00:00", "earliest_call": "2026-06-25T16:15:27+00:00", "days_since": 5, "call_price": 521.58, "now_price": 580.91, "raw_pct": 11.4, "excess_pct": 4.0, "in_field": false, "has_price": true, "n_calls": 3, "priority": 2}, {"ticker": "NVDA", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T10:02:56+00:00", "earliest_call": "2026-06-25T16:15:27+00:00", "days_since": 5, "call_price": 192.53, "now_price": 200.09, "raw_pct": 3.9, "excess_pct": -3.5, "in_field": false, "has_price": true, "n_calls": 2, "priority": 2}, {"ticker": "PLTR", "kol": "serenity", "direction": "long", "called_at": "2026-06-25T14:51:04+00:00", "earliest_call": "2026-06-25T14:51:04+00:00", "days_since": 6, "call_price": null, "now_price": null, "raw_pct": null, "excess_pct": null, "in_field": false, "has_price": false, "n_calls": 1, "priority": 3}, {"ticker": "DRAM", "kol": "serenity", "direction": "long", "called_at": "2026-06-25T00:26:11+00:00", "earliest_call": "2026-06-25T00:26:11+00:00", "days_since": 6, "call_price": null, "now_price": null, "raw_pct": null, "excess_pct": null, "in_field": false, "has_price": false, "n_calls": 1, "priority": 3}]</script>
<script id="SUMMARIES" type="application/json">{"today": "【共识卡点】HBM 量产难度：zephyr 指出飞线方案量产极难 (✅存储/HBM)，jukan 转三星专利解决高堆叠 HBM 结构问题 (✅存储/HBM)。存储涨价：jukan 转 TrendForce 上调 PC/服务器 DRAM 合约价 (✅存储)。\n\n【非共识方向】推理算力稀缺：serenity 转 Cerebras 容量被 OpenAI 预订一空 (✅光通信/化合物半导体)。中国手机供应链短缺：jukan 转小米/OPPO 因内存等短缺下调出货目标 (✅存储)。", "consensus": {"0": "**共识方向：HBM/存储与AI算力卡点**\n- **HBM量产难度**：zephyr（✅强项）与jukan（✅强项）均提及HBM高堆叠量产极难，三星专利瞄准16层以上HBM5。\n- **存储涨价**：jukan（✅强项）转述DRAM合约价上调，与手机存储短缺形成供需矛盾。\n- **AI算力瓶颈**：serenity（✅强项）指出推理容量被OpenAI垄断，zephyr（✅强项）称中国硬件效率低2-3倍。\n\n**分歧**：austin（⚠️盲区）仅陈述技术架构，未表态。", "1": "近1月4大V共识：\n1. **存储/HBM是核心瓶颈**：Jukan、zephyr多次强调DRAM/HBM供应短缺、LTA模式转变、推理受限于内存带宽；serenity也提及市场轮动从存储开始。\n2. **AI算力需求持续**：Jukan、serenity、zephyr均认为CSP资本支出不会降，算力仍稀缺。\n3. **中国半导体国产化**：Jukan、zephyr关注CXMT及国产设备（ACMR等），但zephyr对CXMT CAPEX周期存风险提示。\n4. **光通信/激光器瓶颈**：serenity强项领域，看好激光器短缺延续至2029，资金将回流光子学。", "3": "**共识方向：存储/HBM 仍是核心瓶颈**\n- **jukan** (✅存储) 与 **zephyr** (✅存储) 多次强调 DRAM 供应紧张、LTA 普及、CXMT 短期无法倾销；jukan 认为推理 ROI 更依赖内存而非 GPU。\n- **serenity** (✅光通信) 指出激光器短缺延续至 2029，光通信将接棒存储轮动。\n- **分歧**：austin 仅客观提及 AI 对内存周期影响，无明确方向。", "6": "共识：\n1. **存储/HBM 是核心瓶颈**：Jukan、Zephyr 多次强调 DRAM/HBM 供应极度短缺，LTA 盛行，产能不足将持续至 2028+。\n2. **AI 算力需求持续扩张**：Jukan、Serenity 共识 CSP 资本支出不会下降，算力仍是最稀缺资源。\n3. **光通信/激光器短缺延续**：Serenity 强项领域指出激光器售罄至 2029，光通信将轮动回归。\n\n分歧：\n- Austin 弱看空/中性，但 Jukan/Zephyr 在存储强项上强烈看多，Austin 观点需打折。", "12": "**共识方向：存储/HBM 是核心瓶颈**\n- **Jukan** (存储强项✅) 多次强调 DRAM 为最重要瓶颈，MU 在推理中比 GPU 更关键。\n- **Zephyr** (存储强项✅) 指出内存占 Capex 40%、HBM 供应不足且良率低、CXMT 短期无倾销能力。\n- **Austin** (弱项⚠️) 仅提及 AI 对内存周期影响，无明确方向。\n\n**共识卡点：AI 算力/推理受内存带宽制约**\n- **Jukan** 认为推理 ROI 依赖内存而非 GPU。\n- **Zephyr** 指出内存带宽决定推理收入，GPU 常因内存瓶颈闲置。\n\n**分歧**：Austin 对存储方向表态较弱（盲区⚠️），但未与共识相左。"}, "person": {"jukan": {"0": "Jukan 今日核心表态：存储/HBM 方向偏多，转述 TrendForce 上调 3Q26 PC/服务器 DRAM 合约价预测（✅强项）。代工/卡点方面，指出三星代工获 TPU V10ax 订单、LG 电子基于台积电开展 ASIC 设计服务（✅强项）。另提及中国手机品牌因存储等短缺下调出货目标（✅强项）。", "1": "Jukan 近一月核心表态（强项：存储/HBM/代工/卡点）：\n- **存储**：坚定看多，强调DRAM是AI最重要瓶颈（引述Elon Musk），供应短缺短期无解；客户主动签3-5年长协，商业模式根本转变；反驳中国倾销论。\n- **HBM**：关注三星高堆叠HBM结构专利，解决16层以上可靠性。\n- **代工**：指出三星1.4nm重启开发、TPU V10ax由三星代工；联发科v8t量产早于v8i。\n- **AI算力**：认为推理ROI更依赖内存而非GPU，MU未来可能比NVDA更重要。", "3": "Jukan 近3月核心表态：**存储/HBM 是 AI 最核心瓶颈**，DRAM 供应短缺长期化，客户主动签长协（LTA），反驳中国倾销论；**代工**方面三星重启1.4nm、LG 基于台积电开展 ASIC 设计；**卡点**强调推理 ROI 更依赖内存而非 GPU。⚠️ 看空 Apple 出货量属弱项，仅参考。", "6": "Jukan 近 6 月核心表态：**存储/HBM 持续看多**（✅可信），强调 DRAM 是 AI 最核心瓶颈，供应短缺将长期化，LTA 模式结构性转变，反驳中国倾销论。**代工领域**（✅可信）指出三星获 TPU V10ax 订单、推进 1.4nm，MTK 项目进展超预期。**弱项领域**看空 AAPL 出货量（⚠️仅参考）。", "12": "Jukan 近一年核心表态聚焦存储/HBM/代工卡点：  \n- **存储**：坚定看多 DRAM 结构性短缺，强调 LTA 模式转变、CXMT 产能不足、推理 ROI 更依赖内存而非 GPU（✅可信）。  \n- **HBM/封装**：关注三星高堆叠 HBM 专利与玻璃基板进展（✅可信）。  \n- **代工**：跟踪三星 1.4nm 开发、LG 基于台积电的 ASIC 设计服务（✅可信）。  \n- **弱项**：看空苹果出货量（⚠️仅参考）。"}, "serenity": {"0": "Serenity 今日核心表态：✅强项领域，Sivers 融资扩产 InP 激光器/光放大器产能，视为量产积极信号，看涨。其余发言多为中性假设或转述（推理算力容量紧张、AI 资本开支难降），非方向性判断；人形机器人持仓披露属自报，不算新表态。", "1": "Serenity 近 1 月核心表态：**强项光通信/InP 持续看多**（✅可信），认为激光器短缺延至 2029，资金将轮动回光子学，SIVE 扩产 InP 为积极信号，Elon 收购 Mesh 利好 merchant 激光器供应商。**弱项机器人/整体追高**（⚠️仅参考）：重仓 Agility Robotics，看好人形机器人长期但承认短期营收贡献有限。", "3": "Serenity 近 3 月核心表态：**强项光通信/InP 持续看多**（✅可信），认为激光器短缺延至 2029，资金将轮动回光子学，重仓 SIVE/AAOI 等；**机器人方向积极**，重仓 Agility Robotics，看好人形机器人上游零部件；**AI 算力方向**（⚠️弱项/仅参考）看好 Cerebras 推理部署及超大规模云商资本支出持续。", "6": "Serenity 近 6 月核心表态：\n\n**强项领域 (✅高可信)**：\n- **光通信/激光器**：持续看多，认为激光器短缺将延续至 2029 年，市场将轮动回光子学，个人最高仓位集中于此。看好 SIVE、POET、LITE、AAOI 等 CW DFB 激光器供应商。\n- **InP/化合物半导体**：Sivers 融资扩产 InP 产能视为量产积极信号，看多 SIVE 在光通信及人形机器人 FMCW LiDAR 中的潜在受益。\n\n**弱项/盲区 (⚠️仅参考)**：\n- 整体追高倾向：自述因关注者增多更难忽视短期价格波动，部分持仓（如 CBRS）仅为谨慎仓位并提醒勿盲目跟单。", "12": "Serenity 近1年核心表态：**强项光通信/InP 持续看多**（✅可信），认为激光器短缺延至2029，资金将轮动回光子学，重仓光通信；**InP 扩产积极信号**（SIVE 融资扩产、POET 合作）。**弱项/盲区**：追高机器人（Agility Robotics 重仓）、AI 算力（Cerebras 建仓）及宏观判断，需打折参考。"}, "zephyr": {"0": "zephyr 今日核心表态：\n- **HBM/存储 (✅强项)**：指出飞线方案量产极其困难；披露与Hynix/Nvidia合作开发100M IOPS NAND控制器。\n- **AI算力 (✅强项)**：中国硬件FLOPS效率低2-3倍，成本优势被抵消；DSpark将获广泛采用。\n- 其余发言为中性事实陈述，无明确多空方向。", "1": "zephyr 近月核心表态：✅存储/HBM强项：看多Gigadevice，指出CXMT将产生$130B毛利但后续CAPEX周期是风险；HBM4仍用1b制程，16Hi HBM短期难量产。✅光通信/卡点：未直接涉及。⚠️弱项：无明确看空表态，AI泡沫论盲区未触发。", "3": "zephyr 近 3 月核心表态：\n- **存储/HBM (✅强项)**：看多 Gigadevice；指出 HBM 供应不足、良率问题多，16-Hi HBM 短期难量产；认为 CXMT 未来 18 月将产生超 $130B 毛利，但后续 CAPEX 支出周期是风险。\n- **光通信/电力**：未涉及。\n- **卡点 (✅强项)**：强调内存带宽制约推理，内存占 Capex 40% 是巨大问题。\n- **弱项 (⚠️打折)**：无明确看空表态。", "6": "zephyr 近6月核心表态（强项：存储/HBM/光通信/卡点）：\n- **存储/HBM**：看多CXMT（mega bullish），预测IPO市值$500B+；指出HBM供应不足、良率问题多，16-Hi短期难量产；强调内存带宽制约推理且占Capex 40%是巨大问题。\n- **卡点**：WFE子系统未来2年将大幅增长；3D DRAM无需EUV可扩展至1b节点。\n- **弱项**：无明确看空表态（符合其看空全错盲区）。", "12": "zephyr 近一年核心表态：强项领域（✅可信）聚焦存储/HBM/光通信卡点，持续看多 CXMT 产能与毛利周期，并提示 HBM 供应瓶颈与 3D DRAM 技术路径。弱项盲区（⚠️仅参考）未出现明确看空表态，AI 泡沫论盲区无相关发言。"}, "austin": {"0": "Austin 今日无方向性表态，三条均为技术/商业格局中性陈述。涉及推理市场终端客户机会、SRAM+HBM 低延迟内存池架构、LVI 集群协同设计（晶体管到 token）。均属其强项领域（商业格局/Foundry 模式），但无多空判断，仅作技术事实参考。", "1": "近1月Austin无明确方向性表态，7条均为中性技术/事件陈述。涉及推理市场、HBM/SRAM架构、LVI集群协同设计、存储周期（含MU是否见顶疑问）及QCOM投资者日。均属其强项（商业格局/Foundry模式）相关领域，但未形成看多/看空判断。", "3": "近3月Austin无明确方向性表态，7条推文均为中性。内容涉及推理市场机会、HBM/SRAM架构、AI集群协同设计、存储周期影响等，属其强项领域（商业格局/Foundry模式）的技术事实陈述，但未形成看多/看空判断。", "6": "近6月Austin无明确方向性表态，7条推文均为中性技术陈述或事件转发。涉及推理市场、HBM/SRAM架构、LVI集群设计、存储周期及Micron/MU、高通/QCOM等，但未给出看多/看空判断。其强项（商业格局、CUDA护城河）在此期间未发表方向性观点。", "12": "近1年Austin核心表态集中在商业格局与存储周期。强项领域：对Micron(MU)提出“是否已见顶”的质疑，并计划从供应端及Hynix、Samsung角度分析（✅可信）。其余发言多为技术架构陈述或事件转发，无明确方向性判断。"}}}</script>
<script>
const RECORDS=JSON.parse(document.getElementById('DATA').textContent);
const KOLS=JSON.parse(document.getElementById('KOLS').textContent);
const TICKERS=JSON.parse(document.getElementById('TICKERS').textContent);
const SUM=JSON.parse(document.getElementById('SUMMARIES').textContent);
const COLORS={jukan:'#48c9d6',serenity:'#f0a73c',zephyr:'#9a8cff',austin:'#e0617a'};
const ORDER=['jukan','serenity','zephyr','austin'];
function initials(n){return n.slice(0,1).toUpperCase()}
function fmtDate(iso){const d=new Date(iso);return `${d.getMonth()+1}/${d.getDate()}`}
function fmtFull(iso){const d=new Date(iso);return `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`}
function fmtTime(iso){const d=new Date(iso);return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`}

/* ---- 01 今日总结 ---- */
function renderBrief(){
  const sorted=[...RECORDS].sort((a,b)=>new Date(b.published_at)-new Date(a.published_at));
  const latest=new Date(sorted[0].published_at);
  const dayStr=`${latest.getFullYear()}-${String(latest.getMonth()+1).padStart(2,'0')}-${String(latest.getDate()).padStart(2,'0')}`;
  const items=sorted; // demo: 全样本当"今日"
  const dirN=items.filter(r=>r.direction!=='neutral').length;
  const bkCount={};items.forEach(r=>{if(r.bottleneck)bkCount[r.bottleneck]=(bkCount[r.bottleneck]||0)+1});
  const hot=Object.entries(bkCount).sort((a,b)=>b[1]-a[1]).slice(0,3);
  document.getElementById('brief').innerHTML=`
    <div class="bh"><span class="blabel">◆ Daily Brief</span><span class="bdate">${dayStr} · 北京 06:00 自动生成</span></div>
    <div class="btext">${SUM.today}</div>
    <div class="bstrip">
      <div class="bstat"><span class="v">${items.length}</span><span class="k">posts</span></div>
      <div class="bstat"><span class="v cy">${dirN}</span><span class="k">方向表态</span></div>
      <div class="bstat"><span class="v am">${Object.keys(bkCount).length}</span><span class="k">涉及卡点</span></div>
      <div class="bhot">${hot.map(([b,n])=>`<span class="tag bk">${b} ·${n}</span>`).join('')}</div>
    </div>`;
}

/* ---- 02 近期态度 ---- */
let win=3;
function renderStance(){
  // consensus
  document.getElementById('consensus').innerHTML=`
    <div class="ch"><span class="clabel">◇ 近期四人共识</span><span class="cwin">${winLabel(win)}</span></div>
    <div class="ctext">${SUM.consensus[win]}</div>`;
  let cut;
  if(win===0){
    // 1D：取数据里最新一天的0点作为cut
    const sorted=[...RECORDS].sort((a,b)=>new Date(b.published_at)-new Date(a.published_at));
    const ld=new Date(sorted[0].published_at); ld.setHours(0,0,0,0); cut=ld;
  } else { cut=new Date(); cut.setMonth(cut.getMonth()-win); }
  const g=document.getElementById('stancegrid');
  g.innerHTML=ORDER.map(key=>{
    const k=KOLS[key];const c=COLORS[key];
    let recs=RECORDS.filter(r=>r.kol===key&&new Date(r.published_at)>=cut)
      .filter(r=>(r.direction!=='neutral'||r.bottleneck))
      .sort((a,b)=>new Date(b.published_at)-new Date(a.published_at)).slice(0,4);
    const rows=recs.length?recs.map(r=>{
      const ic=r.direction==='long'?'▲':r.direction==='short'?'▼':'•';
      const bkStrong=r.bottleneck&&(k.strong||[]).some(s=>r.bottleneck.includes(s)||s.includes(r.bottleneck));
      const flags=[];if(r.is_disc)flags.push('<span class="flag">持仓披露</span>');if(r.is_retro)flags.push('<span class="flag">回顾</span>');
      const tk=(r.ticker||[]).map(t=>`<span class="tag">${t}</span>`).join('');
      const bk=r.bottleneck?`<span class="tag bk">${r.bottleneck}</span>`:'';
      const ft=r.bottleneck?(bkStrong?'<span class="tag strong">强项</span>':'<span class="tag weak">盲区</span>'):'';
      return `<div class="stmt"><div class="dir ${r.direction}">${ic}</div><div class="body">
        <div class="txt">${r.summary||r.raw_text||''}</div>
        <div class="meta">${tk}${bk}${ft}${flags.join('')}<span class="tag date">${fmtFull(r.published_at)}</span></div></div></div>`;
    }).join(''):`<div class="stmt"><div class="dir neutral">·</div><div class="body"><div class="txt" style="color:var(--ink-faint)">该窗口内无强项方向性表态</div></div></div>`;
    const psum=(SUM.person[key]&&SUM.person[key][win])||'';
    return `<div class="stance">
      <div class="sh"><div class="av" style="background:${c}">${initials(k.name)}</div>
        <div class="nm">${k.name}</div><div class="tp ${k.type}">${k.type}</div><div class="ct">${recs.length} 条</div></div>
      <div class="psum"><span class="lead">${winLabel(win)} · 核心立场</span>${psum}</div>
      ${rows}</div>`;
  }).join('');
}
function winLabel(w){return ({0:'今日',1:'近 1 个月',3:'近 3 个月',6:'近 6 个月',12:'近 1 年'})[w]}

/* ---- 03 今日明细 ---- */
let feedExpanded=false;
function renderFeed(){
  const sorted=[...RECORDS].sort((a,b)=>new Date(b.published_at)-new Date(a.published_at));
  const latest=new Date(sorted[0].published_at);
  document.getElementById('feed-date').textContent=`最新批次 · ${latest.getFullYear()}-${String(latest.getMonth()+1).padStart(2,'0')}-${String(latest.getDate()).padStart(2,'0')}（demo 取全部样本）`;
  const COLLAPSE=6;
  const show=feedExpanded?sorted:sorted.slice(0,COLLAPSE);
  document.getElementById('feed').innerHTML=show.map(r=>{
    const c=COLORS[r.kol];const k=KOLS[r.kol];
    const tk=(r.ticker||[]).map(t=>`<span class="tag">${t}</span>`).join('');
    const bk=r.bottleneck?`<span class="tag bk">${r.bottleneck}</span>`:'';
    const dp=r.direction!=='neutral'?`<span class="dirpill ${r.direction}">${r.direction}</span>`:'';
    const flags=[];if(r.is_disc)flags.push('<span class="flag">持仓披露</span>');if(r.is_retro)flags.push('<span class="flag">回顾</span>');if(r.is_selfret)flags.push('<span class="flag">自报收益</span>');
    const rb=r.rebuts?`<div class="frebut">反驳叙事 · ${r.rebuts}</div>`:'';
    return `<div class="fitem"><div class="ftime">${fmtDate(r.published_at)}<br>${fmtTime(r.published_at)}</div>
      <div class="frail"><div class="fav" style="background:${c}">${initials(k.name)}</div><div class="fline"></div></div>
      <div class="fbody"><div class="ftop"><span class="fnm">${k.name}</span>${dp}${tk}${bk}${flags.join('')}</div>
        <div class="fsum">${r.summary||r.raw_text||''}</div>${rb}
        <div class="frow"><span class="atb ${r.attribution}">${r.attribution||'NA'}</span><a class="flink" href="${r.raw_url}" target="_blank">view on X ↗</a></div></div></div>`;
  }).join('');
  const more=sorted.length-COLLAPSE;
  document.getElementById('feed-toggle').innerHTML=(more>0)?
    `<button id="ftbtn">${feedExpanded?'收起':'展开全部 '+sorted.length+' 条 ↓'}</button>`:'';
  const b=document.getElementById('ftbtn');if(b)b.onclick=()=>{feedExpanded=!feedExpanded;renderFeed();};
  document.getElementById('foot-count').textContent=`${RECORDS.length} extractions`;
}

/* ---- 04 标的 ---- */
function renderTickers(){
  document.getElementById('tbody').innerHTML=TICKERS.map(t=>{
    const c=COLORS[t.kol];const k=KOLS[t.kol];
    const rs=t.raw_pct>=0?'+':'';const es=t.excess_pct>=0?'+':'';
    return `<tr><td><span class="tk ${t.direction}">${t.ticker}</span></td>
      <td><div class="by"><div class="av" style="background:${c}">${initials(k.name)}</div><span class="nm">${k.name}</span> <span class="dirpill2 ${t.direction}">${t.direction}</span></div></td>
      <td><span class="when">${fmtFull(t.called_at)}</span></td>
      <td><span class="when">$${t.call_price}</span></td>
      <td><span class="when">$${t.now_price}</span> &nbsp;<span class="circle ${t.raw_pct>=0?'in':'out'}">${rs}${t.raw_pct}%</span></td>
      <td><span class="circle ${t.excess_pct>=0?'in':'out'}">${es}${t.excess_pct}pp</span></td>
      <td>${t.in_field?'<span class="tag strong">强项</span>':'<span class="tag weak">圈外</span>'}</td>
      <td><span class="pending"><span class="q">?</span> 待判断序列 · M3</span></td></tr>`;
  }).join('');
}

/* ---- 05 人物卡 ---- */
function renderKols(){
  document.getElementById('kolgrid').innerHTML=ORDER.map(key=>{
    const k=KOLS[key];const c=COLORS[key];
    const st=(k.strong||[]).map(s=>`<span class="chip s">${s}</span>`).join('');
    const wk=(k.weak||[]).map(s=>`<span class="chip w">${s}</span>`).join('');
    return `<div class="kol" data-type="${k.type}" style="--accent:${c}">
      <div class="khead"><div class="avatar" style="background:${c}">${initials(k.name)}</div>
        <div><div class="kname">${k.name}</div><div class="khandle">${k.handle}</div></div></div>
      <div class="ktype">${k.typeLabel}</div>
      <div class="kdesc">${k.desc}</div>
      <div class="kgroup strong"><div class="glab">▸ 信他</div><div class="chips">${st}</div></div>
      <div class="kgroup weak"><div class="glab">▸ 略过</div><div class="chips">${wk}</div></div></div>`;
  }).join('');
}

function tick(){const d=new Date();document.getElementById('clock').innerHTML=`<b>${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}</b> CST`;}
setInterval(tick,1000);tick();
document.querySelectorAll('#seg-stance button').forEach(b=>b.addEventListener('click',()=>{
  document.querySelectorAll('#seg-stance button').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');win=+b.dataset.w;renderStance();}));

renderBrief();renderStance();renderFeed();renderTickers();renderKols();
</script>
</body>
</html>
