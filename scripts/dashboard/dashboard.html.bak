<!doctype html>
<html lang="zh">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SIGNAL DESK · 大V情报终端</title>
<style>
:root{
  --bg:#0c0e13;--panel:#13161e;--panel-2:#181c26;--line:#262b38;--line-soft:#1d2230;
  --ink:#e8eaf2;--ink-dim:#9aa4b8;--ink-faint:#5e677d;
  --amber:#f0a73c;--amber-soft:#3a2c12;--cyan:#48c9d6;--cyan-soft:#11313a;
  --rose:#e0617a;--rose-soft:#33161f;--violet:#9a8cff;
  --mono:"SF Mono",ui-monospace,"JetBrains Mono","Roboto Mono",Menlo,Consolas,monospace;
  --sans:"Inter",-apple-system,"PingFang SC","Microsoft YaHei",system-ui,sans-serif;
}
*{box-sizing:border-box}
html,body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sans);
  -webkit-font-smoothing:antialiased;font-size:14px;line-height:1.5}
a{color:inherit;text-decoration:none}
::selection{background:var(--amber);color:#0c0e13}

.topbar{position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:18px;
  padding:0 22px;height:54px;background:rgba(12,14,19,.86);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--line)}
.brand{display:flex;align-items:baseline;gap:10px}
.brand .mark{font-family:var(--mono);font-weight:700;letter-spacing:.14em;font-size:15px;color:var(--amber)}
.brand .sub{font-family:var(--mono);font-size:10.5px;letter-spacing:.22em;color:var(--ink-faint);text-transform:uppercase}
.topbar .spacer{flex:1}
.clock{font-family:var(--mono);font-size:11px;color:var(--ink-dim);letter-spacing:.06em}
.clock b{color:var(--cyan)}
.live{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;
  letter-spacing:.16em;color:var(--ink-faint);text-transform:uppercase}
.live .dot{width:6px;height:6px;border-radius:50%;background:var(--cyan);animation:pulse 2.4s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(72,201,214,.5)}70%{box-shadow:0 0 0 7px rgba(72,201,214,0)}100%{box-shadow:0 0 0 0 rgba(72,201,214,0)}}

.wrap{max-width:1240px;margin:0 auto;padding:26px 22px 80px}

.shead{display:flex;align-items:baseline;gap:14px;margin:40px 0 16px}
.shead .num{font-family:var(--mono);font-size:11px;color:var(--amber);letter-spacing:.1em}
.shead h2{margin:0;font-size:15px;font-weight:600;letter-spacing:.02em}
.shead .hint{font-family:var(--mono);font-size:10.5px;color:var(--ink-faint);letter-spacing:.04em}
.shead .rule{flex:1;height:1px;background:linear-gradient(90deg,var(--line),transparent)}

/* ===== today brief (hero) ===== */
.brief{background:linear-gradient(135deg,#15171f,#11141b);border:1px solid var(--line);
  border-radius:12px;padding:20px 22px;position:relative;overflow:hidden;margin-top:8px}
.brief::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--amber)}
.brief .bh{display:flex;align-items:center;gap:10px;margin-bottom:11px}
.brief .blabel{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--amber)}
.brief .bdate{font-family:var(--mono);font-size:10.5px;color:var(--ink-faint);margin-left:auto}
.brief .btext{font-size:14.5px;line-height:1.72;color:var(--ink)}
.brief .btext .mark-amber{color:var(--amber)}
.brief .bstrip{display:flex;flex-wrap:wrap;gap:14px;margin-top:15px;padding-top:14px;border-top:1px solid var(--line-soft)}
.brief .bstat{display:flex;align-items:baseline;gap:6px}
.brief .bstat .v{font-family:var(--mono);font-weight:700;font-size:15px}
.brief .bstat .v.cy{color:var(--cyan)}.brief .bstat .v.am{color:var(--amber)}
.brief .bstat .k{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-faint)}
.brief .bhot{margin-left:auto;display:flex;gap:6px;align-items:center}

/* ===== window toggle ===== */
.winrow{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.winrow .lab{font-family:var(--mono);font-size:10px;color:var(--ink-faint);letter-spacing:.08em;text-transform:uppercase}
.seg{display:inline-flex;background:var(--panel);border:1px solid var(--line);border-radius:7px;padding:2px}
.seg button{font-family:var(--mono);font-size:11px;color:var(--ink-dim);background:none;border:none;
  padding:5px 12px;border-radius:5px;cursor:pointer;letter-spacing:.04em;transition:.15s}
.seg button:hover{color:var(--ink)}
.seg button.on{background:var(--amber);color:#0c0e13;font-weight:600}

/* consensus band */
.consensus{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:15px 18px;margin-bottom:16px}
.consensus .ch{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.consensus .clabel{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--cyan)}
.consensus .cwin{font-family:var(--mono);font-size:10px;color:var(--ink-faint);margin-left:auto}
.consensus .ctext{font-size:13px;line-height:1.66;color:var(--ink-dim)}

/* ===== stance grid ===== */
.stance-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.stance{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:15px 16px}
.stance .sh{display:flex;align-items:center;gap:9px;margin-bottom:11px}
.stance .sh .av{width:26px;height:26px;border-radius:6px;display:grid;place-items:center;
  font-family:var(--mono);font-weight:700;font-size:12px;color:#0c0e13}
.stance .sh .nm{font-weight:600;font-size:13.5px}
.stance .sh .tp{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  padding:2px 7px;border-radius:4px;background:var(--panel-2);border:1px solid var(--line);color:var(--ink-dim)}
.stance .sh .tp.signal{color:var(--cyan);border-color:var(--cyan-soft);background:var(--cyan-soft)}
.stance .ct{margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--ink-faint)}
.stance .psum{font-size:12px;line-height:1.6;color:var(--ink-dim);padding:11px 12px;margin-bottom:11px;
  background:var(--panel-2);border-radius:8px;border:1px solid var(--line-soft)}
.stance .psum .lead{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--ink-faint);display:block;margin-bottom:4px}
.stmt{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--line-soft)}
.stmt:last-child{border-bottom:none;padding-bottom:0}
.stmt .dir{flex:none;width:16px;text-align:center;font-family:var(--mono);font-weight:700;font-size:12px;margin-top:1px}
.stmt .dir.long{color:var(--cyan)}.stmt .dir.short{color:var(--rose)}.stmt .dir.neutral{color:var(--ink-faint)}
.stmt .body{flex:1;min-width:0}
.stmt .txt{font-size:12px;color:var(--ink);line-height:1.5}
.stmt .meta{display:flex;flex-wrap:wrap;align-items:center;gap:5px;margin-top:5px}
.tag{font-family:var(--mono);font-size:9.5px;letter-spacing:.03em;padding:2px 6px;border-radius:4px;
  background:var(--panel-2);border:1px solid var(--line);color:var(--ink-dim)}
.tag.bk{color:var(--amber);border-color:var(--amber-soft);background:var(--amber-soft)}
.tag.strong{color:var(--cyan);border-color:var(--cyan-soft);background:var(--cyan-soft)}
.tag.weak{color:var(--rose);border-color:var(--rose-soft);background:var(--rose-soft)}
.tag.date{color:var(--ink-faint)}
.flag{font-family:var(--mono);font-size:9px;letter-spacing:.05em;padding:2px 6px;border-radius:4px;
  background:#221c3a;border:1px solid #34295c;color:var(--violet)}

/* ===== daily feed ===== */
.feed{display:flex;flex-direction:column}
.fitem{display:grid;grid-template-columns:58px 26px 1fr;gap:13px;padding:13px 0;border-bottom:1px solid var(--line-soft)}
.fitem:last-child{border-bottom:none}
.fitem .ftime{font-family:var(--mono);font-size:10.5px;color:var(--ink-faint);text-align:right;padding-top:2px;line-height:1.4}
.fitem .frail{display:flex;flex-direction:column;align-items:center}
.fitem .fav{width:24px;height:24px;border-radius:6px;display:grid;place-items:center;
  font-family:var(--mono);font-weight:700;font-size:11px;color:#0c0e13}
.fitem .fline{flex:1;width:1px;background:var(--line-soft);margin-top:6px;min-height:8px}
.fitem:last-child .fline{display:none}
.fbody{min-width:0}
.fbody .ftop{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:5px}
.fbody .fnm{font-weight:600;font-size:12.5px}
.fbody .fsum{font-size:12.5px;color:var(--ink-dim);line-height:1.5}
.fbody .frebut{margin-top:6px;font-size:11.5px;color:var(--amber);line-height:1.45;padding-left:9px;border-left:2px solid var(--amber-soft)}
.fbody .frow{display:flex;flex-wrap:wrap;gap:6px;margin-top:7px;align-items:center}
.dirpill{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.05em;padding:2px 7px;border-radius:5px;text-transform:uppercase}
.dirpill.long{background:var(--cyan-soft);color:#a9e6ec}.dirpill.short{background:var(--rose-soft);color:#f0a5b5}
.atb{font-family:var(--mono);font-size:9px;letter-spacing:.06em;padding:1.5px 6px;border-radius:3px;border:1px solid var(--line);color:var(--ink-faint)}
.atb.ORIGINAL{color:var(--cyan);border-color:var(--cyan-soft)}
.flink{font-family:var(--mono);font-size:10px;color:var(--ink-faint);margin-left:auto}
.flink:hover{color:var(--cyan)}
.feed-toggle{margin-top:14px;text-align:center}
.feed-toggle button{font-family:var(--mono);font-size:11px;color:var(--ink-dim);background:var(--panel);
  border:1px solid var(--line);border-radius:7px;padding:8px 18px;cursor:pointer;letter-spacing:.04em}
.feed-toggle button:hover{color:var(--ink);border-color:#34405a}

/* ===== ticker table ===== */
.tcard{background:var(--panel);border:1px solid var(--line);border-radius:10px;overflow:hidden}
.ttable{width:100%;border-collapse:collapse;font-size:12.5px}
.ttable thead th{font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--ink-faint);text-align:left;padding:11px 14px;background:var(--panel-2);border-bottom:1px solid var(--line);font-weight:500;white-space:nowrap}
.ttable tbody td{padding:12px 14px;border-bottom:1px solid var(--line-soft);vertical-align:top}
.ttable tbody tr:last-child td{border-bottom:none}
.ttable tbody tr:hover{background:var(--panel-2)}
.tk{font-family:var(--mono);font-weight:700;font-size:13px}.tk.long{color:var(--cyan)}.tk.short{color:var(--rose)}
.by{display:flex;align-items:center;gap:7px}
.by .av{width:20px;height:20px;border-radius:5px;display:grid;place-items:center;font-family:var(--mono);font-weight:700;font-size:10px;color:#0c0e13;flex:none}
.by .nm{font-size:12px}
.when{font-family:var(--mono);font-size:11px;color:var(--ink-dim)}
.circle{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:11px}
.circle.in{color:var(--cyan)}.circle.out{color:var(--ink-faint)}
.dirpill2{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.05em;padding:2px 7px;border-radius:5px;text-transform:uppercase}
.dirpill2.long{background:var(--cyan-soft);color:#a9e6ec}.dirpill2.short{background:var(--rose-soft);color:#f0a5b5}
.pending{font-family:var(--mono);font-size:10px;letter-spacing:.04em;color:var(--ink-faint);border:1px dashed var(--line);border-radius:5px;padding:4px 9px;display:inline-flex;align-items:center;gap:6px}
.pending .q{color:var(--amber)}

/* ===== KOL cards (now at bottom, compact reference) ===== */
.kolgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.kol{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px;position:relative;overflow:hidden}
.kol::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent,var(--amber))}
.kol .khead{display:flex;align-items:center;gap:9px;margin-bottom:3px}
.kol .avatar{width:28px;height:28px;border-radius:7px;display:grid;place-items:center;font-family:var(--mono);font-weight:700;font-size:12px;color:#0c0e13;background:var(--accent,var(--amber))}
.kol .kname{font-weight:600;font-size:14px}
.kol .khandle{font-family:var(--mono);font-size:10px;color:var(--ink-faint)}
.kol .ktype{display:inline-block;margin-top:8px;font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:4px;background:var(--panel-2);border:1px solid var(--line);color:var(--ink-dim)}
.kol[data-type="signal"] .ktype{color:var(--cyan);border-color:var(--cyan-soft);background:var(--cyan-soft)}
.kol .kdesc{margin:10px 0 11px;font-size:11.5px;color:var(--ink-dim);line-height:1.45}
.kgroup{margin-top:8px}
.kgroup .glab{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:5px;margin-bottom:5px}
.kgroup.strong .glab{color:var(--cyan)}.kgroup.weak .glab{color:var(--rose)}
.chips{display:flex;flex-wrap:wrap;gap:4px}
.chip{font-size:10.5px;padding:2px 7px;border-radius:5px;line-height:1.3;border:1px solid transparent}
.chip.s{background:var(--cyan-soft);color:#a9e6ec;border-color:#1c4750}
.chip.w{background:var(--rose-soft);color:#f0a5b5;border-color:#4d2330}

.foot{margin-top:50px;padding-top:18px;border-top:1px solid var(--line);font-family:var(--mono);font-size:10.5px;color:var(--ink-faint);letter-spacing:.04em;display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.foot .sep{color:var(--line)}

@media(max-width:1080px){.kolgrid{grid-template-columns:repeat(2,1fr)}.stance-grid{grid-template-columns:1fr}}
@media(max-width:680px){
  .kolgrid{grid-template-columns:1fr}.wrap{padding:18px 14px 60px}
  .ttable thead{display:none}.ttable,.ttable tbody,.ttable tr,.ttable td{display:block;width:100%}
  .ttable tbody tr{border-bottom:1px solid var(--line);padding:6px 0}.ttable td{border:none;padding:5px 14px}
  .fitem{grid-template-columns:42px 22px 1fr;gap:10px}
}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand"><span class="mark">SIGNAL DESK</span><span class="sub">semiconductor intel</span></div>
  <div class="spacer"></div>
  <span class="clock" id="clock"></span>
  <span class="live"><span class="dot"></span>auto · 06:00 CST</span>
</div>

<div class="wrap">

  <!-- ===== 今日总结 (hero) ===== -->
  <div class="shead"><span class="num">01</span><h2>今日总结</h2>
    <span class="hint">四源综合 · LLM 提炼 · 已按能力圈加权</span><span class="rule"></span></div>
  <div class="brief" id="brief"></div>

  <!-- ===== 近期态度 ===== -->
  <div class="shead"><span class="num">02</span><h2>近期态度</h2>
    <span class="hint">单人/共识总结 + 强项方向表态 · 随时间窗变化</span><span class="rule"></span></div>
  <div class="winrow"><span class="lab">window</span>
    <div class="seg" id="seg-stance">
      <button data-w="0">1D</button><button data-w="1">1M</button><button data-w="3" class="on">3M</button>
      <button data-w="6">6M</button><button data-w="12">1Y</button>
    </div>
  </div>
  <div class="consensus" id="consensus"></div>
  <div class="stance-grid" id="stancegrid"></div>

  <!-- ===== 今日明细 ===== -->
  <div class="shead"><span class="num">03</span><h2>今日明细</h2>
    <span class="hint" id="feed-date"></span><span class="rule"></span></div>
  <div class="feed" id="feed"></div>
  <div class="feed-toggle" id="feed-toggle"></div>

  <!-- ===== 标的追踪 ===== -->
  <div class="shead"><span class="num">04</span><h2>标的追踪</h2>
    <span class="hint">喊单 → 至今表现 · 绝对/超额分列</span><span class="rule"></span></div>
  <div class="tcard">
    <table class="ttable">
      <thead><tr><th>标的</th><th>谁 · 方向</th><th>最近喊单</th><th>喊单价</th>
        <th>现价 / 绝对</th><th>超额(板块)</th><th>能力圈</th><th>现在还有空间?</th></tr></thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>

  <!-- ===== 追踪对象 (ref, bottom) ===== -->
  <div class="shead"><span class="num">05</span><h2>追踪对象</h2>
    <span class="hint">能力圈备忘 · 信什么 / 略过什么</span><span class="rule"></span></div>
  <div class="kolgrid" id="kolgrid"></div>

  <div class="foot"><span>SIGNAL DESK</span><span class="sep">/</span>
    <span>4 sources</span><span class="sep">/</span><span id="foot-count"></span><span class="sep">/</span>
    <span style="color:var(--amber)">demo data — 接入真实 DB 后由 cron 每日生成</span></div>
</div>

<script id="DATA" type="application/json">[{"post_id": "2072097730722455674", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T23:19:31+00:00", "direction": "neutral", "ticker": ["2327.TW"], "company": ["Yageo"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "台湾被动元件龙头国巨宣布自7月1日起全面调涨电容产品价格，涵盖MLCC、铝电容、钽电容等，为近年最广泛涨价。成本压力来自地缘政治、能源及原物料上涨，AI服务器、HPC、电动车需求推升高阶产品需求，电容占营收约50%，涨价可望支撑获利。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "• Taiwan’s leading passive components company, Yageo, has implemented price increases across its full capacitor solutions portfolio, including MLCCs, aluminum, tantalum, polymer, film, and supercapacitors. This marks one of the broadest price hikes the company has carried out in recent years and takes effect immediately from July 1.\n\n• Manufacturing cost pressure has reached its limit due to geopolitical risks, strong energy prices, and rising costs for key raw materials. While Yageo had previously absorbed these costs through process efficiency improvements, external headwinds such as escalating tensions in the Middle East and rising international freight rates have made price adjustments unavoidable.\n\n• Given that capacitor products account for roughly 50% of Yageo’s revenue, this price increase is expected to directly support earnings improvement. In addition, demand for high-spec products continues to rise on the back of growth in AI servers, HPC, and electric vehicles, accelerating capacity consumption across the industry.", "raw_url": "https://x.com/jukan05/status/2072097730722455674"}, {"post_id": "2072094213483983268", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T23:05:32+00:00", "direction": "neutral", "ticker": [], "company": ["Guangyuan New Material"], "bottleneck": "Substrate", "attribution": "RELAYED", "rebuts": null, "summary": "转推 Nikkei 报道：中国广远新材料已开始出货 T-Glass 玻璃基板。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Interesting. China is reportedly finally shipping T-Glass.\n\nNikkei: Guangyuan New Material has recently started shipping T-Glass. https://t.co/fSDHA04rQu", "raw_url": "https://x.com/jukan05/status/2072094213483983268"}, {"post_id": "2072012346726256644", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-30T17:40:14+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 podbois 相信推理市场就是市场本身，以及模型实验室等终端客户的投资机会。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@proxietuna Or podbois believe in the investment opportunity (inference market is the market) and the end customer (model labs etc)", "raw_url": "https://x.com/austinsemis/status/2072012346726256644"}, {"post_id": "2072007692684837039", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T17:21:44+00:00", "direction": "long", "ticker": ["SIVE", "GFS"], "company": ["Sivers Semiconductors", "GlobalFoundries"], "bottleneck": "InP", "attribution": "ORIGINAL", "rebuts": null, "summary": "Sivers 融资约 $61M 扩产 InP 激光器和光放大器产能，作者认为若由长线机构认购且无大幅折价则非常看涨，并建议引入 GFS 等战略投资者，整体视为量产积极信号。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "$SIVE is raising ~$61M (600M SEK) to expand manufacturing capacity for InP lasers and optical amplifiers.\n\nSivers operates as a fab-lite model so this is likely hinting at foundry allocation/scaling for CW DFB laser ramp across Jabil, and their other partners.  \n\nIt could also point to broader foundry allocation/scaling beyond the already announced WIN partnership. \n\nMy feedback is that it's very bullish if it's comprised of long-only institutions and there's no heavy discount (30 day VWAP). Otherwise, would need to reaccess if there's arb or short term investors. \n\nThis is the perfect time to get ideal strategic investors like $GFS on the cap table. As well as focusing on having more US institutional support. \n\nEspecially considering $56M is a small check to a single US institution that want photonics exposure (eg. look at Poet's $400M registered direct offering for sentiment). \n\nA lot of it is \"it depends when more info comes out\", but this looks like a very positive signal for mass production given Siver's fab-lite models.", "raw_url": "https://x.com/aleabitoreddit/status/2072007692684837039"}, {"post_id": "2071995924172394695", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T16:34:58+00:00", "direction": "long", "ticker": ["CCXI", "NVDA", "AMZN"], "company": ["Agility Robotics", "Foxconn", "NVIDIA", "Amazon", "Softbank"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表示 Agility Robotics 是其目前最喜爱的人形机器人持仓，将通过 CCXI 在纳斯达克上市，V4 已在亚马逊等场所运营，V5 计划明年量产，投资者包括富士康、NVDA、AMZN、软银等，作者偏好投资美国供应链，并提及 SPAC 风险。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "Yep! Agility Robotics is currently my favorite humanoid/robotics position.\n\nThey're set to be listed on NASDAQ via $CCXI as early as September (per Digitimes).\n\nJust for informational purposes: Their V4 humanoid robot is already operating in sites like Amazon. And have V5 slated for mass production next year (they have a 10,000+ /year capacity).\n\nInvestors include Foxconn, $NVDA, $AMZN, Softbank, and now Serenity. \n\nI've been personally waiting for humanoid exposure for awhile (Agility is set to be the first US pure-play listed one) to the point I was actually planning on investing in Unitree's IPO. \n\nBut I'm glad now I personally have a compelling alternative now since I prefer to invest capital to build up Made in America supply chains (75% of their components are US-sourced from investor desks). \n\nThere are risks assigned to SPACs such as listing delays, or cancellation. But excited to see what happens next with developments.\n\nI do hope this encourages other frontier companies to go public early on.", "raw_url": "https://x.com/aleabitoreddit/status/2071995924172394695"}, {"post_id": "2071995258599280973", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T16:32:20+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出通过专用飞线而非PCB路由实现超快内存访问，但认为量产将极其困难。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Rather than routing data thru PCB, they are using lots of dedicated flyover cables to achieve ultra fast memory access\nManufacturing this in volume will be an extremely tough job https://t.co/3EbsWZnBH9", "raw_url": "https://x.com/zephyr_z9/status/2071995258599280973"}, {"post_id": "2071989570065809797", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-30T16:09:43+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "NA", "rebuts": null, "summary": "推文描述 SRAM 与 HBM 共享低延迟内存池及专有超低延迟高带宽互连，属技术架构陈述，无方向性判断。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "SRAM + HBM\n\nshared low-latency memory pool across scale-up domain\n\nproprietary ultra-low-latency, high-bandwidth interconnect", "raw_url": "https://x.com/austinsemis/status/2071989570065809797"}, {"post_id": "2071988763132113386", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-30T16:06:31+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者阐述运行 LVI 需要从晶体管到 token 的集群协同设计，涉及可拆分数学阵列、电路技术、新型调度算法、供电网络、VRM 架构、先进封装、冷板设计等，属技术事实陈述，无投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "“Running LVI requires co-designing the entire cluster from the transistor to the token: new splittable math arrays, circuit techniques, novel tiling and scheduling algorithms, power delivery networks, VRM architectures, advanced packaging, cold plate designs, and more”", "raw_url": "https://x.com/austinsemis/status/2071988763132113386"}, {"post_id": "2071977219002613768", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T15:20:39+00:00", "direction": "neutral", "ticker": ["TSLA"], "company": ["Tesla"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提出一个假设性问题：如果特斯拉Optimus人形机器人量产数千万台，谁来做外观美化（机器人化妆品/皮肤瓶颈），未表达投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I wonder if humanoids is going to spark a new bottleneck/industry for robot cosmetics.\n\nLike a skin bottleneck. Or Aespa KPOP robot makeover as a service.\n\nSo if $TSLA Optimus makes tens of millions of humanoids:\n\nWho’s going to make them all look hot?", "raw_url": "https://x.com/aleabitoreddit/status/2071977219002613768"}, {"post_id": "2071961279380791729", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T14:17:18+00:00", "direction": "neutral", "ticker": ["RDDT", "CBRS"], "company": ["Reddit", "Cerebras"], "bottleneck": "推理算力", "attribution": "RELAYED", "rebuts": null, "summary": "转述 Reddit 上 ML 子版块的抱怨: 用户想用 Cerebras 达到 1-2K tokens/s 推理速度, 但 OpenAI 已预订所有容量, 其他人无限排队; Groq API 也无法访问. 反映快速推理市场玩家少、容量有限.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "There was a pretty funny anecdotal complaint from the Machine Learning $RDDT subreddit.\n\nOn $CBRS + OpenAI:\n\n- Needs 1-2K tokens/sec so tries to use Cerebras.\n\n- Claims OpenAI reserved all capacity, making waitlist infinite for everyone else not a hyperscaler.\n\n- Stated alternatives with Groq’s API not accessible to them\n\nFeels bad. But it does show how few players / limited capacity there is for fast inference.", "raw_url": "https://x.com/aleabitoreddit/status/2071961279380791729"}, {"post_id": "2071936402691158026", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T12:38:27+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出中国硬件在 FLOPS 效率上低 2-3 倍，除非芯片便宜 3 倍（实际并非如此），否则 10% 的成本优势会消失。客观技术比较，无明确多空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bookwormengr Well, Chinese hardware is 2x-3x less efficient on a FLOPS basis\nSo unless the chips are 3x cheap (which they are not)\nThe 10% advantage goes away", "raw_url": "https://x.com/zephyr_z9/status/2071936402691158026"}, {"post_id": "2071928453822324769", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T12:06:52+00:00", "direction": "neutral", "ticker": ["NVDA"], "company": ["Nvidia"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者称 Nvidia Dynamo 的存在是因为 'the whale' (可能指大客户或特定需求), 未表达明确多空观点.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Nvidia Dynamo exists because of the whale", "raw_url": "https://x.com/zephyr_z9/status/2071928453822324769"}, {"post_id": "2071907884737482807", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T10:45:08+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electronics"], "bottleneck": "HBM", "attribution": "NA", "rebuts": null, "summary": "三星电子申请新专利，通过三层阶梯加曲面结构的顶部虚拟芯片设计，解决高堆叠HBM的芯片分层、开裂和翘曲问题，提升结构稳定性和良率，目标瞄准16层以上HBM5。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Samsung Electronics Pushes Next Generation HBM Structural Change… Files Novel Patent for High Stack Response\n\nSamsung Electronics has been confirmed to have filed a new patent aimed at solving the reliability problems of high bandwidth memory (HBM) packages. As the high stack era of HBM4E and HBM5 draws near, the company is innovating the \"dummy die\" structure that protects the memory dies, pursuing both structural stability and yield stability. According to the HBM packaging patent disclosed on the 28th, Samsung Electronics has developed a technology that machines the side of the topmost dummy die in the stack into a three tier stepped plus curved structure. It is a method that can effectively improve the chip delamination, cracking, and warpage problems that commonly occur in high stack HBM.\n\nHBM is a structure in which multiple memory dies are vertically stacked on top of a base die, with a topmost dummy die placed above them. The dummy die brings the overall package height into specification and performs mechanical protection and heat dissipation roles. However, as the number of stacked layers has climbed beyond 12 to 16 or more, the reliability of the topmost dummy die has emerged as a key variable for yield and long term stability. Typically, the move from 8 to 12 layers cuts yield by 10 to 20 percentage points, and as it goes toward 16 layers it falls more sharply, dropping into the 40 to 60 percent range. Here, improving the dummy die structure addresses the warpage problem and the thermal expansion mismatch problem, which are among the important causes of yield decline.\n\nSamsung Electronics employs a \"deep groove sawing\" process for the dummy die. Deep groove sawing is a high precision cutting process that separates chips (dies) by carving deep grooves into the wafer, a technique that forms deeper and more precise grooves than conventional ordinary blade sawing (mechanical sawing). Its advantage is that it is laser based and minimizes damage to the semiconductor crystal structure.\n\nThis structure is designed in an inverted pyramid form, in which the bottom surface (bonding surface) of the topmost dummy die is kept narrow while the top surface widens. The sides are divided into first, second, and third sides, characterized by a discontinuous structure in which the slope changes abruptly at each connection point, along with a convex curved surface toward the top. As a result, mechanical strength is expected to improve substantially versus a conventional simple vertical side. In addition, by forming a trench (Tr) in advance in the non bonding region (NBR), the design resolves the problem of debris generated during the sawing process contaminating the bonding interface. This in turn strengthens fusion bonding reliability.\n\nIt is also noteworthy from a heat management standpoint. The patent precisely designs the vertical distance between the bottom surface of the bonding insulation layer and the horizontal extension surface to be 1 to 10 micrometers, allowing heat transfer efficiency to be maintained at the existing level. A modified protruding surface design that minimizes molding layer (EMC) volume is also included, raising the possibility of actually improving the heat transfer path.\n\nSamsung Electronics appears set to link this technology with existing HBM packaging technologies such as hybrid bonding and HPB (Heat Path Block) to strengthen comprehensive reliability competitiveness and expand its HBM market share.\n\nAn industry official explained that in high stack HBM of 12 layers or more, the warpage of the topmost dummy die is in fact a key variable with a major impact on yield, adding that it appears to be a forward looking technology targeting HBM5 of 16 layers or more.", "raw_url": "https://x.com/jukan05/status/2071907884737482807"}, {"post_id": "2071903552608362500", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T10:27:55+00:00", "direction": "neutral", "ticker": ["GOOGL", "META", "ASML"], "company": ["Google", "Meta", "ASML", "360", "Nvidia", "AMD", "Ulvac"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为美国 AI 超大规模企业资本支出不会大幅下降，并描述中美在 AI 领域的现代冷战态势，涉及供应链相互依赖、出口管制、稀土、EUV 等，强调美国需尽快建立稀土供应链并维护盟友关系。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Hard to see a world where US AI hyperscaler capex drops dramatically from $GOOGL to $META.\n\nWhen China entities like 360 go and claim:\n\nThey now have a \"AI cyber nuclear weapon\" that can hack Western companies and governments.\n\n(Zhou claimed Mythos was like an AI era cyber nuclear weapon, then claimed they built a Chinese equivalent).\n\nWe're probably witnessing the modern cold war.\n\nBut instead of nuclear stockpiles, it's racing to build superintelligence both offensively and defensively.\n\nWith many different \"battles\" happening concurrently like supply chain export controls between China -> Japan -> US hyperscalers.\n\nThe funny thing is that everyone still depends on one another:\n\n- US with things like rare earths and feedstock from China.\n- China with EUV to EDA and engineered substrates.\n\nSo there's still give or takes trades to build up capabilities like Nvidia/AMD AI chips access for rare-earth/magnets access.\n\nWhich is exactly why it's important for the US to build up rare earths supply chains ASAP.\n\nAnd not piss off allied supply chain chokepoints like European EUV partners with $ASML to Japanese vacuum/furnace makers like Ulvac with things like tariffs, if the US wants to use it as leverage for negotiations.\n\nBut we're getting dangerously closer to a point where supply chain interdependence is not a deterrent against escalation.\n\nEspecially as China grows closer to becoming self-reliant. And that might be the tipping point.", "raw_url": "https://x.com/aleabitoreddit/status/2071903552608362500"}, {"post_id": "2071889665289077117", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T09:32:44+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 DSpark 将获得广泛采用，并指出 Whale 减轻了中国 AI 基础设施的计算压力。未提及具体股票代码或明确投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "DSpark will see crazy adoption \nThe Whale reduced the compute pressure on Chinese AI infra", "raw_url": "https://x.com/zephyr_z9/status/2071889665289077117"}, {"post_id": "2071878284154212859", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T08:47:31+00:00", "direction": "neutral", "ticker": [], "company": ["LG Electronics", "TSMC", "Broadcom", "Marvell", "ASICLAND", "Samsung Electronics"], "bottleneck": "晶圆代工", "attribution": "RELAYED", "rebuts": null, "summary": "LG电子基于台积电制程开展ASIC设计服务，利用自研SoC能力，模式对标博通与美满，目标客户为国内外fabless公司，首款产品为机器人吸尘器芯片，采用台积电6nm工艺，并计划拓展至3nm。强调成本优势及与台积电20年合作关系，但非VCA成员。三星代工收缩可能带来溢出需求。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "LG Electronics Begins ASIC Design Service Based on TSMC Processes\n\nLG Electronics is entering the application specific integrated circuit (ASIC) design service market, leveraging its independent system semiconductor design capabilities. LG Electronics has designed system on chip (SoC) products for use in its own devices since the early 2000s, and it is now expanding this into an external service. The business model mirrors that of US semiconductor firms Broadcom and Marvell, and the target customers are domestic and overseas fabless companies.\n\nAccording to the semiconductor industry on the 30th, LG Electronics has launched its design service business centered on the SoC Center under its Chief Technology Officer (CTO). A design service involves converting a semiconductor design circuit into a physical circuit suited to a foundry's production line.\n\nUnlike a typical design house, LG Electronics provides ASIC design services. This follows the same business model as Broadcom and Marvell, with the company's in house SoC expertise developed through chips such as DQ-C serving as the foundation for the business.\n\nIts first result is a robot vacuum cleaner chipset being mass produced under the \"K On Device AI Semiconductor\" national project. The chip is produced on TSMC's 6nm (nanometer, one billionth of a meter) process based on orders from a domestic fabless company, after which LG Electronics' HS Business Division repurchases it and installs it in robot vacuum cleaners. LG Electronics is reportedly in talks on design service cooperation with several domestic and overseas customers.\n\nOne semiconductor industry official assessed, \"LG Electronics' SoC Center is a large scale specialized organization that supports the home appliance and automotive component businesses and possesses its own IP development capability,\" adding, \"From a business diversification standpoint, the strategy of deploying its high end design workforce into external design services is a competitive choice in terms of both technical stability and business efficiency.\"\n\nLG Electronics already holds an IP portfolio for processes at 6nm and below, and it reportedly plans to broaden its service scope to the 3nm (N3) process within the next three years, depending on customer demand.\n\nCost Savings Through In House Staffing... A \"30 Year TSMC Partnership\" Reference as a Strength\n\nThe competitive edge LG Electronics emphasizes is cost. Existing design houses relied on outsourced staff during the design process, resulting in high contracting costs. By contrast, LG Electronics uses a structure in which in house engineers handle the design directly, allowing it to reduce additional labor costs.\n\nIts track record is also a strength. Even after selling LG Semicon in 1999, LG Electronics retained its design organization, effectively making it a fabless company. Having lost its production plants, LG Electronics began outsourcing chip production to TSMC in the early 2000s, a partnership spanning more than 20 years.\n\nThe industry expects that, on the basis of its relationship of trust with TSMC, LG Electronics will be able to offer support such as wafer allocation for customer volumes.\n\nA fabless industry official who requested anonymity explained, \"Most design houses tend to set high contracting costs because they rely on outsourced staff due to a shortage of their own personnel,\" adding, \"LG Electronics is free from this labor cost burden and has a long standing relationship of trust with TSMC, which can make it an attractive option.\"\n\nThat said, LG Electronics is not a TSMC VCA (Value Chain Alliance). A VCA is a partner design house that has built a cooperative framework with TSMC. Under TSMC policy, outside of mainland Taiwan only one VCA may exist per country. In Korea, ASICLAND is the TSMC VCA.\n\nSpillover Benefit From Samsung Foundry's Shift in Direction... Expected to Absorb Domestic Demand\n\nThe industry also expects that the contraction of Samsung Electronics' foundry legacy processes will be a boon for LG Electronics' design service.\n\nA semiconductor industry official forecast, \"As Samsung Foundry's legacy processes contract, some customers are turning to TSMC, which has abundant legacy capacity,\" predicting, \"If LG Electronics rides this trend, it could draw in a substantial share of domestic demand.\"\n\nAn LG Electronics official responded, \"We cannot confirm the matter.\"", "raw_url": "https://x.com/jukan05/status/2071878284154212859"}, {"post_id": "2071875242365157763", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T08:35:26+00:00", "direction": "long", "ticker": ["MU"], "company": ["Micron"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "TrendForce 上调 3Q26 PC DRAM 合约价预测至 QoQ +15-20%, 4Q26 至 +3-8%; 3Q26 服务器 DRAM 预计 QoQ +13-18%. 提及 $MU.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "TrendForce:\n\n3Q26 PC DRAM contract price growth has been revised up from the previous forecast of +8–13% QoQ to +15–20% QoQ. The 4Q26 forecast was also revised up from +0–5% to +3–8%.\n\n3Q26 server DRAM contract prices are expected to rise by 13–18% QoQ.\n\n$DRAM $MU", "raw_url": "https://x.com/jukan05/status/2071875242365157763"}, {"post_id": "2071866798988026335", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T08:01:52+00:00", "direction": "neutral", "ticker": [], "company": ["Hynix", "Nvidia"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者宣布与 Hynix 和 Nvidia 合作开发 100M IOPS NAND 控制器, 用于其 CMX 解决方案.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Developing a 100M IOPS NAND controller in collaboration with Hynix &amp; Nvidia for their CMX solution", "raw_url": "https://x.com/zephyr_z9/status/2071866798988026335"}, {"post_id": "2071851376246989079", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T07:00:35+00:00", "direction": "neutral", "ticker": ["NBIS"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者回顾早期讨论 NBIS 和 Neoclouds 的时光，感谢支持，并祝贺对方账户增长。属于回顾性交流，无新投资判断。", "is_retro": 1, "is_disc": 0, "is_selfret": 0, "raw_text": "@EndicottInvests Good times, wasn’t too long ago back at 3K followers! \n\nDiscussion on $NBIS was fun back when there was a lot of debate on Neoclouds and it was still really early. \n\nThanks for the support, fun to see your account grow as well", "raw_url": "https://x.com/aleabitoreddit/status/2071851376246989079"}, {"post_id": "2071845911966400975", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-30T06:38:53+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者陈述日本加入大语言模型竞赛，为客观事实，无具体股票代码或方向性表态。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Japan joins the LLM race", "raw_url": "https://x.com/zephyr_z9/status/2071845911966400975"}, {"post_id": "2071837834416390430", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T06:06:47+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "封装", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者评论 FCBGA 产能增加，但认为对方只是在处理旧设备，无明确股票方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@blazingbees FCBGA 케파는 늘리고 있는데...저건 그냥 구형장비 처리하는거 같습니다", "raw_url": "https://x.com/jukan05/status/2071837834416390430"}, {"post_id": "2071829189905506305", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T05:32:26+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Foundry"], "bottleneck": "晶圆代工", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者称 TPU V10ax 将由三星代工制造。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "TPU V10ax will be manufactured by Samsung Foundry.\n👀 https://t.co/b19OcU6N7v", "raw_url": "https://x.com/jukan05/status/2071829189905506305"}, {"post_id": "2071826747327463477", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T05:22:43+00:00", "direction": "neutral", "ticker": [], "company": ["Xiaomi", "OPPO", "vivo"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "转述 Nikkei Asia 报道：小米、OPPO、vivo 等中国手机品牌今年出货目标下调最多 30%，因内存、PCB 及配套芯片供应严重短缺，明年新品规划也面临困难。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Nikkei Asia reported that Chinese smartphone brands such as Xiaomi, OPPO, and vivo have cut their shipment targets for this year by as much as 30%.\n\n“Even planning for new product launches next year has become extremely difficult, because we have no idea how we can actually secure the components needed for those new products,” Nikkei quoted a source as saying.\n\nIn particular, the supply shortage is reportedly severe not only for memory, but also for certain types of printed circuit boards and other supporting chips.", "raw_url": "https://x.com/jukan05/status/2071826747327463477"}, {"post_id": "2071812092907446560", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T04:24:30+00:00", "direction": "neutral", "ticker": ["TSM"], "company": ["TSMC"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": "DigiTimes 散布关于 TSMC 的恐慌叙事", "summary": "作者指责 DigiTimes 再次散布恐慌，每当出现可能威胁 TSMC 的事物时，他们就编造荒谬叙事。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "DigiTimes is spreading FUD again…\n\nAs always, whenever something looks like it could pose a threat to TSMC, they start making up all kinds of ridiculous narratives. https://t.co/djkaLAeLLM", "raw_url": "https://x.com/jukan05/status/2071812092907446560"}, {"post_id": "2071780035116364134", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T02:17:06+00:00", "direction": "neutral", "ticker": ["ASML"], "company": ["Samsung", "ASML"], "bottleneck": "光刻", "attribution": "RELAYED", "rebuts": null, "summary": "转述韩媒报道：三星将在1.4nm节点开始使用High-NA EUV光刻机，提及ASML。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "According to Korean media reports, Samsung will start using High-NA EUV from its 1.4nm node.\n\n$ASML https://t.co/CjHhgZoyga", "raw_url": "https://x.com/jukan05/status/2071780035116364134"}, {"post_id": "2071763387948859506", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-30T01:10:57+00:00", "direction": "neutral", "ticker": ["RPI", "SIVE", "JBL", "GFS", "XFAB", "AXTI", "NBIS", "ALAB", "CBRS"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者反思大V困境：安全威胁、媒体曲解为meme股、机器人诈骗、钓鱼互动、粉丝缺乏 nuance 及合规压力。提及多个 ticker 仅为举例，无投资建议。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I've reached 900k followers, thank you everyone!\n\nJust some reflection, it's actually a nightmare at higher counts...\n\nWhich is new to me, since I started at almost nothing earlier this year.\n\n1. Threats of safety, which I don't enjoy.\n\n- Random new accounts sending personal threats\n- Mysterious foreign accounts, sending coercive messages the moment I mention a foreign ticker\n\nIf I hold an opinion about a stock, I'd prefer not to have anyone show up on the street with a knife at night since it's safety risk at this point...\n\nNever felt like I'd have to take that into consideration for holding an opinion.\n\n2. Egregious media narratives\n\n- Lot of outlets try to dismiss my ideas like $RPI or $SIVE as \"meme stocks\" or me as \"meme trader\" when I talk about supply chain chokepoints or fundamental catalysts to revenue due to AI.\n\nWithout ever covering the core ideas or hyperscaler mapping I've done.\n\nI let success validate my ideas, but it's annoying when they can just pretend their claims like \"___ will imminently crash as a fact\" which ends up not happening.\n\nOr that \"___\" is just a retail meme stock without mentioning $JBL, Ayar, $GFS or others for CPO scale up or pluggables.\n\nI'm grateful to some outlets, like in Belgium for $XFAB coverage, but many others try and paint their own narrative rather than covering a very nuanced thesis objectively.\n\n- When I mention a ticker in a foreign market, some try to frame me as some \"adversarial account\"!\n\nI'm just sharing ideas, and I'll always disclose positions/financial interest if I have them.\n\nIf I say I have none, they just make up some narrative that I'm some foreign institution or random group inside their country that does.\n\nSome have even tried hilariously forging screenshots of me to harm my reputation, which was annoying to deal with. Since it's easier to textedit a photo and spread it around than it is to dispel disinformation.\n\nLot of institutions know me personally by now.\n\nI just don't go broadcasting my identity to random people in the media/public, since personal security gets expensive and I just want to live about my day.\n\n3. Endless X bot spam\n\n- I have endless hundreds of comments a day trying to link external communities pretending they're me.\n\nI manually delete, and block thousands of these accounts, sometimes hit regular people by accident.\n\nAnd it's extremely exhausting to the point my fingers cramp certain days. \n\nEven if I give the most blatant warnings in bio, people still get scammed and think it's me. Then I get blamed for it too.\n\nI actually had a conversation where someone asked if a scammer was me.\n\nI said no verbatim, then they double checked like 2-3 more times because they didn't believe I said no because someone had the same username on another scam platform.\n\nIn another world, maybe we'll get automod type tools. But until then,  it's mentally exhausting dealing with all of this. But I do so anyways since I don't want my followers to get scammed. \n\n4. Endless engagement baiting\n\n- I have tons of people making up fake stuff about me, tagging me in posts, randomly bashing my ideas while missing any technical nuance in order to get me to comment or farm views.\n\nIt's a catch 22 since the moment I reply, they get a lot of views, which was their goal. And if I don't reply it just looks like I'm avoiding something (which is not true).\n\nI'm very transparent, I always try and entertain people who disagree first. But when it gets into personal attacks or leading questions/disinformation rather than substance then I don't engage.\n\nIt's a little sad though when people I've interacted with end up caring more about engagement over relationships down the road. \n\n5. People missing the nuance\n\n- I share ideas pretty often and I always maintain I don't want people to copytrade or blindly follow, which is why I haven't set up any copytrading apps.\n\nBefore it was just posting with a few $RDDT friends on ideas like $AXTI, $NBIS, or $ALAB, and people were more knowledgeable traders. \n\nThen seeing if markets validate my guesses like with InP substrate bottlenecks. \n\nBut because many turned out directionally right, to the point it became a central talking point between China/US trade relations, lot of random folks started to follow my account last few months.\n\nBut many of them miss nuances with float dilution, or material updates along the way such as rate hikes, and I get blamed if a thesis changes.\n\nNow since there's so many random people, even if I share an idea about $CBRS last Friday.\n\nAt market open I had people panicking over a 2% drop, asking me if I did something to a $44B+ company, even if it went up 20%+ today.\n\nNow I have compliance review for posts, which delays things a lot but makes sure people don't get the wrong idea. And I have to be careful about my timing, so I post new ideas when markets close.\n\nBefore, it was just sharing ideas the moment I had them during lunch or in the shower, so this is becoming a headache.\n\n6. I post my core ideas for free. And I've always said this from the start.\n\nI actually made my subscribers chat literally by accident, and set the bare minimum amount on purpose since I didn't want to take people's money. But kept it so I could avoid the bots and not spam the main timeline with random thoughts/scrapped research.\n\nI think me becoming the #1 most subscribed to person on X was literally by accident.\n\nBut lot of weird narratives out there when media or others don't believe that I just genuinely want to share my ideas for free.\n\nAnd that people shouldn't need to pay $300 in a paywalled community to see them.\n\n_\n\nNot sure if people want to read it all, but just some things I've gone through.\n\nIt's not as much fun at higher numbers and it would be nice to go back to when I was smaller.\n\nRegardless, I'd rather not turn this into a job, or make it feel like one.\n\nWill probably take a break when I hit 1M as a milestone and do something else that will help out the community like sharing my research pipelines and such.\n\nThink a lot of my friends at 10-50K follower counts, seem to experience some of these issues too. But problems get magnified a lot at this level.\n\nI never needed the X creator fees or anything, just wanted to share ideas for fun if people wanted to listen.\n\nAnd didn't expect any popularity, but it's nice to see that people find my ideas compelling.", "raw_url": "https://x.com/aleabitoreddit/status/2071763387948859506"}, {"post_id": "2071762447304995212", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T01:07:13+00:00", "direction": "neutral", "ticker": [], "company": ["MediaTek"], "bottleneck": "晶圆代工", "attribution": "ORIGINAL", "rebuts": "反驳北美卖方/买方认为 MediaTek v8t 进展慢于 v8i 且已延迟的观点", "summary": "作者列出 MediaTek 各项目进展: v8t 量产早于 v8i, v9 是唯一 2nm 项目, v10 稳固而其他不确定, 并反问北美卖方/买方是否曾称 v8t 进展更慢且延迟.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "•v8: MTK’s v8t to start volume earlier than that of v8i •v9: MTK’s Humufish/Triggerfish is by now the only 2nm project  •v10: MTK’s Icefish to be solid, while others uncertain\n\nInteresting. Didn’t North American sell-side / buy-side say that MediaTek’s v8t was progressing more slowly than v8i and had been delayed?", "raw_url": "https://x.com/jukan05/status/2071762447304995212"}, {"post_id": "2071761135980937521", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-30T01:02:00+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electronics", "Applied Materials", "Lam Research", "ASML", "TSMC", "Intel", "Tesla"], "bottleneck": "晶圆代工", "attribution": "ORIGINAL", "rebuts": null, "summary": "三星启动1.4nm晶圆代工工艺开发，目标2029年量产，已要求应用材料、泛林等合作伙伴提前开发设备，ASML高NA EUV已引入研发中心。此前为提升2nm良率推迟1.4nm，现2nm已获特斯拉AI芯片订单。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Samsung Begins Full Scale Advance Development of \"1.4 Nanometer\" Process\n\nSamsung Electronics is restarting its push toward commercializing the 1.4nm foundry process (SF1.4). The 1.4nm process, which was originally targeted for mass production in 2027, has had its schedule adjusted and development is now proceeding with a mass production target of 2029.\n\nIt is understood that Samsung has recently asked domestic and overseas partners to begin advance development of equipment for the process. The equipment is set to be brought into NRD-K, Samsung Electronics' next generation semiconductor research and development (R&D) hub.\n\nAccording to industry sources on the 25th, Samsung Electronics recently shared its 1.4nm process plans with major semiconductor equipment makers such as Applied Materials (Applied) and Lam Research. Along with this, it is reported to have requested advance development of equipment.\n\nApplied and Lam Research are key equipment partners for Samsung Electronics. Equipment from these companies is widely applied across both foundry and memory processes.\n\nThese companies develop equipment in cooperation with chipmakers such as Samsung Electronics starting from the process development stage. The structure is one in which the required equipment specifications are presented and the equipment is then designed and developed to match them.\n\nThe 1.4nm process that Samsung Electronics is preparing to commercialize was a technology originally targeted for mass production next year. However, the company adjusted the 1.4nm mass production schedule to 2029 in order to concentrate its capabilities on securing the competitiveness of the 2nm (SF2) and the 2nm derivative process (SF2P).\n\nThe decision was aimed at building internal strength by focusing on yield stabilization and optimization of existing processes rather than forcing the leading edge process ahead prematurely.\n\nThe strategy appears to have paid off. Samsung Electronics stabilized the yield of its 2nm process and went on to succeed in winning orders for the production volume of Tesla's next generation artificial intelligence (AI) chip.\n\nHaving delivered results on the 2nm process, the company now appears to be moving into preparation for its next generation process. The next generation equipment developed by partners will be brought into NRD-K and used for 1.4nm process development.\n\nASML's next generation lithography equipment, the high NA extreme ultraviolet (EUV) tool, has already been brought into NRD-K. High NA EUV is understood to be applied to some layers starting from the 1.4nm process.\n\nDomestic partners are also closely watching the trends in Samsung Electronics' next generation process development. As process difficulty continues to rise, sufficient development time is needed to develop equipment that matches the process specifications required by the customer.\n\nAs Samsung Electronics again picks up the pace on 1.4nm process development, attention is focused on whether it can narrow the technology gap with competitors such as TSMC. TSMC is targeting commercialization of its 1.4nm process in 2028. Intel is proceeding with development aimed at mass production next year.\n\nIn addition, Samsung Electronics is understood to have also requested equipment orders for the development of its next generation V12 NAND. V12 NAND is expected to enter full scale mass production around 2030. As it applies a structure that stacks multiple wafers, its storage capacity and performance are significantly improved compared with existing NAND.\n\nA senior official at a global semiconductor equipment company explained that equipment makers discuss with chipmakers from the early stages when they develop a next generation process, and that there are many cases where equipment is developed to match the process requirements.", "raw_url": "https://x.com/jukan05/status/2071761135980937521"}, {"post_id": "2071745275325190339", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T23:58:59+00:00", "direction": "neutral", "ticker": ["MU", "SNDK"], "company": ["Micron", "SanDisk", "Samsung", "SK Hynix", "Kioxia"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "分析内存行业长期协议(LTA)的结构性变化：供应商高利润率下客户主动提出3-5年LTA，覆盖2028年后，表明供应短缺不会短期结束。对比美光、三星、SK海力士的LTA条款差异，指出五家供应商均签署类似LTA，标志着内存商业模式的根本转变。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "KIS: On Memory LTAs\n\nWith suppliers' commodity DRAM operating margins already at 80% and gross margins above 90%, prices cannot be raised endlessly on supply and demand dynamics alone. What matters is that at price levels where supplier operating margins exceed 80%, it was the customers, not the suppliers, who first actively proposed three to five year long term agreements. The customers are not unaware of Samsung and SK Hynix's fab plans, and they know that new fab output begins contributing to supply from 2028 onward. The fact that they nonetheless proposed long term agreements covering 2028 and beyond first is evidence that the memory supply shortage will not end within a short period. The key point is that suppliers have used this to secure, for the first time in memory history, a contract structure that sustains high margins over an extended period.\n\nComparing Micron's LTA with those of Samsung and SK Hynix, SK Hynix has only a price floor with no price ceiling, while Samsung, similar to Micron, is understood to include both a price ceiling and a price floor in its LTA terms. The structure of collecting a portion of annual revenue upfront as advance payments is also similar. The advance payment is a binding condition that prevents arbitrary volume changes after the contract is signed. However, unlike SanDisk, Samsung, and SK Hynix, Micron's advance payment is presumed to be structured as refundable upon maintenance of the contract rather than deducted from revenue. The LTA contract period is similar across all memory suppliers at three to five years per customer. Customers who have already completed their contracts maintain three to five year terms beginning in 2Q26 and running through 2028 or 2030. The fact that all five memory suppliers (Samsung, SK Hynix, Micron, Kioxia, SanDisk), and not a single supplier alone, are signing similar three to five year LTAs is what explains the structural change in the memory business model.", "raw_url": "https://x.com/jukan05/status/2071745275325190339"}, {"post_id": "2071743355684626656", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T23:51:21+00:00", "direction": "long", "ticker": ["SNDK", "MU", "AAOI"], "company": ["SanDisk", "Micron", "Applied Optoelectronics"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为市场轮动从存储（SNDK到MU）转向光通信，预计资金将回流光子学，个人最高仓位集中于此，明确看多光通信。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@gurukid5995 Markets tend to rotate from bottleneck to bottleneck.\n\nMemory from $SNDK to $MU was the market's main focus this month, while optical names like $AAOI corrected.\n\nI think we'll see a rotation back into photonics eventually, it's personally my highest concentration theme.", "raw_url": "https://x.com/aleabitoreddit/status/2071743355684626656"}, {"post_id": "2071730699363881241", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T23:01:04+00:00", "direction": "long", "ticker": ["6324", "VPG", "688017"], "company": ["Harmonic Drive", "Vishay Precision", "LeaderDrive", "Schaeffler", "Unitree", "Agility Robotics"], "bottleneck": "机器人", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者看好机器人公司 Unitree 和 Agility Robotics，重仓 Agility Robotics。持有上游零部件 Harmonic Drive (6324) 和 Vishay Precision (VPG)，看好 LeaderDrive (688017) 和 Schaeffler 但未持有。强调仅为个人持仓分享，不构成投资建议。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "For robotics companies, I have a favorable view on Unitree and Agility Robotics, two humanoid players. \n\nAnd I have largest concentration in Agility Robotics, since I personally prefer US humanoid players. \n\nFor upstream component exposure, I currently own:\n\n- Harmonic Drive (6324) given high content BOM on things like harmonic reduction gear. \n- Vishay Precision for sensors and a possible candidate for Telsa Optimus.  \n\nLeaderDrive (688017) and Schaeffler I have favorable views on but don't own personally. \n\nMany of the other AI DC players, I have indirect exposure to robotics like memory. \n\nDon't recommend anyone to copy, just sharing personal positions/thoughts. \n\nHumanoid sector is large, and as seen with Goldman Sachs report that \"Korean companies will command a 30% direct and indirect share of global humanoid robot production\". \n\nLot of players out there globally. This was an older report but just linking it again since you see all of them pop up in GS institutional reports + what they cover.\n\nAgility Robotics is my personal favorite as of now.", "raw_url": "https://x.com/aleabitoreddit/status/2071730699363881241"}, {"post_id": "2071697032440611185", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T20:47:17+00:00", "direction": "neutral", "ticker": [], "company": ["Ascend"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提到 384s 芯片，并称有传言称 long cat 2.0 正在 Ascend 上训练已流传一个多月，可在推特上找到。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@zugzwangg_ @teortaxesTex Clearly 384s\nBtw, rumors long cat 2.0 being trained on Ascend has been floating around for over a month\nU can find it on twitter too", "raw_url": "https://x.com/zephyr_z9/status/2071697032440611185"}, {"post_id": "2071591263024144823", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T13:47:00+00:00", "direction": "long", "ticker": [], "company": ["Gigadevice"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者明确表态 mega bullish Gigadevice，看多该半导体公司。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@VagabondWa Yes, mega bullish Gigadevice", "raw_url": "https://x.com/zephyr_z9/status/2071591263024144823"}, {"post_id": "2071571547928838631", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T12:28:39+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": "反驳“所有 token 都一样”的观点，认为美国前沿模型仍领先中国模型", "summary": "作者反驳“所有 token 都一样”的观点，认为美国前沿模型在质量和智能上仍领先中国模型，并比喻当前 AI 企业采用率不足 1%，未来需要更强大的模型。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Utter nonsense.\n\nNot all tokens are created equal. The quality and intelligence behind each token vary, and the outputs of leading U.S. frontier models still maintain a clear edge over their Chinese counterparts.\n\nSome people ask, “Why drive a Lamborghini just to go grocery shopping?” But remember: AI adoption among enterprises is still below 1%.\n\nThere will be many more tasks going forward that require a Lamborghini. And there’s a good chance even a Lamborghini won’t be enough, we may end up needing a Formula 1 car.", "raw_url": "https://x.com/jukan05/status/2071571547928838631"}, {"post_id": "2071545016007467486", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T10:43:13+00:00", "direction": "neutral", "ticker": ["ASTS", "SPCX"], "company": ["Rakuten", "AST SpaceMobile", "Starlink"], "bottleneck": "LEO", "attribution": "RELAYED", "rebuts": null, "summary": "日本乐天与AST SpaceMobile成立合资公司，在日本建设低轨卫星网络，被视为应对Starlink在日影响力增长的策略。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Japan's Rakuten to establish joint venture with $ASTS to build out LEO satellite networks for Japan per Digitimes/Nikkei. \n\n\"The move is widely viewed as a strategic response to the growing influence of $SPCX Starlink in Japan\" https://t.co/RDFvgQNVsp", "raw_url": "https://x.com/aleabitoreddit/status/2071545016007467486"}, {"post_id": "2071532870859149617", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T09:54:58+00:00", "direction": "neutral", "ticker": ["GM", "NVDA", "AMZN"], "company": ["General Motors", "NVIDIA", "Amazon"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者引用报道称通用汽车裁员1000人并用50台机器人替代，同时与英伟达合作工厂机器人，认为这是机器人行业验证，预示自动化提升利润率和效率，但担忧未来就业损失。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "$GM cuts 1,000 workers and replaces them with 50 robots (Jun 22nd report)\n\nReports also show GM is working on a deal with $NVDA on factory robotics.\n\nThis is industry validation for robotics, since it likely demonstrates increased opex margins + efficiency from employee automation. \n\nEspecially from companies like $AMZN to General Motors with assembly/warehouse lines that have high headcount.\n\nI think the technology is already here and use cases are already proven. Robotics/Humanoids are just pre-scale right now. \n\nThe wording from large companies is “assistive robotics”… But in all honesty, it’s here to automate away the human workforce and increase profitability.\n\nI don’t think companies want to be paying insurance, salaries, etc. when robots can do a better job, and 24/7, so very sad to see potential job losses in the future from robotics automation.\n\nWhether people like it or not; seems like the inflection point for robotics is here.", "raw_url": "https://x.com/aleabitoreddit/status/2071532870859149617"}, {"post_id": "2071530841776492559", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T09:46:54+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出内存占 Capex 40% 是巨大问题，但内存带宽/$ 尚未下降，且内存带宽制约推理。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bookwormengr Memory being 40% of total Capex is a huge issue\nBut even after this crazy inflation, memory bandwidth/$ has not fallen yet (very surprising fact)\nAnd as u know, memory bandwidth gates inference", "raw_url": "https://x.com/zephyr_z9/status/2071530841776492559"}, {"post_id": "2071529663936319559", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T09:42:13+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "晶圆代工", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出大家都在争抢相同的 DUVi、刻蚀/沉积设备，认为 WFE 子系统未来两年将大幅增长。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Everyone is fighting for the same DUVi, etch/deposition tools\n\nWFE sub systems are going to rip hard in the next 2 years", "raw_url": "https://x.com/zephyr_z9/status/2071529663936319559"}, {"post_id": "2071511133362754018", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T08:28:35+00:00", "direction": "neutral", "ticker": [], "company": ["OpenAI", "Anthropic", "Nebius"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为欧美企业将放弃 OpenAI 和 Anthropic 转向中国模型，但指出 Nebius 等公司缺乏支撑此趋势的规模和算力。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "\"American and European enterprises will ditch OpenAI and anthropic and adopt Chinese models.\"\nI love fireworks, Nebius et al\nBut they don't have the scale or compute required to support this", "raw_url": "https://x.com/zephyr_z9/status/2071511133362754018"}, {"post_id": "2071508897203101704", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T08:19:42+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "GPU", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出本地部署的最大约束是 GPU/内存不足，并预测美国政府将很快推出中国操作系统模型禁令。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@TheAhmadOsman Not enough GPU/memory for on prem deployment (biggest constraint)\nUSG will likely roll out China OS model bans soon", "raw_url": "https://x.com/zephyr_z9/status/2071508897203101704"}, {"post_id": "2071507097330856394", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T08:12:33+00:00", "direction": "neutral", "ticker": [], "company": ["Apple", "CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者称苹果希望采购 CXMT 内存用于中国市场，非出口用途。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Well, Apple wants CXMT's memory for the Chinese market \nNot for exports", "raw_url": "https://x.com/zephyr_z9/status/2071507097330856394"}, {"post_id": "2071506152551240066", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T08:08:48+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "GPU", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表达对本地部署获取 GPU 和内存的悲观态度，未提及具体股票或公司，属于客观陈述。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Good luck getting GPUs and memory for on prem deployment", "raw_url": "https://x.com/zephyr_z9/status/2071506152551240066"}, {"post_id": "2071505730243551264", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T08:07:07+00:00", "direction": "neutral", "ticker": ["POET"], "company": ["POET Technologies"], "bottleneck": "激光器", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者阅读 POET AGM 记录, 发现 POET 称激光器厂商未来两年完全售罄, 暗示激光器瓶颈可能延续至 2029 年.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Nah, I actually read the whole $POET AGM transcript in the shower. And then compared what they said, compared to what markets might have known already.\n\nThis was manual since it’s on some random GitHub page rather than officially published yet afaik. \n\nThen I just learn interesting insights from statements like $POET confidently saying laser players are completely sold out next two years.\n\nSince it’s signal for laser bottleneck likely extending into 2029 thematically.", "raw_url": "https://x.com/aleabitoreddit/status/2071505730243551264"}, {"post_id": "2071505314357375275", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T08:05:28+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT", "Apple"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "KIS 评论 Reuters 关于 CXMT 的报道: 苹果从 CXMT 采购 DRAM 不易, 因中国可能限制 CXMT 供应外国公司, 且 CXMT 产能已转向 DDR 支持国内数据中心, 导致中国手机厂商 DRAM 短缺, 稀缺产能不会优先给苹果. 整体上 CXMT 未增加供应压力, 三大 DRAM 厂供应美国数据中心已不足, CXMT 产能连中国公司需求都难满足.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "KIS’ comment on Reuters’ report regarding CXMT’s LTA:\n\n“For several reasons, it does not seem easy for Apple to purchase DRAM from CXMT. Regardless of whether the U.S. government removes CXMT from the Entity List, it now seems more likely that the Chinese government could restrict CXMT DRAM from being supplied to foreign companies.\n\nFrom China’s perspective, most of CXMT’s capacity has been shifted from LPDDR to DDR in order to support domestic data centers. As a result, Chinese smartphone makers are suffering from an even more severe DRAM shortage. Given this situation, it seems highly unlikely that scarce CXMT DRAM would be prioritized for Apple rather than domestic smartphone companies.\n\nFrom an overall memory supply perspective, the article above also shows that CXMT is not currently creating additional supply pressure. The top three DRAM makers are already short of supply even in supporting U.S. data centers, while CXMT’s capacity is insufficient even to support Chinese companies that cannot secure enough DRAM from those top three suppliers.”", "raw_url": "https://x.com/jukan05/status/2071505314357375275"}, {"post_id": "2071497488415252777", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T07:34:22+00:00", "direction": "neutral", "ticker": ["MRVL"], "company": ["Marvell"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者暗示 Marvell 有更多未公开信息或发展，但未明确表达看多或看空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "The Marvell puzzle has more pieces 😏😏 https://t.co/gePuS9OFtp", "raw_url": "https://x.com/zephyr_z9/status/2071497488415252777"}, {"post_id": "2071493369856229433", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T07:18:00+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者转述一位“内存游客”称 CXMT 将以廉价 DRAM 冲击市场，但以惊恐表情表达，未明确自身建仓方向，按反问/不确定归 neutral。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "But a memory tourist told me CXMT will flood the market with cheap DRAM 😱😱😱", "raw_url": "https://x.com/zephyr_z9/status/2071493369856229433"}, {"post_id": "2071492231840846107", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T07:13:29+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT", "Tencent", "Alibaba Cloud", "ByteDance", "Xiaomi"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "转推路透: CXMT 与腾讯签 30 亿美元长协, 并与阿里云、字节、小米洽谈; Q1 DDR5 良率仍落后西方; 合肥两座 12 英寸厂加北京一座, 月产能约 30 万片.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Even Chinese companies are signing LTAs now lol\n\nRTRS:\n\n- China’s CXMT has signed a $3 billion LTA with Tencent.\n- CXMT is also in talks with other Chinese internet companies, including Alibaba Cloud, ByteDance, and Xiaomi.\n- As of Q1, CXMT’s DDR5 yields still lagged behind Western peers.\n- CXMT currently operates two 12-inch DRAM fabs in Hefei and one fab in Beijing, with total wafer capacity of around 300k wafers per month.", "raw_url": "https://x.com/jukan05/status/2071492231840846107"}, {"post_id": "2071488272245944399", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T06:57:45+00:00", "direction": "long", "ticker": ["POET", "LITE", "SIVE", "AAOI"], "company": ["POET Technologies", "Lumentum", "Sivers Semiconductors", "Applied Optoelectronics"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者分析 POET 年会及光通信市场：激光器短缺延续至2029，POET 与 SIVE 合作高功率外部光源，Lumilens 协议预计5年超5亿美元，POET 产能将扩10倍。作者未持仓但认为若管理层实现预测则前景积极，同时指出 POET 客户透明度不如 AAOI。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "Just some notes on $POET AGM and read through on optical markets:\n\n- \"The top three laser suppliers control 68% of the market, and they’re completely sold out for the next two years\"\n\n$LITE CEO said into 2028, so POET implicitly confirms laser shortage is going into 2029 now.\n\n- NRE with a new customer, building on POET’s interposer for high-power external light source.\n\nThis is high confidence $SIVE as laser supplier given the Sept 29, 2025 PR on ELS, and new customer qualification would be material for revenue if it goes into volume ramp. \n\n- Poet expects Lumilens commercial agreement to scale to over $500 million over the next 5 years.\n\nLumilens claimed a top-3 hyperscaler was their initial customer (Linkedin OSINT)\n\n- $830M cash on hand on balance sheet (this is more for Poet fundamentals).\n\n- \"The entire optical components industry today is facing a severe shortage of critical components.\"\n\nReaffirming what we know already regarding optical bottlenecks.\n\n- \"Production ramp in the second half of 2026 this year.\" \n\nJust production timelines H2. \n\nIn terms of $POET volumes:\n- existing capacity around 1 million optical engines per year\n- projected demand exiting 2027 around 1 million optical engines per month\n- roughly 10x capacity expansion\n\nI don't own Poet, but if management delivers on these projections it directionally looks very positive.\n\nHowever something to note is that unlike other suppliers that have named hyperscaler customers to to back up capacity revenues like $AAOI: $POET seems more questionable.\n\nBut this does look like a very positive outlook for $POET if they match projections.", "raw_url": "https://x.com/aleabitoreddit/status/2071488272245944399"}, {"post_id": "2071465314794233905", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-29T05:26:31+00:00", "direction": "long", "ticker": ["RKLB", "SPCX", "EOS.ASX", "LITE", "TSLA"], "company": ["Rocket Lab", "SpaceX", "Electro Optic Systems", "Lumentum", "Tesla", "Anthropic", "OpenAI", "Boston Dynamics", "Unitree", "Waymo"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者列举 2020-2030 年多项突破性技术（可复用火箭、ASI、人形机器人、激光、自动驾驶、量子计算），认为这是投资黄金时代，提及 RKLB、SPCX、EOS.ASX、LITE、TSLA 等标的，整体看多。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Honestly this decade from 2020-2030 might be the most goated in human history.\n\n- Scaling massive reusable rockets for orbital compute with $RKLB to $SPCX.\n\n- on the cusp of ASI and recursive learning with Anthropic and OpenAI \n\n- Backflipping Boston Dynamics and Unitree humanoids to replace the human workforce\n\n- Star Wars laser beams from $EOS.ASX to AI DC lasers like $LITE.\n\n- Waymo and $TSLA self driving cars everywhere in urban cities\n\n- and we get industry Quantum commercialization end of decade\n\nThis is kinda crazy to be an investor in this timeframe. Feels like every movie from the Star Wars Death Star to Skynet is coming to life.\n\nWhat’s next?", "raw_url": "https://x.com/aleabitoreddit/status/2071465314794233905"}, {"post_id": "2071416090459341044", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T02:10:55+00:00", "direction": "neutral", "ticker": ["ACMR"], "company": ["BOE", "ACM Research"], "bottleneck": "Substrate", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 BOE 在玻璃基板领域很强，建议密切关注，并提到 ACMR 将为其供应 Ultra ECP 工具。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "BOE is very strong in glass substrates\nWatch them closely\nACMR will supply them with their Ultra ECP tool", "raw_url": "https://x.com/zephyr_z9/status/2071416090459341044"}, {"post_id": "2071395435605053877", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-29T00:48:51+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "反驳银行认为 CXMT 将在 27-28 年花费 250 亿美元 CAPEX 的观点", "summary": "作者认为 CXMT 未来两年没有产能倾销内存，将产生 1300 亿美元毛利，质疑银行对其 27-28 年 CAPEX 的预测明显错误。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Yup, it's gross profit generation time\nCXMT doesn't have the capacity to dump memory for the next 2 years\nNow the big question is what they do with the $130B in gross profits generated\nFor some reason, banks believe that CXMT will just spend $25B on CAPEX in 27 & 28, which is clearly wrong", "raw_url": "https://x.com/zephyr_z9/status/2071395435605053877"}, {"post_id": "2071388270530039938", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T00:20:22+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "反驳那些自称专家的人说中国会倾销内存", "summary": "作者表示过滤掉那些声称中国将倾销内存的自称专家有助于形成更好的判断，未明确表达多空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@notvikingpm Just filtering out the self-proclaimed experts who keep saying China will dump memory already helps a lot in forming a better judgment.", "raw_url": "https://x.com/jukan05/status/2071388270530039938"}, {"post_id": "2071387254409605525", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T00:16:20+00:00", "direction": "neutral", "ticker": [], "company": ["Apple", "CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者质疑苹果故意泄露 CXMT 内存审批无望的消息，以合理化自身涨价并妖魔化内存厂商，同时表示不理解对方暗示哪个子行业会受益。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Ultimately, Apple leaked this to the press knowing full well that approval to use CXMT memory is unlikely, just to justify its own price hikes, right? And as a bonus, they get to demonize the memory makers too.\n\nBut I still don’t understand which subsector you’re implying will benefit from this.", "raw_url": "https://x.com/jukan05/status/2071387254409605525"}, {"post_id": "2071384670365950025", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-29T00:06:04+00:00", "direction": "long", "ticker": [], "company": ["SK Hynix"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表示兑现保险并买入 2x 杠杆 SK Hynix，属于持仓披露，方向看多。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "@citrini I cashed out my insurance and bought 2x leveraged SK Hynix.", "raw_url": "https://x.com/jukan05/status/2071384670365950025"}, {"post_id": "2071366174408085902", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T22:52:34+00:00", "direction": "neutral", "ticker": ["TSM", "2344.TW"], "company": ["TSMC", "Winbond"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "TSMC 与 Winbond 合作开发 WoW 3D 堆叠技术，Winbond 供应 DRAM 晶圆，TSMC 将其与逻辑晶圆堆叠用于 AI 芯片，旨在多元化存储供应链并强化台湾本土供应稳定性。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": ">>TSMC Teams Up with Winbond to Build a Homegrown DRAM Supply Chain for AI \n\n• Amid deepening global memory shortages, TSMC has brought Winbond into its AI chip supply chain. The two companies will collaborate on next generation WoW (Wafer on Wafer) 3D stacking technology, with Winbond supplying DRAM wafers and TSMC stacking them with logic wafers for use in AI chips.\n\n• TSMC has historically relied on Samsung Electronics, SK Hynix, and Micron, but as the supply shortage has intensified, it is seen as moving to diversify its sourcing. The industry views this partnership not as a simple supply agreement but as part of a TSMC strategy to cultivate a memory supply chain within Taiwan and strengthen the supply stability of its AI chips. Winbond, for its part, is expected to use this as a springboard to enter the AI server and high performance computing supply chains in earnest.", "raw_url": "https://x.com/jukan05/status/2071366174408085902"}, {"post_id": "2071303139115122698", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T18:42:05+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出如果没有 Dspark，Whale 需要 4-5 倍算力才能维持相同吞吐量，属于技术比较，无明确投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bookwormengr these guys don't realize that without Dspark, the Whale will need a 4x-5x larger compute footprint to serve at the same throughput", "raw_url": "https://x.com/zephyr_z9/status/2071303139115122698"}, {"post_id": "2071301851870588964", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T18:36:59+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者回复他人，确认 HBM4 仍基于 1b 制程，属技术事实陈述，无明确多空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@evrgn11112231 @racetrack275 yes\nhbm4 is still on 1b", "raw_url": "https://x.com/zephyr_z9/status/2071301851870588964"}, {"post_id": "2071293192058871923", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T18:02:34+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 HBM 短期内不会到来，供应不足且良率问题多，属于产业事实陈述，未明确看多或看空具体股票。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "16 Hi HBM ain't coming anytime soon\nNot enough supply &amp; lots of yield issues", "raw_url": "https://x.com/zephyr_z9/status/2071293192058871923"}, {"post_id": "2071285255450083579", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T17:31:02+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung", "Hynix", "Micron"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者说明 EUV 使用取决于节点：三星和海力士在 2021 年 D1a 节点使用 EUV，美光在 2025 年 D1c 节点才采用 EUV，此前均使用 DUVi。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bubbleboi EUV use depends on the node\nSamsung used EUV in 2021 with their D1a node\nHynix also used EUV in 2021 with their D1a node\nMicron adopted EUV later in its D1c node in 2025\nBefore that, D1x/D1y/D1z all just used DUVi, and Micron used only DUVi for 1a/1b as well", "raw_url": "https://x.com/zephyr_z9/status/2071285255450083579"}, {"post_id": "2071282946452148327", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T17:21:51+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 3D DRAM 不需要 EUV 光刻, 使用旧节点即可完成, 属于技术事实陈述, 无投资方向.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bubbleboi U don't need EUV for 3D DRAM (this is done on older nodes)", "raw_url": "https://x.com/zephyr_z9/status/2071282946452148327"}, {"post_id": "2071278289893929210", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T17:03:21+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者声称 3D DRAM 可扩展至 10 亿节点且无需 EUV，提及 HBM3E。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Check 3D DRAM, and u can scale till 1b node without EUV (HBM3E)", "raw_url": "https://x.com/zephyr_z9/status/2071278289893929210"}, {"post_id": "2071195645499818062", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T11:34:57+00:00", "direction": "short", "ticker": ["AAPL"], "company": ["Apple"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者预期苹果明年出货量将大幅下滑，因苹果在排队中非常落后。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@rwang07 I expect Apple to face a significant decline in shipments starting next year. Apple is very late in the queue.", "raw_url": "https://x.com/jukan05/status/2071195645499818062"}, {"post_id": "2071194390450831526", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T11:29:58+00:00", "direction": "neutral", "ticker": ["AAPL"], "company": ["Apple"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": "反驳苹果市场份额增长代表实际出货量增长的观点", "summary": "作者指出苹果市场份额上升是因为整体市场萎缩，实际出货量持平，并非真正增长。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@rwang07 Even if Apple appears to be gaining market share, its actual shipment volume is basically flat. Its share is only rising because the overall market itself is shrinking, so simply maintaining shipments is enough to gain share.", "raw_url": "https://x.com/jukan05/status/2071194390450831526"}, {"post_id": "2071190579082646015", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T11:14:49+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者反驳对方观点，指出内存不像石油那样钻个洞就能从地里冒出来，强调内存生产并非简单资源开采。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@Aion19834333 @GavinSBaker Are you stupid? Memory doesn’t just come out of the ground like oil when you drill a hole.", "raw_url": "https://x.com/jukan05/status/2071190579082646015"}, {"post_id": "2071188353131962740", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T11:05:58+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "DRAM", "attribution": "RELAYED", "rebuts": "反驳 DRAM 只是可被中国产品随时替代的大宗商品", "summary": "作者引用 Gavin Baker 在 All-In 的发言，指出 Elon Musk 将 DRAM 视为最重要瓶颈并优先投入 Terafab，以此反驳 DRAM 只是普通商品的观点，强调其战略重要性。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Listen to what @GavinSBaker said on All-In at 1:04:06:\n\n“DRAM is the most important bottleneck, and Elon is focusing the Terafab on memory because he believes memory is the most important bottleneck. Not lasers, not capacitors, not power semis, not NAND, not HDDs. DRAM.”\n\nEven Elon is prioritizing memory, specifically DRAM, as the key focus for the Terafab.\n\nAnd yet, do you still think DRAM is just a commodity that can be replaced by Chinese products at any time?\n\nThis is Elon validating the strategic importance of DRAM.", "raw_url": "https://x.com/jukan05/status/2071188353131962740"}, {"post_id": "2071181361956983138", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T10:38:12+00:00", "direction": "neutral", "ticker": ["AAPL"], "company": ["Apple"], "bottleneck": null, "attribution": "RELAYED", "rebuts": null, "summary": "转推 Counterpoint Research 分析: 预计 Apple 2026 年在智能手机、平板、PC 市场份额将创历史新高.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "According to the latest analysis from Counterpoint Research, Apple is expected to achieve record-high market share across smartphones, tablets, and PCs in 2026.\n\n$AAPL https://t.co/NBFB5rySra", "raw_url": "https://x.com/jukan05/status/2071181361956983138"}, {"post_id": "2071177572910850097", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T10:23:08+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electro-Mechanics", "Sumitomo Chemical", "Dongwoo Fine-Chem"], "bottleneck": "Substrate", "attribution": "RELAYED", "rebuts": null, "summary": "韩媒报道三星电机与住友化学本周将签署玻璃基板合资协议，总投资5000亿韩元，三星电机持股过半，计划2028年初投产。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Korean media reported that Samsung Electro-Mechanics is expected to sign a formal agreement this week with Sumitomo Chemical to establish a glass substrate JV.\n\nThe two companies will invest KRW 500 billion, or about USD 320 million, to set up the entity. Samsung Electro-Mechanics is expected to own more than half of the JV and contribute around KRW 300 billion. The plan is reportedly to establish the entity at the Pyeongtaek site of Dongwoo Fine-Chem, Sumitomo Chemical’s Korean subsidiary, and begin operating production equipment in early 2028.", "raw_url": "https://x.com/jukan05/status/2071177572910850097"}, {"post_id": "2071164721299112316", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-28T09:32:04+00:00", "direction": "long", "ticker": ["SHA0", "TSLA"], "company": ["Schaeffler", "Nabtesco", "Sanhua", "Tesla"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 Schaeffler 是汽车零部件厂商涉足人形机器人的理想例子，与45家人形机器人厂商合作，覆盖轴承、齿轮箱等，可占BOM约50%，目标10%市场份额。但2030年营收预测仅数亿欧元，若按Elon市场预测则极度保守。提及Nabtesco做关节、Sanhua供Tesla Optimus。这些公司因汽车业务拖累估值偏低，但人形机器人和AI汽车（台积电董事长提及）将是2027年后催化剂。作者认为需先有ChatGPT式下游突破，目前机器人收入占比仅约1%，市场关注内存、MLCC等瓶颈。未来可能出现类似HBM的意外需求。整体看好人形机器人对汽车零部件企业的长期拉动。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Yup, Schaeffler $SHA0 is the ideal example for automotive players.\n\n~ €7.47B MC auto player.\n- but also working with 45 humanoid players (extremely insane number, they do have €5.14b debt, EV is higher)\n- covers bearings, gearboxes, sensors/ECUs, actuators, power electronics.\n-ests. They can be roughly 50% BOM of a humanoid \n- targeting 10% market share of that.\n\nBut only projecting a few hundred million revenue by 2030 (extremely sandbagged) if we’re using Elon’s projections for the market.\n\nThen’s theres auto players like Nabtesco (6268) for joints. And then Sanhua in China for $TSLA Optimus.\n\nMany of them are trade at lower valuations from drag from auto.\n\nBut humanoids + AI Auto (TSM chairman cited this as a growth vector) should be a good catalyst past 2027 for automotive players. \n\nIMO there just needs to be a ChatGPT/Anthropic breakout downstream leader first for humanoids.\n\nThat brings up the entire ecosystem that has robotics exposure. \n\nBut as of now it’s probably like 1% of many of their overall revenue figures, and markets are focusing on immediate upside from bottlenecks like memory or MLCC.\n\nI’m sure we’ll see some random Toto-HBM type surprise as different humanoid architecture evolve.", "raw_url": "https://x.com/aleabitoreddit/status/2071164721299112316"}, {"post_id": "2071140098851373137", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-28T07:54:14+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出内存带宽对解码至关重要并决定收入，未提及具体股票或方向性建议。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Memory bandwidth matters for decode and determines ur revenue", "raw_url": "https://x.com/zephyr_z9/status/2071140098851373137"}, {"post_id": "2071139712082022855", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T07:52:41+00:00", "direction": "long", "ticker": ["MU", "NVDA"], "company": ["Micron", "Nvidia"], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": "反驳市场仍用 Nvidia 框架看待 Micron，认为推理的 ROI 更依赖内存而非 GPU", "summary": "作者认为 MU 未来可能比 NVDA 更重要，因为推理直接与金钱挂钩，GPU 在推理中常因内存瓶颈而闲置，增加内存对推理 ROI 更有价值，呼吁跳出 Nvidia 框架看 Micron。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Yes, MU is not Nvidia.\n\nBut going forward, it may become even more important than Nvidia.\n\nThink about it. Inference is now directly tied to money. But inference does not get better simply by adding more Nvidia GPUs. In fact, GPUs are often underutilized in inference, sitting idle due to memory bottlenecks.\n\nFor inference, adding more memory is far more valuable.\n\nUltimately, the ROI of inference depends less on GPUs and more on memory. So why are people still looking at Micron through Nvidia’s framework?\n\nThink bigger.\n\nInference is memory.", "raw_url": "https://x.com/jukan05/status/2071139712082022855"}, {"post_id": "2071135874100990438", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-28T07:37:26+00:00", "direction": "long", "ticker": ["META", "NBIS", "GOOGL"], "company": ["Meta", "Nebius", "Google"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者推测 Meta 3 月与 NBIS 等 Neocloud 签大单是因 Google 限制其算力容量, 认为这利好 AI 数据中心资本支出, 因超大规模云商容量远低于需求且无法互相依赖.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Guess we finally found why $META signed massive agreements with Neoclouds like $NBIS back in March...\n\nAnd why Gemini got super nerfed. \n\n$GOOGL reportedly restricted Meta's capacity in March 2026 because of compute restraints. \n\nGoogle's CEO said from last earnings computing power restrictions prevented Google Cloud from taking on more customer needs and made the department's backlog nearly double the previous quarter.\n\nThis is probably positive for the AI DC capex buildout since hyperscalers capacity is way below what is needed, and especially so if they can't rely on one another.", "raw_url": "https://x.com/aleabitoreddit/status/2071135874100990438"}, {"post_id": "2071126659307385321", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T07:00:49+00:00", "direction": "neutral", "ticker": [], "company": ["Google", "Meta"], "bottleneck": "AI 算力", "attribution": "RELAYED", "rebuts": null, "summary": "转述 FT 报道: Google 因算力短缺限制 Meta 使用 Gemini, 强调算力仍是 AI 最稀缺资源.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Google reportedly limited Meta’s use of Gemini due to a shortage of compute resources. — FT\n\nGoogle is in a position where it can’t sell Gemini to Meta as freely as it might want to.\n\nCompute remains power, and the scarcest resource in AI.", "raw_url": "https://x.com/jukan05/status/2071126659307385321"}, {"post_id": "2071122361328476235", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T06:43:45+00:00", "direction": "long", "ticker": ["IBM"], "company": ["IBM"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": "反驳市场对 CSP 负现金流和 CAPEX 增长的质疑，认为应前瞻性看待现金流", "summary": "作者引用 IBM CEO 观点，认为企业 AI 第一年净亏损，第二年 ROI 10 倍回报，CSP 的 CAPEX 收入比将减速，形成良性循环，反驳只看当前现金流的短视。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Many people point to CSPs already running negative cash flow and ask how on earth CAPEX can keep growing from here.\n\nIt is a foolish question.\n\nLook at what Arvind Krishna (IBM CEO) said in a podcast conversation.\n\n“Year one of enterprise AI is a net loss. That is exactly why 80 percent of companies right now look like they have failed. It comes down to more engineers, higher token costs, and opportunity cost.\n\nYear two is precisely when the 10x return kicks in. Most companies are not failing at AI. They are simply at the worst point on the curve, right before ROI compresses and improves.”\n\nUltimately, at this 10x return inflection point, the CSPs’ own revenue base will be expanded by AI, so even as CAPEX grows in absolute terms, the CAPEX to revenue ratio will decelerate, eventually setting off a virtuous cycle, a flywheel effect.\n\nWhy do people look to the future when judging CAPEX, but look only at the present when judging cash flow? Cash flow should also be judged by pulling forward the future cash flow.", "raw_url": "https://x.com/jukan05/status/2071122361328476235"}, {"post_id": "2071074680253911267", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-28T03:34:17+00:00", "direction": "neutral", "ticker": [], "company": ["Anthropic", "Zhipu AI"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": "反驳将责任归咎于政府的叙事，认为 Anthropic 自身防护不足导致蒸馏", "summary": "作者评论 WSJ 报道中国智谱 AI 在网络安全基准测试中匹敌 Anthropic，认为 Anthropic 未设足够防护防止蒸馏，且不应通过 API 轻易交出成果。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "WSJ: “China Has Matched Anthropic in Cybersecurity, Resetting AI Race”\n\nChina’s Zhipu AI, has matched \nAnthropic’s Mythos in certain benchmarks, such as exploiting cybersecurity bugs. \n\nWell, that’s not good.\n\nInstead of blaming the administration which did the correct thing… \n\nAnthropic’s clearly at fault for not setting enough guardrails to prevent distillation.\nEven before Fable release there were a lot of rumors that China had backdoors to distill it.\n\nPart of it is the trillions of capex to accelerate the AI moat. \n\nAnd the second part is not handing that work over on a silver platter for millions in API calls.", "raw_url": "https://x.com/aleabitoreddit/status/2071074680253911267"}, {"post_id": "2071043118028472690", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T01:28:52+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electro Mechanics"], "bottleneck": "MLCC", "attribution": "NA", "rebuts": null, "summary": "三星电机正与某美国云服务商就AI服务器MLCC供应合同进行最终谈判，合同价值约5000亿韩元。AI服务器对高容量高可靠性MLCC需求激增，市场供不应求，三星电机有望加速盈利恢复。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Samsung Electro Mechanics Sees Its Value Rise as It Pursues 320 Million Dollar AI MLCC Supply Deal With Big Tech\n\nSamsung Electro Mechanics is moving to supply global big tech with several hundred billion won worth of multilayer ceramic capacitors (MLCC) for artificial intelligence (AI) servers. As the AI supercycle (a period of exceptional boom) spreads beyond semiconductors into electronic components, Samsung Electro Mechanics is expected to gain momentum in its earnings recovery as well.\n\nAccording to industry sources on the 28th, Samsung Electro Mechanics is reportedly in final stage discussions ahead of an AI server MLCC supply contract with a US cloud service provider (CSP). The contract is estimated to be worth around 500 billion won (320 million dollars). Major CSPs such as Google, Amazon Web Services (AWS), and Meta have recently been competing to build out AI data centers, and the industry believes the counterparty is most likely one of these companies.\n\nMLCC is a core component that stably supplies and controls electric current within the circuits of electronic products. Its range of application is widening beyond information technology (IT) devices such as smartphones and PCs to AI servers and automotive electrical and electronic equipment. In particular, because AI servers carry large numbers of high performance semiconductors such as graphics processing units (GPU), high bandwidth memory (HBM), and central processing units (CPU), power density has risen sharply, driving a surge in demand for high capacity, high reliability MLCC.\n\nOnce supply ramps up in earnest under this contract, the pace of Samsung Electro Mechanics' earnings improvement is expected to accelerate further. AI server MLCC is technically more difficult than the mobile variety, but it sells for at least three times more and is used in far greater volumes. A smartphone typically carries 1,000 to 1,300 MLCCs, whereas an AI server computing board uses 15,000 to 25,000 per board. The latest AI servers are equipped with around 20 computing boards, so a single server is said to require hundreds of thousands of MLCCs.\n\nMarket growth is also steep. According to market research firm MarketsandMarkets, the global AI server market is projected to grow to 837.8 billion dollars (about 1,150 trillion won) by 2030. Meanwhile, much like memory chips such as DRAM, MLCC supply is failing to keep pace with demand. Jang Duk hyun, president of Samsung Electro Mechanics, said at the regular shareholders meeting this past March that \"with rising data center investment, the supply and demand for high capacity, high reliability MLCC is tightening,\" adding that \"we are in discussions with customers to expand supply in line with market conditions.\"\n\nAs a seller's market takes shape, the pricing power of major players including Samsung Electro Mechanics and Japan's Murata, TDK, and Taiyo Yuden has also strengthened. Prices for some MLCC products have already been raised, and long term supply agreements (LTA) are reportedly being signed one after another. In its MLCC business, which accounts for more than 45 percent of total revenue, Samsung Electro Mechanics is focusing on improving profitability by expanding the share of high capacity, high performance products. It is regarded as having secured top tier global competitiveness in AI server MLCC.\n\nAgainst this market backdrop, analysts forecast that the operating profit of the Component Solutions division, which oversees Samsung Electro Mechanics' MLCC business, will surpass 1 trillion won this year, up more than 70 percent from last year (about 600 billion won). There is also talk of the possibility of reaching operating profit in the low to mid 2 trillion won range next year, roughly double that level. Samsung Electro Mechanics currently conducts MLCC research and development and raw material production at its Suwon and Busan sites, and operates production subsidiaries in Tianjin, China, and the Philippines as mass production bases. A plant expansion is also underway in the Philippines to increase MLCC capacity.", "raw_url": "https://x.com/jukan05/status/2071043118028472690"}, {"post_id": "2071029953001570708", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-28T00:36:33+00:00", "direction": "long", "ticker": ["ACMR", "NAURA", "CRUS"], "company": ["ACM Research", "NAURA Technology Group", "Cirrus Logic", "CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "反驳西方投资者低估 CXMT 在中国境内的投资狂热", "summary": "作者认为 2H26 有吸引力的投资机会是中国半导体国产化标的, 提到 CXMT IPO 后市值可能达 5 万亿人民币, 看好 ACMR 和 NAURA, 并考虑做空苹果供应链但标的有限, 质疑苹果业务吸引力.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Potential attractive investment opportunities for 2H26 —\n\nI still think they are likely to be Chinese semiconductor localization names.\n\nA few days ago, I had meetings with Chinese sell-side analysts, and they said CXMT’s market cap immediately after IPO could be at least RMB 5 trillion.\n\nIt seems that many Western investors are underestimating the investment frenzy around CXMT within China. I was also surprised when I first heard the RMB 5 trillion number, but I don’t think it is completely unreasonable.\n\nMost of the capital raised through CXMT’s IPO will likely flow into Chinese semiconductor localization stocks.\n\nNames like ACMR and NAURA look promising.\n\nI also think shorting the Apple supply chain could be an interesting idea… but there are not many Apple supply chain names with low AI exposure.\n\nMaybe CRUS is one of the few?\n\nBut isn’t that itself a bearish point on Apple? If the Apple business were truly strong and attractive, why are so many Apple vendors trying to move away from Apple exposure and gain AI exposure instead?", "raw_url": "https://x.com/jukan05/status/2071029953001570708"}, {"post_id": "2070934445918683164", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T18:17:02+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 CXMT 将进入大规模 CAPEX 支出周期，并认为这是一个风险，但未明确表达做空或卖出建议，属于客观风险陈述。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@fi56622380 @LinQingV BRUH\nCXMT will go on a huge CAPEX spending cycle, which is a risk", "raw_url": "https://x.com/zephyr_z9/status/2070934445918683164"}, {"post_id": "2070895932166807728", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T15:44:00+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 CXMT 未来 18 个月将产生超 $130B 毛利，其资金使用方式将影响内存周期长度及 28-29 年格局。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Good point\nCXMT will generate over $130B in gross profit in the next 18 months\n\nHow they spend that money will determine how long the memory cycle lasts and what happens in 28-29", "raw_url": "https://x.com/zephyr_z9/status/2070895932166807728"}, {"post_id": "2070877970256842889", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-27T14:32:37+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "NA", "rebuts": null, "summary": "推文仅提及 AI 对内存周期的影响，无具体股票代码、公司或方向性表态，属客观陈述。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "The impact of AI on the memory cycle! https://t.co/cBQE8OOPlY", "raw_url": "https://x.com/austinsemis/status/2070877970256842889"}, {"post_id": "2070796064698044849", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T09:07:10+00:00", "direction": "neutral", "ticker": ["RR"], "company": ["Rolls-Royce"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者对比 $RR 与人形机器人军事应用，认为市场更想投资后者，但未明确给出 long/short 建议，仅表达感受。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@buy_the_day Bro look at $RR on the left. \n\nAnd then humanoids deployed in military combat on the right. \n\nI feel like the right one is what markets want exposure to https://t.co/EY2wHjfQmH", "raw_url": "https://x.com/aleabitoreddit/status/2070796064698044849"}, {"post_id": "2070793664599863682", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T08:57:37+00:00", "direction": "neutral", "ticker": ["SIVE", "AEVA"], "company": ["Sivers Semiconductors", "Aeva Technologies", "LG Innotek"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 SIVE 有不错的机会通过 AEVA 和 LG Innotek 进入 Boston Dynamics 人形机器人项目，但近期对营收影响不大，因为领先的人形机器人公司目前仅生产约 1 万台。若 2028 年后产量达百万级，可能对营收产生实质影响。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "$SIVE is has a decent chance to be in Boston Dynamics humanoid programs through $AEVA and LG Innotek. \n\nI don’t see it being too material to revenue near term since the leading humanoid companies have only made ~10K so far.\n\nBut if you get to the millions in past 2028, it’s probably material to revenue", "raw_url": "https://x.com/aleabitoreddit/status/2070793664599863682"}, {"post_id": "2070792527259775235", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T08:53:06+00:00", "direction": "long", "ticker": [], "company": ["Unitree"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者明确看多 Unitree 在中国国内市场，但认为其人形机器人难以渗透美国市场，引用 DJI 黑客事件说明外国公司数据访问风险。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I’m actually very bullish on Unitree for CN domestic markets.\n\nHowever I don’t think there’s going to be much US market penetration for Chinese humanoids.\n\nEspecially with the DJI incident where a hacker could see into everyone’s house, and shows what foreign companies have access to.", "raw_url": "https://x.com/aleabitoreddit/status/2070792527259775235"}, {"post_id": "2070789923108798545", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T08:42:45+00:00", "direction": "neutral", "ticker": ["AMZN", "TSLA"], "company": ["Amazon", "Tesla"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者引用 a16z 数据指出机器人领域投资激增，认为 AI 数据中心曝光与机器人 ramp 有交叉，目前投资集中在上游组件和大型企业如 AMZN、TSLA，预计 2025 下半年至 2027 年将迎来纯机器人公司 IPO 热潮。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Robotics is next. \n\nBoth deal count and investment amounts are skyrocketing per pitchbook March data (source: a16z)\n\nGood thing is: the same AI DC exposure often has cross-exposure to humanoid ramp.\n\nLike DRAM/NAND with memory (on humanoid inference/storage) or DFB lasers with photonics (FMCW LiDAR vision/sensing).\n\nRight now most exposure is upstream component parts… or programs within large players like $AMZN or $TSLA. \n\nSo global IPO season H2 into 2027 for pure play humanoids/robotics companies is going to be fun.", "raw_url": "https://x.com/aleabitoreddit/status/2070789923108798545"}, {"post_id": "2070772477404619256", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T07:33:26+00:00", "direction": "neutral", "ticker": [], "company": ["Groq", "Whale"], "bottleneck": "SRAM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 Whale 的方法能改善草稿质量和验证管理，建议与 Groq 等 SRAM 加速器搭配，并指出中国对 SRAM 加速器需求增长，预计 Whale 会尝试采购。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Whale's method improves draft quality and manages verification in a much better manner\nPair this up with an SRAM based accelerator like Groq then we are off to the races \nThe demand for SRAM based accelerators is growing in China and I think the Whale will try to procure some now", "raw_url": "https://x.com/zephyr_z9/status/2070772477404619256"}, {"post_id": "2070765786340405584", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T07:06:51+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": "作者曾长期反对 speculative decoding，但 Dflash 和 Whale 的工作改变了看法", "summary": "作者回复多人，称赞工作令人印象深刻，并承认自己曾是 speculative decoding 的长期反对者，但 Dflash 和 Whale 的成果改变了他的观点。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@eliebakouch @teortaxesTex @antirez @_xjdr @norpadon Yes\nVery Impressive work\nI have been a speculative decoding hater for a long time\nDflash and this from whale have changed my mind", "raw_url": "https://x.com/zephyr_z9/status/2070765786340405584"}, {"post_id": "2070758710599954450", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T06:38:44+00:00", "direction": "neutral", "ticker": ["CBRS"], "company": ["Cerebras"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表示 $CBRS 目前只是谨慎仓位，提醒不要盲目跟单，因 AI 领域每月变化，最终由读者自行判断。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "pls don’t blindly follow along, esp. since I actively manage my own positions!\n\n$CBRS is just a cautionary position for me right now. \n\nCause things evolve every month in the AI space (eg. Custom jalapeño chips, maybe OpenAI has troubles, rate hikes), etc.\n\nBut if it’s compelling to you, you do you.", "raw_url": "https://x.com/aleabitoreddit/status/2070758710599954450"}, {"post_id": "2070754658868687086", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T06:22:38+00:00", "direction": "long", "ticker": ["CBRS", "JBL"], "company": ["Cerebras", "Jabil"], "bottleneck": "推理算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 OpenAI 在 Cerebras 上部署 5.6 Sol 模型验证了其技术，首次在 IPO 价以下建仓，但认为相比 JBL 等盈利公司估值偏高，不过有 OpenAI 曝光溢价。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "Kinda nutty OpenAI’s is launching its heavyweight 5.6 Sol frontier model on $CBRS.\n\nAt up to 750 tokens/sec, which is obscene performance.\n\nAmerican inference go brrr.\n\nI actually picked up starter positions on Cerebras for the first time in the ~170s (below $185 IPO price) after seeing this news yesterday.\n\nFeels like validation of its tech. IMO a bit overvalued compared to profitable companies like $JBL at the same valuation.\n\nBut there’s likely premiums for OpenAI exposure, as long as they stay the leader.", "raw_url": "https://x.com/aleabitoreddit/status/2070754658868687086"}, {"post_id": "2070723110639436221", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T04:17:16+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者预测 CXMT 上市市值可能达 $500B-$700B，并指出中国国家基金及补贴自 2014 年累计约 $250B，仅此一家 IPO 即可产生 2-3 倍回报。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "CXMT will probably list at $500B (some are predicting $700B) on the Shanghai Star Market\n\nBig Fund I, II, III have raised a total of $95B since 2014 and total Chinese state investment & subsidies are believed to be around $250B since 2014\nNow, just 1 company going public will literally generate 2x-3x return on the total investment\n\nCrazy", "raw_url": "https://x.com/zephyr_z9/status/2070723110639436221"}, {"post_id": "2070705915012297005", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T03:08:56+00:00", "direction": "long", "ticker": ["SPCX", "SIVE"], "company": ["Spruce Power", "Sivers Semiconductors"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为在 SPCX 收购 Mesh 后，基于其与早期初创公司合作的经验，SIVE 可能受益。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@beauty_oe ニュースが発表された時、誰がすぐに恩恵を受けるのかを考えるようにしているんです。\n\n$SPCXによるMeshの買収後、初期のスタートアップと協業してきた実績を考えると $SIVE が恩恵を受けそうだなと思いました。\n\nフォロワー2万人達成、おめでとうございます！", "raw_url": "https://x.com/aleabitoreddit/status/2070705915012297005"}, {"post_id": "2070701580442313052", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T02:51:43+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT", "Huawei", "SwaySure", "YMTC"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者分析中国DRAM供应紧张，苹果若不使用CXMT DRAM将难以维持中国市场份额，并指出华为可通过CXMT及自有SwaySure合资厂获取内存，Kirin 9040将大幅缩小SoC性能差距，同时透露YMTC NAND也在游说中。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "The problem isn't just the price\nGetting enough DRAM is hard\nSecondly, this is China only\nThey have to compete with Huawei (which can use CXMT and also has its own memory fab thru SwaySure JV)\nApple can't maintain its market share in China without using CXMT DRAM\nKirin 9040 will close the SoC performance gap by a lot\nI can also assure u that they are lobbying for YMTC NAND as well", "raw_url": "https://x.com/zephyr_z9/status/2070701580442313052"}, {"post_id": "2070696320948715858", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-27T02:30:49+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为某种行为等同于自愿放弃美国内存产业，未提及具体股票或公司，属于产业观点而非投资建议。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@Alex_Intel_ That would be like voluntarily abandoning the U.S. memory industry.", "raw_url": "https://x.com/jukan05/status/2070696320948715858"}, {"post_id": "2070695754025558471", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-27T02:28:34+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung", "Apple"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "转推 Ben Bajarin: 三星近期向苹果供应大量 DRAM, 属产业事实陈述, 无方向性判断.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@BenBajarin Recently, Samsung has been supplying a lot of DRAM to Apple.", "raw_url": "https://x.com/jukan05/status/2070695754025558471"}, {"post_id": "2070693580155556349", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-27T02:19:55+00:00", "direction": "neutral", "ticker": [], "company": ["Apple", "CXMT"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "据FT报道，苹果正游说特朗普政府，希望获准从CXMT采购内存。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Apple is lobbying the Trump administration to allow it to buy memory from CXMT, according to the FT. https://t.co/dfseSjIFIk", "raw_url": "https://x.com/jukan05/status/2070693580155556349"}, {"post_id": "2070691462354993543", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-27T02:11:30+00:00", "direction": "long", "ticker": ["SPCX", "SIVE", "POET", "LITE", "MTSI"], "company": ["Mesh", "Sivers Semiconductors", "POET Technologies", "Lumentum", "MACOM"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "Elon Musk 收购光网络初创 Mesh (做 1.6T OSFP), 可能从 SIVE 等采购 CW DFB 激光器, 利好 merchant 激光器供应商, 并显示光互连方向正确.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "$SPCX / Elon Musk acquires Mesh, an optical networking startup.\n\nWhich is working on 1.6T OSFP (pluggable).\n\nIt’s seems they own the optical engine/packaging side of things, but likely sources CW DFB lasers off merchant companies. \n\n$SIVE is one of the more startup friendly plausible merchant suppliers as seen with Ayar to $POET?\n\nMaybe $LITE and $MTSI that were have a little history too, but less so.\n\nRegardless it’s very positive a lot of startups recently like Celestial have been acquired by Marvell.\n\nFor both merchant laser supplier revenue (working with startups -> having hyperscalers like SpaceX drive revenue after being designed in already).\n\nAs well as valuations from M&A desirability.\n\nGoes to show how optical interconnects is the right direction if Elon Musk is directly buying these companies.", "raw_url": "https://x.com/aleabitoreddit/status/2070691462354993543"}, {"post_id": "2070691407355080929", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-27T02:11:17+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "NA", "rebuts": null, "summary": "DRAM ETF 首次纳入中国大陆股票，为客观事实陈述，无具体股票代码或方向性判断。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "This marks the DRAM ETF’s first inclusion of a mainland Chinese stock.", "raw_url": "https://x.com/jukan05/status/2070691407355080929"}, {"post_id": "2070689063624200568", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-27T02:01:58+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 DRAM ETF 已将 CXMT 母公司纳入持仓，属于客观事实陈述，无方向性判断。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "$DRAM ETF has added CXMT’s parent company. https://t.co/CSaviFiCdV", "raw_url": "https://x.com/jukan05/status/2070689063624200568"}, {"post_id": "2070687777994444815", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T01:56:52+00:00", "direction": "neutral", "ticker": [], "company": ["Groq"], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出当前计算机使用AI模型普遍笨拙且缓慢，认为小型模型和降低延迟（如使用Groq类硬件）将非常重要。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Very important paradigm\nRn all the computer use AI models are janky &amp; slow\nSmall models and reducing latency (use Groq like hardware) will be super important", "raw_url": "https://x.com/zephyr_z9/status/2070687777994444815"}, {"post_id": "2070674114600436039", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-27T01:02:34+00:00", "direction": "neutral", "ticker": [], "company": ["Google"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "ASIC 供应商难以获得 HBM 供应，市场由 Jensen 和 Hock 两大巨头主导，Google 曾尝试直接采购 HBM 但极其困难。作者本月已发布两份相关报告。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "ASIC suppliers are having a very hard time securing HBM supply\nThere are two 800-pound gorillas in the market - Jensen (more like 2400 pound) & Hock\nGoogle wanted to source HBM directly, but getting HBM supply is extremely hard (if u are not Jensen or Hock)\nWe have published two reports on that this month on https://t.co/lwcgRgObnB", "raw_url": "https://x.com/zephyr_z9/status/2070674114600436039"}, {"post_id": "2070643945814610201", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-26T23:02:42+00:00", "direction": "neutral", "ticker": ["MU"], "company": ["Micron"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 Micron 本季表现优异，但提出是否已见顶的疑问，并计划从供应端及 Hynix、Samsung 角度分析。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Micron hit it out of the park this quarter.\nPeak though, or no?\nLet's look at supply, and also Hynix and Samsung.\n\nhttps://t.co/38TkALIZrq", "raw_url": "https://x.com/austinsemis/status/2070643945814610201"}, {"post_id": "2070559154352353724", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T17:25:46+00:00", "direction": "long", "ticker": [], "company": ["OpenAI", "Anthropic"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者对 OpenAI 发布新模型 GPT-5.6 Sol 表示兴奋，称其在编码/工作流和生物/网络安全方面超越 Mythos 5 和 Anthropic，明确看多 OpenAI。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Brooo, OpenAI is back and they're releasing their new model GPT-5.6 Sol. \n\nWith their benchmarks, OpenAI claims: \n\n- Sol Ultra beats Mythos 5 and mogs it for coding/workflow. \n\n- And is better for bio/cybersecurity too.  \n\nPretty bullish on OpenAI again if they leapfrogged Anthropic.", "raw_url": "https://x.com/aleabitoreddit/status/2070559154352353724"}, {"post_id": "2070553697541910760", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-26T17:04:05+00:00", "direction": "neutral", "ticker": ["Samsung", "Huawei", "Apple", "Qualcomm", "Google", "Nvidia", "Broadcom"], "company": ["Samsung", "Huawei", "Apple", "Qualcomm", "Google", "Nvidia", "Broadcom"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者列出多家公司将在手机和AI XPU中采用逻辑芯片上的3D堆叠内存技术，时间线为2027-2029年，属于产业趋势陈述，无明确多空观点。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Everyone is adopting memory on logic 3D stacking\nSamsung, Huawei, Apple, Qualcomm for phones (2027-28)\nGoogle, Nvidia, Broadcom for AI XPUs (2028-29)", "raw_url": "https://x.com/zephyr_z9/status/2070553697541910760"}, {"post_id": "2070538032412000470", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T16:01:50+00:00", "direction": "long", "ticker": [], "company": ["BofA"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为不加息是极度看涨信号，因市场近期因美联储紧缩担忧和BofA三次加息预测而抛售。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@BeerMoneyBull Oh yes no hikes is extremely bullish since feels like markets recently sold off on fed tightening fears + BofA 3 hike projections.", "raw_url": "https://x.com/aleabitoreddit/status/2070538032412000470"}, {"post_id": "2070526386016866675", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-26T15:15:33+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "PCB", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 PCB 生产因日本厂商停止接受碳化钨切割工具订单而受阻，表达担忧但未给出具体股票方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "PCB production is fucked at this rate. \nLooks like all the Japanese players have stopped accepting tungsten carbide cutting tools orders", "raw_url": "https://x.com/zephyr_z9/status/2070526386016866675"}, {"post_id": "2070511386988552220", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-26T14:15:57+00:00", "direction": "neutral", "ticker": ["ADEA"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者澄清引用推文(QT)中他人误以为自己在为ADEA背书，但未表达任何看多/看空立场。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@acemoney21 If u look at QTs, they think I'm endorsing $ADEA", "raw_url": "https://x.com/zephyr_z9/status/2070511386988552220"}, {"post_id": "2070493783804813451", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T13:06:00+00:00", "direction": "neutral", "ticker": [], "company": ["Anthropic", "DeepSeek", "Gemini", "OpenAI", "Mythos", "Fable"], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提出美国AI公司面临中国模型蒸馏问题，建议加强身份验证、法规限制和优化推理模型以保持竞争力。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "just throwing out a random thought, the UBS report is anecdotally true + and it's interesting there's more Chinese reports on Anthropic distillation.  \n\nMany US startups/companies using AI:\n\nAre using Chinese models like DeepSeek since they’re much cheaper than Gemini/OpenAI/Anthropic reasoning models for cost per task.\n\nKinda a catch 22 when US is built on capitalism and everyone goes for the cheaper options.\n\nI think the US just has to get good and out innovate here:\n\n- both with heavy KYC-auth frontier models for US only like Mythos given those are being distilled by competitors. and amybe staggered tiers for allied partners so US is always ahead\n\nMaybe something like dedicated AI Google auth like FaceID + Persona would do the trick before access/key creation for the newer models, then short lived scopes.\n\nAt least addressing those simpler fake/stolen account + pool allegations, requiring biometrics before use.\n\nThen US Gov drafting new regulations making it illegal for sharing access similar to identity forgery with bank accounts.\n\n- then the most obvious one is just heavily optimized reasoning models that mogs DeepSeek and others.\n\nKinda good Trump admin paused Fable/Mythos access, imo not quite sure why a trillion dollar company keeps letting itself get distilled over and over again.\n\nThere should be friction added if you’re accessing something close to ASI.\n\nTLDR: US just needs to good at cheap inference and add bank-grade authentication to AI model access. Easier said than done tho.", "raw_url": "https://x.com/aleabitoreddit/status/2070493783804813451"}, {"post_id": "2070475755759567125", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-26T11:54:22+00:00", "direction": "neutral", "ticker": [], "company": ["Episil Technologies", "Nvidia"], "bottleneck": "电力", "attribution": "RELAYED", "rebuts": "反驳 800V 延迟传闻", "summary": "Episil 董事长徐建華对 Tech Taiwan 表示, Nvidia 仍按计划在 2027 年推出 800VDC 架构, 否认延迟传闻.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "J. H. Shyu (徐建華), chairman of Taiwan-based power semiconductor company Episil Technologies / 漢磊科技, pushed back against rumors of an 800V delay in comments to Tech Taiwan today.\n\n“Nvidia’s goal has always been to introduce the 800VDC architecture in 2027,” he said. “As far as I know, everything is still proceeding according to that schedule.”", "raw_url": "https://x.com/jukan05/status/2070475755759567125"}, {"post_id": "2070450820634788268", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T10:15:17+00:00", "direction": "neutral", "ticker": ["SIVE"], "company": ["Sivers Semiconductors"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": "反驳混淆员工激励计划与股东会决议的观点", "summary": "作者澄清 SIVE 从会议议程中移除了员工激励计划，纳斯达克上市仍在进行中，股东会通过了股份发行授权和新董事会成员决议，只是按清单推进。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "They never did. $SIVE dropped the employee incentive program from the meeting agenda, think you're confusing the two. \n\nNASDAQ listing just takes time and still in the process. \n\nThe shareholder meeting passed the authorization for share issuance, which is needed for dual listing liquidity. \n\nThe resolution for the new board members was also needed. They're just crossing off the checklist.", "raw_url": "https://x.com/aleabitoreddit/status/2070450820634788268"}, {"post_id": "2070448555672928277", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T10:06:17+00:00", "direction": "neutral", "ticker": ["NBIS"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者感谢粉丝支持，回顾早期翻译帖帮助自己走红，提到过去即使$NBIS下跌也能耐心等待论点兑现，但现在因关注者增多，每日价格波动评论让人更难忽视。", "is_retro": 1, "is_disc": 1, "is_selfret": 0, "raw_text": "You've been supporting me from the very start, thank you so much! \n\nI still remember your first translation post helped me get popular. \n\nBefore I was just able to wait for my thesis to play out like $NBIS even in the drops, since I didn't have so many followers. \n\nNow everyone's monitoring day-to-day price volatility and commenting about it so it's harder to ignore.", "raw_url": "https://x.com/aleabitoreddit/status/2070448555672928277"}, {"post_id": "2070447713196327115", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T10:02:56+00:00", "direction": "long", "ticker": ["SIVE", "JBL", "GFS", "AMD", "NVDA", "POET", "AEVA", "MRVL"], "company": ["Sivers Semiconductors", "Jabil", "GlobalFoundries", "Advanced Micro Devices", "Nvidia", "POET Technologies", "Aeva", "Marvell"], "bottleneck": "CPO", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 SIVE 仍被低估，列举多项近期利好：JBL 1.6T LRO 合作、GFS 参考激光设计、AMD 采用 GFS CPO、SIVE 发布 CW TFLN、Ayar 进入 NVLink 生态、AlChip 与 Amazon 合作、O-Net 合作量产、POET 获大客户订单、CHIPS 法案资助、LiDAR 客户 Q4 2026 量产、Ayar 可能将 SIVE 作为主要光源供应商等。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Not really, I personally still think it's undervalued. It's about MC relative to forward revenue potential. \n\nIn just that tiny timeframe for $SIVE:\n\n- $JBL announced 1.6T LRO with Sivers\n- $GFS reference laser announcement with $SIVE\n- $AMD went to $GFS for CPO\n- $SIVE announced CW with TFLN \n- Ayar (using $SIVE) raised a bunch for volume ramp and joined $NVDA NVLink ecosystem\n- AlChip private placement with Amazon, which is Ayar's primary ASIC partner (hinting at Trainium wins)\n- O-Net new ELS partnership with $SIVE for mass production\n- $POET new purchase order with a customer that stated their initial clients is a \"top-3 hyperscaper\"\n- New CHIPS Act nondilutive funding \n-  \"LIDAR customer will ramp production starting Q4 2026,\" which is likely $AEVA \n- New information discovery likely linking $SIVE customer to $MRVL Celestial (not through Poet), Lightelligence, and Lightelligence. \n- New information discovery about Ayar removing Lumentum / Macom from website and likely making Sivers primary source\n- More pluggable players on top of $JBL. \n- $NVDA bottlenecking CW laser supply and $AMD + other CSPs going around signing LTAs\n- NASDAQ listing planned\n\nAnd more.", "raw_url": "https://x.com/aleabitoreddit/status/2070447713196327115"}, {"post_id": "2070444675337503166", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T09:50:52+00:00", "direction": "long", "ticker": ["SIVE", "EWY", "NBIS", "IREN", "LITE"], "company": ["Sivers Semiconductors", "iShares MSCI South Korea ETF", "Nebius Group", "Iris Energy", "Lumentum"], "bottleneck": "InP", "attribution": "ORIGINAL", "rebuts": "反驳市场对 SIVE 的质疑（InP fab 尺寸、员工数、客户、量产时间等），认为这些争论是噪音，自己基于 hyperscaler mapping 研究有信心", "summary": "作者表示对 SIVE 的 hyperscaler mapping 研究有信心，仍持有百万股。回顾过去对 EWY 和 NBIS 的成功判断，认为 SIVE 将像 LITE 一样从 30 亿增长到 600 亿以上，等待 2027 年量产和纳斯达克上市。", "is_retro": 1, "is_disc": 1, "is_selfret": 0, "raw_text": "OFC I'm aware. But I'm personally sleeping comfortably since I have conviction in my hyperscaler mapping research with $SIVE. \n\nAnd yes, I still have my million+ share position.\n\nNot sure if people realize this: but I'm only here to share my thoughts/ideas.\n\nI don't control market volatility, what decisions you all make, or how markets react to new information synthesis. \n\nIt's much safer for analysts to just reactively tag along Morgan Stanley/JP Morgan/Goldman Sachs research whenever it's created and just summarize. \n\nRather than coming up with new ideas from OSINT mapping and waiting them get validated. \n\nBecause when you discover a new angle:\n\nEveryone keeps heatedly debating topics of 4-6 inch InP fabs, employee count, who their hyperscaler customers are, volume ramp timelines, etc to try and play devils advocate with a thesis. \n\nThen actively monitoring every single 5-20% price movement.\n\nI'm forced to stay on this topic more since it's less validated + there's always heated discussions. Just like $EWY in Feb, which I did memory projections on + Helium/LNG/Oil analysis. \n\nBut months later everyone sees memory looks structural with Micron's 16+ LTAs and LNG isn't taking down SK Hynix margins. \n\nOr $NBIS from last year in terms of sum-of-parts / dilution structures vs $IREN.\n\nAnd now it's close to ATHs and listed on $QQQ. \n\nI'm personally just waiting Sivers to volume ramp in 2027 + listing on NASDAQ to support their M&A efforts. \n\nSo they can walk down the same path as $LITE when they scaled from $3B to $60B+.", "raw_url": "https://x.com/aleabitoreddit/status/2070444675337503166"}, {"post_id": "2070432536384372867", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T09:02:38+00:00", "direction": "long", "ticker": ["SIVE", "AAOI"], "company": ["Sivers Semiconductors", "Applied Optoelectronics"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者对 SIVE 和 AAOI 在 2027 年激光器收入增长充满信心，明确看多。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@JClaydog Yeah sad to see. \n\nI'm personally very confident in $SIVE / $AAOI to revenue ramp with lasers in 2027 so I'm sleeping easy.", "raw_url": "https://x.com/aleabitoreddit/status/2070432536384372867"}, {"post_id": "2070413682996347069", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T07:47:43+00:00", "direction": "long", "ticker": ["MU"], "company": ["Micron", "SK Hynix", "Samsung"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 Elon Musk 在暗示内存需求激增和价格上涨，供应紧张，并推测 Musk 对内存瓶颈有更高可见度，隐含看多 MU/SK Hynix/Samsung。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Just Elon Musk casually sounding the alarm.\n\nOn the massive demand + price hikes for $MU / SK Hynix / Samsung memory relative to supply.\n\nHe probably has higher visibility into the memory bottleneck than others… https://t.co/iszX0YJHuS", "raw_url": "https://x.com/aleabitoreddit/status/2070413682996347069"}, {"post_id": "2070404701510893726", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-26T07:12:01+00:00", "direction": "neutral", "ticker": [], "company": ["Lenovo"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": null, "summary": "联想警告 DRAM 和 NAND 价格已进入结构性上升周期，即使供应商扩产，价格也难以回到 2025 年初水平，高内存价格将成为 2030 年后的“新常态”，导致电子设备持续涨价。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": ">> Lenovo: Rising memory prices are the “new normal”; elevated DRAM and NAND pricing to persist beyond 2030\n\n• The era of cheap digital devices is coming to an end. Lenovo warned that DRAM and NAND flash prices have already entered a structural upcycle, and that even if major suppliers continue to expand capacity, prices are unlikely to return to early-2025 levels.\n\nHigher costs are being passed through across the entire industry. Going forward, all types of electronic devices, including PCs and smartphones, are expected to face sustained price-increase pressure, with higher prices becoming the “new normal” beyond 2030.", "raw_url": "https://x.com/jukan05/status/2070404701510893726"}, {"post_id": "2070390794071298075", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-26T06:16:45+00:00", "direction": "neutral", "ticker": [], "company": ["Adeia"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者询问谁能提供混合键合 HBM4，并指出 HBM4 更依赖混合键合，使 Adeia 的 IP 在合同谈判时更关键。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Can someone supply me the hybrid bonded HBM4??\n\n\"HBM4 leans on hybrid bonding even harder, so Adeia's IP gets more critical exactly when those contracts hit the table.\"", "raw_url": "https://x.com/zephyr_z9/status/2070390794071298075"}, {"post_id": "2070354308965728519", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T03:51:47+00:00", "direction": "neutral", "ticker": ["SOI", "RKLB"], "company": ["Solaris Oilfield Infrastructure", "Rocket Lab"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出全球市场正在调整，列举韩国、日本、台湾指数跌幅，提及高贝塔股如SOI、RKLB跌幅更大但通常领先指数下跌并可能更早恢复，整体为市场观察，无明确多空建议。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "There's a global correction right now, no clue when it stops. \n\nKospi is down -8.18% (Sk hynix/Samsung)\nNikkei is down -4.8%\nTWSE Index is down -3.82%\n\nAs you've seen with $SOI or $RKLB dropping 30-40%. \n\nFrom personal experience, high beta stocks get hit a lot harder, but usually frontrun index drops. \n\nAnd they typically recover earlier? \n\nAside from Korea which is typically volatile, when major indexes start correcting 3-4% a day, usually not a fun time.", "raw_url": "https://x.com/aleabitoreddit/status/2070354308965728519"}, {"post_id": "2070342850878009346", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T03:06:15+00:00", "direction": "long", "ticker": ["AXTI", "AAOI", "TSEM", "LITE", "MU", "SNDK", "EWY", "SIVE", "IQE", "SOI"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": "反驳因宏观回调而认为这些推荐错误的主流观点", "summary": "作者回顾过去推荐的多个股票（如 AXTI、AAOI 等），指出尽管宏观回调导致大幅修正，但多数仍上涨数倍，并认为 TW CPO 相关标的只是过早，预期会恢复。", "is_retro": 1, "is_disc": 1, "is_selfret": 0, "raw_text": "FYI, I posted ideas about $AXTI at $15, $AAOI at $30, $TSEM at $115, $LITE $300, $MU $300, $SNDK $400, $EWY $110, $SIVE $4.\n\n$IQE $13, $SOI $44 and so on.\n\nSo when they finally have a massive correction due to macro drop the ideas are wrong? And most are still up a few hundred percent.\n\nTW CPO names are just really early and I’m down a lot on those but I expect them to recover in due time.", "raw_url": "https://x.com/aleabitoreddit/status/2070342850878009346"}, {"post_id": "2070340568597791107", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T02:57:11+00:00", "direction": "neutral", "ticker": ["JBL", "SIVE"], "company": ["Jabil", "Sivers Semiconductors"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者回复 @beauty_oe 表示会查看 JBL 和 SIVE 的规格，未表达明确的多空方向，仅陈述将进行调研。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@beauty_oe Nice! Ill check out the specs now for $JBL + $SIVE https://t.co/psjeaFVx8f", "raw_url": "https://x.com/aleabitoreddit/status/2070340568597791107"}, {"post_id": "2070322525985476918", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-26T01:45:29+00:00", "direction": "neutral", "ticker": ["NVDA"], "company": ["Nvidia"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": "反驳主流认为不用Nvidia芯片是因为HBM定价的观点，指出真正原因是无法直接获得足够HBM供应", "summary": "作者反驳主流叙事，认为不用Nvidia芯片并非因HBM定价，而是无法直接确保足够HBM供应。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@insane_analyst @Alex_Intel_ You should look at it differently. They’re not using Nvidia chips because of HBM pricing, but because they can’t secure enough HBM supply directly.", "raw_url": "https://x.com/jukan05/status/2070322525985476918"}, {"post_id": "2070308614829728045", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T00:50:12+00:00", "direction": "long", "ticker": ["AAOI", "AMD"], "company": ["Applied Optoelectronics", "Advanced Micro Devices"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 AAOI 下跌是光子主题抛售叠加宏观下跌，但个人基于 AMD CW LTA 报告和明年每月 4.71 亿美元预测保持信心，同时提醒光学股波动大，需自行决策。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@chenbaiyang70 Looks like photonics theme selloff combined with macro drop with $AAOI.\n\nI’m personally confident from $AMD CW LTA reports and next year’s $471M/month projections. \n\nBut of course people should make their own decisions, optical names tend to be more volatile.", "raw_url": "https://x.com/aleabitoreddit/status/2070308614829728045"}, {"post_id": "2070306489772986618", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-26T00:41:46+00:00", "direction": "neutral", "ticker": ["NVDA"], "company": ["NVIDIA"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者反驳对方观点，指出NVIDIA以远低于其他ASIC厂商的价格采购HBM，属于事实陈述，无明确多空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@insane_analyst @Alex_Intel_ What are you talking about? NVIDIA sources HBM at much lower prices than other ASIC makers.", "raw_url": "https://x.com/jukan05/status/2070306489772986618"}, {"post_id": "2070304723262210194", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-26T00:34:45+00:00", "direction": "long", "ticker": ["AOSL", "POWI"], "company": ["Alpha and Omega Semiconductor", "Power Integrations", "Yangjie Technology", "Chongqing China Resources Micro", "Silan Microelectronics", "NCE Power"], "bottleneck": "电力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出功率半导体已开始涨价，利好美国功率半导体股 AOSL 和 POWI。中国多家厂商已提价10-15%，需求来自AI数据中心、能源系统和电动车。上游材料公司也可能受益。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Looks like Power Semis are already starting price hikes.\n\nWhich is bullish thematically for US power semi trade from $AOSL to $POWI, before the 800V DC shift fully hits.\n\nChina's Yangjie Technology, announced a 2nd price increase this year, raising prices across its full product range by 10%-15%, July 1.\n\nChongqing China Resources Micro, Silan Microelectronics, and NCE Power also price hiked.\n\n“Demand is playing a larger role than costs in the latest round of price increases” from AI DCs, to energy systems, and new EVs.\n\nAnother potential beneficiary is the upstream material companies that make these:\n\n- nonferrous metals like copper and tin.\n-Plastic molding compounds\n- chemicals, and packaging consumables\n\n“Nearly all major Chinese power semiconductor makers have raised prices in 2026.” (Digitimes)\n\nSo positive read through on power semi adjacent (reduce China-driven price pressure + better pricing + demand validation)", "raw_url": "https://x.com/aleabitoreddit/status/2070304723262210194"}, {"post_id": "2070283671429587419", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T23:11:05+00:00", "direction": "neutral", "ticker": ["6182", "3532", "6488"], "company": ["Wafer Works", "Taisil", "GlobalWafers"], "bottleneck": "晶圆代工", "attribution": "RELAYED", "rebuts": null, "summary": "台湾三大硅晶圆厂同步释出涨价信号，6寸已涨价，8寸需求升温，12寸启动议价。机构看好硅晶圆进入复苏周期。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Taiwan's three major silicon wafer makers signal price hikes\n\nAfter nearly two years of inventory adjustment, the silicon wafer industry is seeing an increasingly clear recovery. As demand for mature process nodes warms up, high end AI applications keep expanding, and energy, freight, and raw material costs remain elevated, Taiwan's three major silicon wafer makers, Wafer Works (6182), Taisil (3532), and GlobalWafers (6488), have recently signaled price increases one after another.\n\nAmong product lines, 6 inch wafers have already led the way with completed price increases, demand for 8 inch is heating up quickly, and 12 inch products have also begun a fresh round of price negotiations with customers. Institutional investors expect the silicon wafer industry to enter a new wave of the recovery cycle.\n\nWafer Works said it completed its 6 inch wafer price adjustment early this year, and the market is now showing supply falling short of demand.\n\nThe company noted that the tight 6 inch supply is not a case of AI directly crowding out mature process nodes. Rather, in recent years some international silicon wafer suppliers, including SUMCO and Siltronic, have successively cut back or exited their 6 inch lines, and combined with each maker adjusting capacity allocation according to product mix and customer structure, overall supply has continued to converge.\n\nBecause Wafer Works still has a large base of mature process customers in power devices, power management ICs (PMIC), and MEMS, demand for its 6 inch and 8 inch products remains stable. As a result, keeping these lines in operation actually delivers better operating efficiency.\n\nThe company further noted that the 8 inch market still has room for price increases in the second half. What is driving the demand recovery is not just PMIC but the broader power semiconductor space, with applications such as automotive electronics, industrial control, and power management all improving in tandem.\n\nTaisil said its 8 inch and 12 inch wafer lines are both running at full capacity. Demand in the 8 inch market has clearly warmed up recently, with many customers already discussing additional orders for the second half of this year and demand for next year ahead of time, leading the company to judge that 8 inch products have room for price increases.\n\nAs for 12 inch products, the company has begun negotiating a new price adjustment mechanism for the second half with customers. However, the increase customers are willing to accept still falls short of what the company expects, and the two sides are continuing to negotiate.\n\nGlobalWafers said that in 2026 the global silicon wafer market is showing an uneven but upward recovery, with the recent warming momentum more clearly defined than before.\n\nHigh end AI and advanced process demand remains strong, while non AI markets such as automotive and industrial control are also gradually recovering. The company is actively negotiating prices with customers to reflect higher energy, freight, and raw material costs.\n\nInstitutional analysts say the three makers' simultaneous price hike signals reflect a clearly improved supply demand structure in the silicon wafer market. Overall, the concurrent recovery in demand for both mature and advanced process nodes should help lift the silicon wafer industry's revenue and earnings, making the operating outlook for the second half cautiously optimistic.", "raw_url": "https://x.com/jukan05/status/2070283671429587419"}, {"post_id": "2070267916013187449", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T22:08:29+00:00", "direction": "neutral", "ticker": [], "company": ["Anthropic"], "bottleneck": "推理算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者估算 Anthropic 处理 25M 交互的推理成本约 $72M（假设 90% 缓存），无缓存则约 $160M，基于 25 万亿 token 和 12:1 输入输出比。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Actually pretty small ($72M)\nAnthropic identified 25M interactions\nLet's say 1M tokens were processed per interaction (very generous assumption)\nThat's around 25 trillion Tokens\nNow, Anthropic said that they were mostly for coding & agentic tasks\nSo assuming, 12:1 input: output ratio and 90% caching on Opus\n\nSo it's nearly around $72M and around $160M if no caching is assumed", "raw_url": "https://x.com/zephyr_z9/status/2070267916013187449"}, {"post_id": "2070266870557704335", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T22:04:20+00:00", "direction": "neutral", "ticker": [], "company": ["Innolux"], "bottleneck": "封装", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者推测 Feynman 若采用 CoPoS 和玻璃基板可能延迟至 2029 年，并提及 Innolux 暗示此方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Feynman is likely delayed to 2029 if they are adopting CoPoS and glass substrates (Innolux is hinting towards that)", "raw_url": "https://x.com/zephyr_z9/status/2070266870557704335"}, {"post_id": "2070197316343283884", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T17:27:57+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者解释 JEDEC 放宽高度要求的原因：16 Hi 堆叠良率低，且不愿浪费已稀缺的晶粒。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@bubbleboi @weremainbull1sh JEDEC relaxed the height requirements \nBoth yield and lack of supply were the problem\n16 Hi yield would have been low and they don't want to waste already scarce dies", "raw_url": "https://x.com/zephyr_z9/status/2070197316343283884"}, {"post_id": "2070195182730121576", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T17:19:28+00:00", "direction": "neutral", "ticker": [], "company": ["Apple"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "反驳他人曲解其观点：作者澄清自己从未说苹果不会降价，而是认为内存价格将维持高位至2028年，且端侧AI需要更多内存，苹果会增配而非降价。", "summary": "作者澄清被误解的观点：他未声称苹果不会降价，而是预测内存价格将维持高位至2028年，且端侧AI推动内存需求，苹果已从8GB增至12GB，未来会继续增配而非降价。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "\"Pretty different though than saying Apple won’t roll back prices because Apple will just keep pricing where it is and take in the additional profit.\"\nI never stated this\n\nI just think that memory prices will stay elevated till at least 2028, and on-device AI requires more memory, so even if memory prices fall, Apple will just add more memory to their devices (already went to 12GB from 8GB) rather than cutting prices on their products in late 2028 or 2029.", "raw_url": "https://x.com/zephyr_z9/status/2070195182730121576"}, {"post_id": "2070190812223455727", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T17:02:06+00:00", "direction": "long", "ticker": ["NVDA"], "company": ["Nvidia"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": "People are still underestimating how much DRAM will be eaten by Agentic CPUs", "summary": "作者认为内存价格未来两年不会降温，指出16 Hi HBM4E被砍和Nvidia Rubin Ultra HBM容量缩减是因为DRAM不足，并反驳市场低估Agentic CPU对DRAM的需求。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Well\nMemory prices aren't cooling for the next 2 years \nA big reason why 16 Hi HBM4E got chopped, and Nvidia reduced Rubin Ultra HBM capacity from 1TB to 768 GB was the lack of enough DRAM\nBtw, we are still unsure if 16 Hi will get adopted for Feynman or not\nPeople are still underestimating how much DRAM will be eaten by Agentic CPUs", "raw_url": "https://x.com/zephyr_z9/status/2070190812223455727"}, {"post_id": "2070189253573890167", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T16:55:54+00:00", "direction": "neutral", "ticker": ["WEN", "MU", "SNDK"], "company": ["Wendy's", "Micron", "SanDisk"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者自嘲端口差，提到 MU/SNDK 今日涨势救不了端口，提 $WEN 是玩笑，不是投资建议。借体育赛事隐喻大盘跌 20%。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Nah, gonna fill out the job application for $WEN and set up camp behind the dumpsters. \n\nEven $MU and $SNDK ridiculous performance today couldn't save my port.\n\nCheering on Japan though, hoping Sweden gets mogged with a 2-0 to represent the 20% drop.", "raw_url": "https://x.com/aleabitoreddit/status/2070189253573890167"}, {"post_id": "2070187514179326144", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T16:49:00+00:00", "direction": "neutral", "ticker": [], "company": ["Databricks"], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 Databricks 聘请 Yuchen 来构建其推理提供商业务。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@teortaxesTex @TheZvi So Databricks hired Yuchen to build their inference provider biz", "raw_url": "https://x.com/zephyr_z9/status/2070187514179326144"}, {"post_id": "2070185814722834696", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T16:42:15+00:00", "direction": "long", "ticker": ["AAOI"], "company": ["Applied Optoelectronics"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者回顾自己在 AAOI 市值 $2.1B、$5.3B、$11B 时发帖看多，认为若其年收入达 $5.4B 将获更高估值。", "is_retro": 1, "is_disc": 0, "is_selfret": 0, "raw_text": "@hobielandrith I posted about $AAOI at $2.1B MC when someone called photonics \"late\". \n\nThen at $5.3B after earnings.\n\nThen $11B now. \n\nUnless their projections are wrong, doing $5.4B annual revenue ($471m/m) as a photonics company probably commands higher valuations. https://t.co/ORFGNdySSc", "raw_url": "https://x.com/aleabitoreddit/status/2070185814722834696"}, {"post_id": "2070184659036893219", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T16:37:39+00:00", "direction": "neutral", "ticker": ["SIVE"], "company": ["Sivers Semiconductors"], "bottleneck": null, "attribution": "RELAYED", "rebuts": null, "summary": "转推 SIVE 财报电话会引述: 一旦主要转为产品收入驱动, 毛利率可达 50%-60%+.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@dpkim19 Quote from $SIVE earnings transcript: \"50% to 60%+ gross margins once we are firmly and predominantly product revenue driven.\" https://t.co/2NpjbQIyZC", "raw_url": "https://x.com/aleabitoreddit/status/2070184659036893219"}, {"post_id": "2070181783338184877", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T16:26:13+00:00", "direction": "neutral", "ticker": ["SIVE"], "company": ["Sivers Semiconductors"], "bottleneck": "InP", "attribution": "ORIGINAL", "rebuts": "反驳人们用 InP fab 比较 SIVE 的做法 (SIVE 是 fabless designer, 不量产激光器, 用 Win Semi 等代工)", "summary": "作者反驳主流用 InP fab 比较 SIVE 的观点, 澄清 SIVE 是 fabless designer, 自身不量产激光器, 用 Win Semi 等代工厂, 不需要大量 capex, 仅有一个研发用 Fab.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@aa11231ggagaa44 Do you mean InP fab? I'm not sure why people are trying to compare InP fabs, $SIVE is not mass producing lasers in-house. \n\nThey're using Win Semi and foundries, Sivers is a fabless designer so they don't need capex. \n\nThey do have a fab for development.", "raw_url": "https://x.com/aleabitoreddit/status/2070181783338184877"}, {"post_id": "2070179307193008592", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T16:16:23+00:00", "direction": "long", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为内存价格将至少维持高位至2028年，未来两年降价无意义，价格上涨概率高于下跌，看多存储行业。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@mweinbach Memory prices will remain elevated till at least 2028\nI doubt it makes sense to roll back prices after 2 years from now\nHigher chance of prices going up rather than going down", "raw_url": "https://x.com/zephyr_z9/status/2070179307193008592"}, {"post_id": "2070179074048409662", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T16:15:27+00:00", "direction": "long", "ticker": ["SIVE", "GFS", "NVDA", "POET", "JBL", "AAOI", "AMD", "NBIS"], "company": ["Sivers Semiconductors", "GlobalFoundries", "NVIDIA", "POET Technologies", "Jabil", "Applied Optoelectronics", "Advanced Micro Devices", "Nebius"], "bottleneck": "激光", "attribution": "ORIGINAL", "rebuts": "反驳瑞典媒体对 SIVE 的看空报道和非法做空 bot 农场，认为股价下跌是噪音，长期看多", "summary": "作者明确表示对 SIVE 比以往更看多，认为 SIVE 是激光瓶颈，供应给 GFS、Ayar、POET、JBL 等，受益于 CPO 和光通信。反驳瑞典媒体看空和做空 bot，认为 15% 增发是为纳斯达克上市和并购授权，可转债规模小。类比 NBIS 去年暴跌后恢复，等待光子学量产出货。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "oh i think u misunderstand... I'm actually more bullish than ever as prices go down. \n\n$SIVE at ~$1.9B MC you have:\n\n- $GFS reference laser \n- laser for Ayar and others in $NVDA NVLink ecosystem for CPO scale up\n- $POET and others for CPO scale out\n- $JBL and others for 1.6T+ pluggable optical transcivers \n- O-Net for ELS mass production\n\nSo you have all these hyperscaler suppliers trying to create as much as possible with Sivers as the laser bottleneck... \n\nAnd it's just a matter of how much Win Semi + others partners can make, with $SIVE receiving ~60% gross margins + optionality to TAM expand downward. \n\nThe 15% recent share expansion that Swedish media have been bearposting is for NASDAQ listing float + M&A (and it's authorization). \n\nYou just have potential short sellers running illegal bot farms, Swedish media bearposting a company Swedish exchange, on top of a general macro drop. \n\nThe ~$140M convertible note is real, but it's pennies to US institutions. We'll likely see more institutional ownership when data comes out.   \n\nBut this is also why it's good for $SIVE to prioritize NASDAQ listing so they don't need to deal with this noise and local media. \n\nWith $AAOI at $10B, you have:\n\n- A end-to-end US laser/design/assembly player projecting $471m month revenue H1 entering H2 2027. \n\n- With other hyperscalers like $AMD apparently discussing LTAs. \n\nAnd they probably are sitting on a ton of cash after running ~$1.4B in ATMs (400M + 400m+ 600m).  \n\nKinda all that needs to be said with those insane revenue projections as long as management doesn't BS. \n\nThis just reminds me of when $NBIS crashed to $70 last year even while projecting $7-9B ARR, and as timelines got closer it recovered to $250+. Feels like dejavu. \n\nI'm just waiting for both volume ramps to hit. Photonics are generally more volatile than the rest.", "raw_url": "https://x.com/aleabitoreddit/status/2070179074048409662"}, {"post_id": "2070171729666994396", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T15:46:16+00:00", "direction": "long", "ticker": ["NBIS"], "company": [], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 NBIS 有动漫主角光环，且一位 OpenAI 对冲基金人士在坚定持有，表达看多情绪。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@CryptoBankz_65 $NBIS has anime protagonist armor and an OpenAI hedge fund guy diamond handing the stock.", "raw_url": "https://x.com/aleabitoreddit/status/2070171729666994396"}, {"post_id": "2070166811354775762", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T15:26:44+00:00", "direction": "neutral", "ticker": ["SIVE", "GFS", "JBL", "POET"], "company": ["Sivers Semiconductors", "GlobalFoundries", "Jabil", "POET Technologies"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者列举 SIVE 的多项激光器合作：为 GFS 提供参考激光器、为 JBL 提供 1.6T 可插拔激光器、为 Ayar 提供 CPO 扩展激光器、为 POET 提供扩展激光器、为 O-Net 提供 ELS 激光器，并提及更多未公开合作。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@RJCcapital Bruh $SIVE is $GFS reference laser, $JBL 1.6T pluggable laser, Ayar CPO scale up laser, $POET scale out laser, O-Net ELS laser. \n\nAnd many other undisclosed partnerships. \n\nWatch and learn.", "raw_url": "https://x.com/aleabitoreddit/status/2070166811354775762"}, {"post_id": "2070160668494557240", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T15:02:19+00:00", "direction": "long", "ticker": ["SIVE"], "company": ["Sivers Semiconductors"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表示 SIVE 是目前最喜欢的光学股票，但指出宏观负面消息和光子学主题抛售，尤其在瑞典交易所上市，对股价不利。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@NieMehrKrieg Of course, $SIVE is my favorite optical name right now.\n\nHowever, having negative macro news compounded with photonics theme selloff. \n\nEspecially on a Swedish exchange, certainly doesn’t help.", "raw_url": "https://x.com/aleabitoreddit/status/2070160668494557240"}, {"post_id": "2070159026747535488", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T14:55:48+00:00", "direction": "neutral", "ticker": ["SNDK"], "company": ["SanDisk"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表达近期亏损，并提及持有 SNDK 类多头仓位，属于持仓披露，无新建仓建议。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "@firstadopter Yep, I lost a sht ton recently and makes me sad if others did too.\n\nAlways hard to build a port full of $SNDK type longs that go up despite macro climates.", "raw_url": "https://x.com/aleabitoreddit/status/2070159026747535488"}, {"post_id": "2070157835137434015", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T14:51:04+00:00", "direction": "long", "ticker": ["MU", "AXTI", "SIVE", "ASTS", "RKLB", "PLTR", "CRM"], "company": ["Micron", "AXT Inc", "Sivers Semiconductors", "AST SpaceMobile", "Rocket Lab", "Palantir", "Salesforce"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出内存、指数、大盘半导体未崩，但光子学、太空、AI、软件等板块大跌，认为市场因鹰派美联储和加息预期承压，但可能因流动性较差的资产被过度抛售。长期仍看好AI建设和上游资本支出受益者。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Feels like the only thing that hasn’t crashed…\n\nIs memory like $MU, indexes, or large cap semis like Intel so far.\n\n- Photonics from $AXTI to $SIVE down 40%.\n\n- Space from $ASTS and $RKLB down 40% 1M. \n\n- Popular AI names like $PLTR is down ~35% YTD. \n\n- Software like $CRM down -40%.\n\n- Bitcoin sub <60k, Ethereum sub <$16k.\n\nNot a fun time with a hawkish fed narrative and potential rate hikes. \n\nHowever this does sorta feel overshot due to margin liquidations on less liquid assets compared to mega caps.\n\nBut we’ll see what happens, usually fundamentals override liquidity shock in the longer run.\n\nI’m still personally bullish on the AI buildout + upstream AI capex beneficiaries, but 1-2 potential rate hikes certainly don’t help.", "raw_url": "https://x.com/aleabitoreddit/status/2070157835137434015"}, {"post_id": "2070144804470796776", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T13:59:17+00:00", "direction": "neutral", "ticker": ["AAPL"], "company": ["Apple"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者称2025年底和2026年Q1的库存积压已结束，预计将出现大量涨价，并指出苹果已发出信号。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Late 2025 and Q1 2026 stockpiles are over\nNow, we are going to get a lot of price hikes \nApple signaled everyone https://t.co/f4c7ETFJOV", "raw_url": "https://x.com/zephyr_z9/status/2070144804470796776"}, {"post_id": "2070094933562994888", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T10:41:07+00:00", "direction": "neutral", "ticker": ["IBM"], "company": ["IBM"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者对 IBM SRAM 缩放技术表示兴奋，称其回归，但未明确给出投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@IanCutress @IBM SRAM scaling is back!", "raw_url": "https://x.com/jukan05/status/2070094933562994888"}, {"post_id": "2070092098229961028", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T10:29:51+00:00", "direction": "neutral", "ticker": ["NVDA"], "company": ["NVIDIA"], "bottleneck": "电力", "attribution": "RELAYED", "rebuts": null, "summary": "转述 TrendForce 报告：NVIDIA 800V 电源机架将作为 Vera Rubin 可选配置，Rubin Ultra 世代起广泛采用。功耗从当前 225kW 升至 660kW，电网传输和变压器交付是瓶颈。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": ">>NVIDIA’s 800V Power Rack to Debut as an Optional Configuration for Vera Rubin, with Broader Adoption Expected in the Rubin Ultra Generation, Says TrendForce\n\n- According to TrendForce's latest research, NVIDIA has been developing its own 800V HVDC power rack. The platform is expected to be ready for customer shipments in 3Q26 and will likely be offered to customers deploying the Vera Rubin platform as an optional configuration rather than a standard feature.\n\n- TrendForce believes that, given current rack level power demand, adoption of 800V power racks will begin to ramp meaningfully after the Rubin Ultra generation launches in the second half of 2027. Widespread deployment is likely to follow in 2028.\n\n- NVIDIA's current VR200 rack consumes roughly 225kW, up from around 150kW for the prior generation GB300. Even so, this higher power demand remains within the range that conventional in rack power supply units (PSUs) can handle.\n\n- The transition to the Rubin Ultra generation, however, marks a major shift in power architecture. Rack power consumption is expected to surge to around 660kW, while next generation air cooled systems may require 1.2MW to 1.3MW of power.\n\n- TrendForce estimates that a single 800V power rack could support one to two Rubin Ultra racks, though the actual deployment ratio will depend on each customer's redundancy requirements. Supply chain sources also say NVIDIA is developing an additional power delivery architecture, which would give customers greater flexibility in how they deploy their systems.\n\n- Hyperscalers and data center developers continue to invest aggressively in new AI infrastructure, and several gigawatt scale campuses across North America are expected to come online before the end of 2026. Actual deployment timelines, however, hinge on a number of supply side constraints, including the ongoing shortage of key server components such as memory and CPUs, as well as whether local power grids can accommodate rapidly rising power demand.\n\n- TrendForce believes that while most U.S. power markets have ample generation capacity to support approved data center projects, the biggest bottleneck lies in transmission. This problem is especially pronounced in regions overseen by PJM Interconnection, where grid interconnection requirements are more demanding. Some grid interconnection queues now exceed five years for newly proposed data centers.\n\n- In response, PJM and several other regional transmission organizations are working with the U.S. federal government to accelerate the grid interconnection process for large scale data center projects.\n\n- The long lead times for critical electrical infrastructure are adding further uncertainty as well. As of mid 2025, the average lead time for large power transformers had stretched to about 2.5 years, while transformers in the 345kV to 765kV voltage class take four to five years, roughly double the lead times seen in 2020. Switchgear is experiencing similar supply constraints.\n\n- Against this backdrop, TrendForce believes the industry should watch closely whether suppliers can accelerate the production and delivery of these critical electrical components and the supporting power infrastructure, noting that any delays could push back data center construction schedules.", "raw_url": "https://x.com/jukan05/status/2070092098229961028"}, {"post_id": "2070090392159359334", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T10:23:04+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者反问对方是否认真，认为即使商品DDR5价格短期受压，只要产能转向HBM就能解决问题。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@MoMoMacro Bro, are you seriously saying this?\n\nIt doesn’t matter if commodity DDR5 prices get crushed for a few weeks. As long as they shift capacity to HBM, the problem is solved.", "raw_url": "https://x.com/jukan05/status/2070090392159359334"}, {"post_id": "2070088742644392189", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T10:16:31+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "RELAYED", "rebuts": null, "summary": "作者转发并赞同原文观点：即使DDR供给增加导致价格承压，可通过将DDR产能转换为HBM产能来防止整体内存价格暴跌。作者认为当前DDR价格是新常态，HBM的巨大需求将吸收商品DRAM产能并提供价格支撑。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "What I’m trying to say is exactly in line with this.\n\nLet’s assume DDR supply increases and DDR prices come under downward pressure.\n\nThat can be offset by converting DDR capacity into HBM capacity, preventing a sharp collapse in overall memory prices.\n\nSo, put simply, even if DDR5 prices “normalize” back to previous levels, though I personally believe current DDR prices are the new normal, that does not necessarily mean the entire memory market will collapse. That is because the massive demand from HBM will absorb commodity DRAM capacity and provide downside support to prices.\n\nThis is a really good piece. You should read it.", "raw_url": "https://x.com/jukan05/status/2070088742644392189"}, {"post_id": "2070080537168105899", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-25T09:43:54+00:00", "direction": "neutral", "ticker": [], "company": ["CXMT", "DeepSeek"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "Disagrees on CXMT points (they are quite active in 3D DRAM, results in 2028, capacity >500k WPM)", "summary": "作者推荐一篇文章，同意大部分观点，但反驳其中关于CXMT的看法，认为CXMT在3D DRAM上很活跃，2028年可能出成果，产能将超50万片/月。同时提到DeepSeek v4等努力减少KV缓存占用，但认为生成/处理的token量会大增，形成Jevons悖论。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Must read for everyone\nI agree with most points written in the article\nAlthough, I disagree on CXMT points (they are quite active in 3D DRAM, and we may see results in 2028, capacity will also be greater than 500k WPM)\nAnd lots of work is happening to reduce KV cache footprint (DeepSeek v4),\nExpect the size of KV cache/token to go down but the volume of tokens generated/processed will be go up so much that it will make up for it\nJevon's paradox", "raw_url": "https://x.com/zephyr_z9/status/2070080537168105899"}, {"post_id": "2070069304108957819", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T08:59:16+00:00", "direction": "neutral", "ticker": ["MU"], "company": ["Micron"], "bottleneck": null, "attribution": "RELAYED", "rebuts": null, "summary": "DA Davidson 将美光目标价上调至 $2,000，作者转推该消息。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "DA Davidson raises its Micron price target to $2,000.\n\n$MU https://t.co/iYHTwUHlun", "raw_url": "https://x.com/jukan05/status/2070069304108957819"}, {"post_id": "2070060603809681477", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T08:24:42+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electronics"], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "三星发布研究，定量证明混合键合(HCB)在HBM4E热管理上优于传统TCB，可降低结温、减少热干扰、提升功率预算，并减薄堆叠高度15%以上，为高堆叠HBM4E量产提供技术支撑。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Samsung Quantitatively Proves \"Hybrid Bonding Advantage\"... Superior HBM4E Thermal Management\n\nSamsung Electronics has objectively demonstrated the technical superiority of the high stacking strategy it is pursuing for next generation high bandwidth memory (HBM4E) packaging. For the first time, the company released quantitative research findings showing that Hybrid Copper Bonding (HCB) technology holds a clear advantage in thermal management over the conventional Thermo Compression Bonding (TCB).\n\nAccording to industry sources on the 25th, Samsung's research team recently used multi scale modeling and actual test chip experiments under conditions close to a real server grade environment to systematically validate HCB's thermal management advantage over TCB. Going beyond chip and package level simulation studies, the team proved HCB's advantage in a practical high stacking environment.\n\nThis shows that Samsung has achieved clear differentiation in technical direction compared with the TCB and MR-MUF (Mass Reflow Molded Underfill) methods, and that it is moving ahead not only in electrical performance but also in thermal management and reliability. In particular, because it can effectively mitigate the thermal problems that arise when stacking more layers (16 or more), it is expected to serve as important technical support for strengthening HBM4E mass production competitiveness going forward. The study, titled \"System Level Thermal Characterization of Hybrid Cu Bonding HBM Applied to 2.5D Advanced Packaging,\" was published this month by the IEEE (Institute of Electrical and Electronics Engineers).\n\nSamsung's research team developed a physics based multi scale numerical modeling technique to precisely analyze thermal characteristics from the chip level microstructure all the way to the package and server system levels. At the chip scale, the method considers metal connectivity and dielectric thin film effects in detail and propagates these into package and server level simulations through the extraction of effective thermal properties. In addition, after mounting HCB based and TCB based HBM test vehicles together with an ASIC test vehicle on a silicon interposer, the team carried out experimental measurements under the air cooling conditions of a real server environment to verify the accuracy of the model.\n\nThe results showed that the hot spot junction temperature was indeed lower than with TCB, reducing the risk of overheating. Thermal interference was also eased, reducing heat transfer between the memory stack and the compute chip (ASIC) below it and lessening mutual interference. Under the same cooling conditions, a higher power budget could be secured, expanding the room for performance improvement. Furthermore, applying HCB reduced the stack height by more than 15%, making the overall package thinner and proving advantageous for heat accumulation as well.\n\nWith TCB, small bumps are used and underfill material sits in between, which breaks the heat transfer path and results in high thermal resistance. By contrast, HCB uses direct copper bonding, providing many paths for heat to escape and thus showing high heat dissipation efficiency. Through a parametric study on the bonding pad density of HCB, the team also presented design directions that could further raise heat dissipation efficiency in the future.\n\nSamsung's research team explained that \"the predictive design framework developed through this study will be used for bonding technology evaluation and thermal optimization in next generation HPC (high performance computing) packaging architectures.\"", "raw_url": "https://x.com/jukan05/status/2070060603809681477"}, {"post_id": "2070020727441621026", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T05:46:15+00:00", "direction": "neutral", "ticker": ["WEN", "RDDT"], "company": ["Wendy's", "Reddit"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提到 WEN 因 meme 交易上涨约 50%，登上全球媒体，同时披露自己的 AI 存储/光通信组合表现不如 RDDT meme 股，并询问是否有人建仓。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "The $WEN meme traders made it to Global Media from Japan to US!\n\nThe burger fast food chain is now up ~50%, which is pretty impressive.\n\nFeels bad to be sidelined and see my AI memory/optical portfolio perform worse than a $RDDT memestock tho.\n\nDid anyone take positions? https://t.co/hM0RhWh21c", "raw_url": "https://x.com/aleabitoreddit/status/2070020727441621026"}, {"post_id": "2069997378724413769", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T04:13:28+00:00", "direction": "neutral", "ticker": [], "company": ["Murata", "Samsung Electro Mechanics", "Fenghua Advanced Technology", "Chaozhou Three Circle Group", "Goldman Sachs"], "bottleneck": "MLCC", "attribution": "NA", "rebuts": null, "summary": "AI服务器需求推动高端MLCC现货价格飙升，部分产品年初至今涨3-5倍，集中在高容量高温型号。村田、三星电机等将产能转向AI和汽车应用，消费电子MLCC需求疲软。高端产线建设需18-24个月，短缺或持续至2027年后，风华高科和三环集团可能受益。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "▶ AI server demand drives sharp price gains in high end MLCCs\n\n- Rising demand for AI server buildouts is tightening global supply of high end MLCCs, triggering sharp price spikes in China's electronic component distribution market.\n\n- Spot prices for some popular MLCC products have climbed 3 to 5x since the start of the year, and in Shenzhen and Shanghai there is even speculative trading in which some product prices shift on a daily basis.\n\n- The price gains are concentrated in high capacity, high temperature products such as 22μF and 47μF. Unlike the broad based shortage of 2018, the core issue this time is an imbalance between surging AI demand and limited supply.\n\n- Major global players such as Murata and Samsung Electro Mechanics have recently scaled back production for consumer electronics such as smartphones and PCs, shifting capacity toward high margin products for AI servers and automotive applications.\n\n- High end MLCCs carry high technical barriers and demanding yield requirements, making it structurally difficult to add new capacity quickly. Some AI server MLCCs have risen from around 80 yuan per 1,000 units at the start of the year to more than 350 yuan.\n\n- Original manufacturers are managing shipments more tightly than before, with orders of several million to tens of millions of units being filled at only 10 to 20% of the requested volume.\n\n- Some overseas suppliers have revived bundling, requiring buyers of high capacity MLCCs to also purchase mid and low capacity products.\n\n- AI servers use roughly 8 to 12x more MLCCs than standard servers. Goldman Sachs projects that MLCCs are the third largest cost item in AI servers after GPUs and memory, and that related demand will grow 4.3x from 2025 to 2030.\n\n- That said, the price gains are concentrated in high capacity, high reliability products for AI and automotive applications rather than across the entire product range. Demand for low capacity consumer electronics MLCCs remains weak.\n\n- Because building high end production lines takes 18 to 24 months, the shortage is likely to persist through the second half of this year and beyond 2027. China's Fenghua Advanced Technology and Chaozhou Three Circle Group could benefit as orders shift their way.", "raw_url": "https://x.com/jukan05/status/2069997378724413769"}, {"post_id": "2069990311296975133", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T03:45:23+00:00", "direction": "long", "ticker": ["MU", "TSM", "TSLA"], "company": ["Micron", "TSMC", "Tesla"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者引述 MU CEO 预测人形机器人将驱动数十年内存需求周期，需求是当前 L2+ 自动驾驶的十倍，且将在 2030 年前启动。同时提及 TSM 董事长和 TSLA 马斯克也看好，认为物理 AI 是下一趋势，并思考内存是否足够。整体看多内存需求。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Very interesting statement today: $MU CEO predicts a multi-decade memory demand cycle driven by humanoid robots.\n\n\"Humanoid robots, he says, will require roughly ten times more memory than today’s Level 2+ autonomous vehicles.\"\n\n\"And that demand wave is set to begin before the decade is out.\"\n\nSomething as well as was \"Over time, we expect the value of on-device AI combined with pent-up unit replacement demand to drive memory demand growth\"\n\nWhich is also another trend (Apple Intelligence is currently dog, but I'm sure we'll see innovations with localized/edge AI). \n\nFeels like all the industry leaders from $TSM Chairman, $TSLA Elon Musk, to $MU CEO see humanoids as the next major trend so physical AI is probably next. \n\nI wonder if the world is going to have enough memory. Or if we'll see enough breakthroughs to shrink memory usage.", "raw_url": "https://x.com/aleabitoreddit/status/2069990311296975133"}, {"post_id": "2069967746377662587", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T02:15:43+00:00", "direction": "neutral", "ticker": ["AXTI", "SOI", "AAOI"], "company": ["AXT Inc.", "Soitec", "Applied Optoelectronics"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": "反驳 Soitec 的负面机构报告", "summary": "作者回顾近期持仓大幅回撤，CPO 相关标的受创最重，反思光通信板块过度集中。提及 AXTI 受稀释担忧、AAOI 被主题拖累。不提供买入建议，但认为光通信超级周期仍早期，2027-2028 年或有拐点。", "is_retro": 1, "is_disc": 1, "is_selfret": 0, "raw_text": "Think so. But in the meantime, I call my strategy: Diversified Losses.\n\nWith $AXTI, $SOI, $AAOI, and many others.\n\nHad a massive drawdown recently, \nCPO exposure was hit the hardest (Foci, Msscorp, etc) and adjacent names, feels bad.\n\nProbably lesson personally, I had too much concentration in photonics vs. memory/other sectors without weighting/hedging properly.\n\nWith Soitec, there's been a few negative institutional reports that I'd disagree with. \n\nThink AXT was hit harder in specific just because of float expansion/dilution concerns. AAOI, probably just brought down with the theme.\n\nI can't give advice on buying, so completely up to you to make for cost averaging or entering positions.\n\nBut I do think we're still early in the Supercycle with photonics, there's bound to be corrections/crashes along the way up.\n\nIf my personal thesis is correct though, many of these names will have a major inflection point in midway through 2027 scaling up to 2028.\n\nMarkets don't typically wait to price things in advance, but some ideas might be a tad early or in the buildout given it's H2 2026 now.\n\nWhich is why it's important to build your own conviction.", "raw_url": "https://x.com/aleabitoreddit/status/2069967746377662587"}, {"post_id": "2069941173075218896", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-25T00:30:07+00:00", "direction": "long", "ticker": ["005930.KS", "000660.KS"], "company": ["Samsung Electronics", "SK Hynix"], "bottleneck": "存储", "attribution": "RELAYED", "rebuts": "反驳过去估值框架，认为应关注盈利能力的结构性变化而非历史估值", "summary": "SK证券认为内存重估仍处早期，AI时代内存与台积电类似具备平台属性，盈利能力和可见性提升，股东回报增强，三星和SK海力士12个月远期市盈率仅6倍，是AI瓶颈中最便宜的股票，维持半导体超配评级。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Korea SK Securities: Memory is the cheapest stock among the bottlenecks of the AI era\n\n\"SK Securities continues to view the memory rerating as still only at its earliest stage. TSMC commands a high multiple because it is a platform style manufacturer that enables its customers' futures. The same holds for memory in the AI era. Structurally elevated earnings power and visibility, and the strengthened shareholder returns built on top of them, mean that the memory rerating and the unwinding of the Korean memory discount will move together. With Samsung Electronics and SK Hynix currently trading at around a 12MF P/E of 6.0x, their share prices indicate that they remain the cheapest stocks among the bottlenecks of the AI era. As value within the industry shifts and is reallocated, the metric to trust and follow is the change in earnings power, not a valuation framework anchored in the past. We maintain our Overweight rating on semiconductors.\"", "raw_url": "https://x.com/jukan05/status/2069941173075218896"}, {"post_id": "2069940182418370732", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T00:26:11+00:00", "direction": "long", "ticker": ["DRAM", "MU", "SNDK"], "company": ["SK Hynix", "Samsung", "Micron", "SanDisk"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 DRAM ETF 是较看好的 ETF 之一, 因其持仓包括 SK Hynix、Samsung、MU 和 SNDK, 覆盖了市场对内存曝险的需求.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@AliTava2020 $DRAM is one of the more positive ETFs I have a view on since it's exposure to SK Hynix, Samsung, $MU, and $SNDK.\n\nWhich is everything people kinda want for memory exposure.", "raw_url": "https://x.com/aleabitoreddit/status/2069940182418370732"}, {"post_id": "2069939902608015383", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T00:25:05+00:00", "direction": "neutral", "ticker": ["BABA"], "company": ["Alibaba", "Anthropic"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 BABA 的 Qwen 通过蒸馏 Anthropic 模型提升市场份额，风险回报有利因无惩罚，且许多美国 AI 初创公司因成本效益使用 Qwen。但指出未被抓到是看跌的，并质疑美国为何不加强惩罚。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I mean if $BABA Qwen marketshare increases from distilling Anthropic models effectively. Rewards outweigh the risks because there's been no penalties (which is why they're doing this). \n\nLot of US AI startups have been using Qwen lately cause of how cost effective it is vs. Gemini and others... \n\nBut so far optically, no getting caught is bearish. \n\nNot sure why more things aren't done on the US side enforcing penalties for this though.", "raw_url": "https://x.com/aleabitoreddit/status/2069939902608015383"}, {"post_id": "2069938631817699588", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-25T00:20:02+00:00", "direction": "neutral", "ticker": ["BABA"], "company": ["Anthropic", "Alibaba"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "Anthropic 指控阿里巴巴 Qwen AI 实验室通过创建数千虚假账户和超 2880 万次交互蒸馏其前沿模型，作者认为此事已知但尚无实质处罚，静观其变。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Today, Anthropic has directly accused the $BABA Qwen AI lab of distilling its frontier AI models.\n\nBy creating thousands of fake accounts and over 28.8 million exchanges. \n\nFeels like this is kind of known by now... but there's been no real penalties enforced yet. \n\nWe'll see what happens.", "raw_url": "https://x.com/aleabitoreddit/status/2069938631817699588"}, {"post_id": "2069931152744608150", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T23:50:18+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "EDA", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者向 Patrick Toulme 提问，询问某事件对 EDA 公司的影响，未表达方向性观点。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@PatrickToulme What impact would this have on EDA companies?", "raw_url": "https://x.com/jukan05/status/2069931152744608150"}, {"post_id": "2069922683681431826", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T23:16:39+00:00", "direction": "long", "ticker": ["MU"], "company": ["Micron"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": "反驳市场将美光最新LTA签署解读为内存价格上涨周期结束的观点", "summary": "作者认为美光签署LTA意味着未锁定的市场供应减少，客户越晚签约越面临供应压力，FOMO加剧，内存制造商能获得更有利条款，因此LTA并非涨价终点，而是接近起点。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I find it hard to understand why some people are interpreting Micron’s latest LTA signing as the end of the memory price upcycle.\n\nSigning an LTA ultimately means that the amount of supply in the market that has not yet been locked up is shrinking. In other words, the later a customer signs an LTA, the greater the pressure they face to secure stable supply, and the stronger their FOMO becomes.\n\nOver time, the fear of failing to secure enough memory will only intensify. That creates an environment where memory makers can secure LTAs on increasingly favorable terms.\n\nI do not think this LTA marks the end of price increases. If anything, I think it is closer to the beginning.", "raw_url": "https://x.com/jukan05/status/2069922683681431826"}, {"post_id": "2069909213879632193", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T22:23:08+00:00", "direction": "long", "ticker": ["MU"], "company": ["Micron"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者表达对 Micron 的信念，明确看多。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I didn’t have enough faith in you…\n\nI believe in Micron!!! https://t.co/MzJ5k6SY50", "raw_url": "https://x.com/jukan05/status/2069909213879632193"}, {"post_id": "2069902006085616025", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T21:54:29+00:00", "direction": "neutral", "ticker": ["TSM"], "company": ["TSMC"], "bottleneck": "晶圆代工", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者推测 TSM 可能效仿内存厂商涨价，但未明确看多或看空，属中性推测。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@mindmoon_108 @Akaletiko Eh, maybe other way around where $TSM sees what memory players are doing and starts price hiking too.", "raw_url": "https://x.com/aleabitoreddit/status/2069902006085616025"}, {"post_id": "2069900250064818480", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T21:47:31+00:00", "direction": "long", "ticker": ["MU", "LITE", "AAOI"], "company": ["Micron", "Lumentum", "Applied Optoelectronics"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 MU 财报对 SK Hynix/Samsung 及 KOSPI 指数是正面解读，也利好 AI 需求，带动 LITE、AAOI 等盘后微涨。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@Zenctwill $MU earnings are probably a good read through on SK Hynix/Samsung, which is majority of KOSPI weighting (passively too). So seems more likely than not for SK index.\n\nIt’s also a positive read through on AI demand, which is why $LITE, $AAOI, and others jumped a tiny bit AH.", "raw_url": "https://x.com/aleabitoreddit/status/2069900250064818480"}, {"post_id": "2069895779985309920", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T21:29:45+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为内存是当前最严重瓶颈，但三大巨头已是万亿公司，市场已部分定价。作者认为光子学是下一个超级周期，但更接近起点，主要收入爬坡始于2027年中。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Not exactly, memory looks like the most severe current bottleneck. But the big three are all trillion dollar companies, so seems like markets have had more time to price this in but are still going.\n\nIMO Photonics is the next supercycle but we’re closer to the beginning, a lot of the major revenue ramps begin mid 2027.", "raw_url": "https://x.com/aleabitoreddit/status/2069895779985309920"}, {"post_id": "2069892511406100716", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T21:16:46+00:00", "direction": "long", "ticker": ["MU"], "company": ["Micron"], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者引用 MU 财报超预期及强劲指引，并指出已签署 16 份长期协议，认为内存需求已结构性增长，AI 交易持续升温，整体看多。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Always amazing looking at $MU earnings: \n\nRevenue: $41.46B vs. $35.8B est.\nEPS: $25.11 vs. $20.78 est.\n\nForecasts:\n\nRevenue: $49B to $51B, vs $43.24B est \nEPS: $30.00 to $32.00, vs. $25.31.\n\n“Micron said on Wednesday that it has signed 16 long-term agreements”\n\n\"When completed, we expect approximately half or more of our company revenue to be under these\"\n\nLooks like memory demand has become structural…\n\nBut great earnings to show up the AI trade is continuing to ramp up.", "raw_url": "https://x.com/aleabitoreddit/status/2069892511406100716"}, {"post_id": "2069890671218229629", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T21:09:27+00:00", "direction": "neutral", "ticker": ["QCOM"], "company": ["Qualcomm"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者回复 @JDorbal1989，称 QCOM 未披露技术细节且经常撒谎，属于负面评价但未明确建仓方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@JDorbal1989 They didn't disclose technical detail\nQCOM lies a lot", "raw_url": "https://x.com/zephyr_z9/status/2069890671218229629"}, {"post_id": "2069879412401860972", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T20:24:43+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者用'Memory FUD bois'调侃那些散布内存行业恐慌的人，未明确表达方向性建仓建议，归neutral。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Read carefully\nMemory FUD bois", "raw_url": "https://x.com/zephyr_z9/status/2069879412401860972"}, {"post_id": "2069874427408588892", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T20:04:54+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者以反问句调侃看空内存的人 (memory FUD bois), 未明确建仓方向, 按反问句规则归 neutral.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Where are the memory FUD bois???", "raw_url": "https://x.com/zephyr_z9/status/2069874427408588892"}, {"post_id": "2069834913302663234", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T17:27:53+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "推理算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者质疑 V4 Flash 的编码性能数据，认为需年处理 110T tokens 或每 GPU 45k tokens/s 才能实现，假设输入输出比 12:1 且 95% 缓存命中。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@teortaxesTex Bullshit math for V4 Flash (at least for coding)\nU need to process around 110T tokens per year or 45k tokens/s/GPU to achieve this, assuming 12:1 input: output and 95% caching", "raw_url": "https://x.com/zephyr_z9/status/2069834913302663234"}, {"post_id": "2069831251109060842", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T17:13:20+00:00", "direction": "neutral", "ticker": [], "company": ["AWS", "Moonshot"], "bottleneck": "推理", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提出一种扩展收入的模式：与超大规模云和推理提供商签署部署协议，由AWS等处理推理部署与合规，Moonshot提供模型权重。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Another way to scale revenue is to sign deployment agreements with hyperscalers and inference providers\nAWS et al. handle the inference deployment and compliance, and Moonshot provides the weights https://t.co/kJpDuWDewW", "raw_url": "https://x.com/zephyr_z9/status/2069831251109060842"}, {"post_id": "2069829722083664176", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-24T17:07:15+00:00", "direction": "neutral", "ticker": ["QCOM"], "company": ["Qualcomm"], "bottleneck": null, "attribution": "RC", "rebuts": null, "summary": "推文提及高通投资者日，并@两位分析师，无明确方向性表态，仅转发事件信息。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Qualcomm Investor Day 🤘🏻\n@PatrickMoorhead \n@BenBajarin https://t.co/1qDfSmBrDf", "raw_url": "https://x.com/austinsemis/status/2069829722083664176"}, {"post_id": "2069816588128391207", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T16:15:04+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为某提案不会通过，因为会关闭全球25%-30%的DRAM和NAND产能。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I don't think it will pass cuz it will shut down a large chunk (25%-30%) of global DRAM and NAND output", "raw_url": "https://x.com/zephyr_z9/status/2069816588128391207"}, {"post_id": "2069799169171259410", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T15:05:51+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者推算合成内容渗透到 30 亿日活、每日 3000 秒、token 效率提升 4 倍时，日 token 消耗将达 90Q，月消耗 2700Q。纯技术推算，无投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "This got me thinking\nIf synthetic content generation penetrates to 3 billion DAU and 3000 seconds per day, and token efficiency increases by 4x (10k tokens/s for 1080P) then daily token consumption grows to 90Q/day or 2700Q/month", "raw_url": "https://x.com/zephyr_z9/status/2069799169171259410"}, {"post_id": "2069780882018459851", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T13:53:11+00:00", "direction": "neutral", "ticker": ["INTC", "UBER"], "company": ["Intel", "Uber"], "bottleneck": null, "attribution": "RELAYED", "rebuts": null, "summary": "转述 Nancy Pelosi 披露的持仓: 100-500万美元 INTC 2027年3月看涨期权, 200张 UBER 2027年3月50美元行权价看涨期权, 于5月29日由丈夫执行. 仅供关注者参考.", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "Nancy Pelosi just disclosed: \n\n- $1 million - $5 million of $INTC March 2027 calls\n- 200 $UBER March 19, 2027 call option contracts with a $50 strike price\n\nThis was done last month May 29th. (her husband is the active trader executing this). Just for the people who like following along Pelosi family trades.", "raw_url": "https://x.com/aleabitoreddit/status/2069780882018459851"}, {"post_id": "2069778045142180302", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T13:41:55+00:00", "direction": "long", "ticker": ["POET"], "company": ["POET Technologies", "Lumilens"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": "反驳做空报告声称 Lumilens 无客户", "summary": "作者指出做空者曾声称 Lumilens 无客户, 现 Lumilens 公开拥有顶级超大规模客户, 此信息可能重要, 隐含看多 POET.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@Web3Eden01 Short sellers (eg. Night Market) were claiming Lumilens had no customers on their $POET short report.\n\nSo Lumilens going out and saying they have a top-3 hyperscaler customer is probably pretty material.", "raw_url": "https://x.com/aleabitoreddit/status/2069778045142180302"}, {"post_id": "2069775482481188875", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T13:31:44+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "HBM", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者在回复中询问是否为 HBM4，并表达自己认为是 HBM3E，属于技术讨论，无投资方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@BenBajarin Is it HBM4? I think it’s HBM3E.", "raw_url": "https://x.com/jukan05/status/2069775482481188875"}, {"post_id": "2069775271562289299", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T13:30:53+00:00", "direction": "long", "ticker": ["POET", "SIVE"], "company": ["POET Technologies", "Sivers Semiconductors", "Lumilens"], "bottleneck": "CPO", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者通过 LinkedIn 线索推断 POET/SIVE 可能为 Top-3 超大规模云商（亚马逊/微软/谷歌）提供 CPO/NPO 方案，认为 Sivers CW DFB 激光器路径更可能，并披露持有 SIVE 多头仓位。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "Fun new information discovery from Poet OSINT community:\n\nSeems likely that $POET / $SIVE are going to power a Top-3 hyperscaler (either Amazon, Microsoft, Google). \n\nGiven a Linkedin update from Ankur Singla (CEO of Lumilens). \n\nWho stated their customer is one of the top 3 hyperscalers with their post focusing on CPO/NPO. \n\nWith that clue, seems more likely the Sivers CW DFB light source path over other EML suppliers given it's CPO Scale Out/NPO. \n\nIf you don't remember, Sivers is the laser supplier to Poet. And Poet has purchase agreements with Lumilens.\n\nAlways fun to find major potential breadcrumbs in the wild before they're officially confirmed. (Disclosure, long Sive)", "raw_url": "https://x.com/aleabitoreddit/status/2069775271562289299"}, {"post_id": "2069774451366064346", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T13:27:38+00:00", "direction": "neutral", "ticker": ["CBRS"], "company": ["Cerebras"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者质疑对方是否误解其观点，并指出 Broadcom 正在试图抢走 Cerebras 的最大营收客户。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@tuolaji2024 Are you sure you’re interpreting my point correctly?\n\nBroadcom is trying to take away CBRS’s largest revenue customer.", "raw_url": "https://x.com/jukan05/status/2069774451366064346"}, {"post_id": "2069772847808225613", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T13:21:16+00:00", "direction": "neutral", "ticker": ["CBRS"], "company": ["Cerebras"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者以反问句表达对 Cerebras 的看跌情绪 (Is it just me...), 未明确建仓, 按【误抽铁律 #1 反问句】归 neutral.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Is it just me, or does this feel bearish for Cerebras? https://t.co/00fQFFE0fx", "raw_url": "https://x.com/jukan05/status/2069772847808225613"}, {"post_id": "2069771231310831809", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T13:14:50+00:00", "direction": "neutral", "ticker": [], "company": ["OpenAI"], "bottleneck": "EDA", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者对 EDA 公司如何解读此事表示好奇，并询问 OpenAI 是否会对外销售这些解决方案。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "I wonder how EDA companies will interpret this.\n\nDo you think OpenAI will try to sell these solutions externally? https://t.co/VBxAHwnLvx", "raw_url": "https://x.com/jukan05/status/2069771231310831809"}, {"post_id": "2069756409957233045", "kol": "austin", "source_id": "tw_austinsemis", "published_at": "2026-06-24T12:15:57+00:00", "direction": "neutral", "ticker": ["QCOM"], "company": ["Qualcomm"], "bottleneck": null, "attribution": "NA", "rebuts": null, "summary": "作者祝贺 @clattner_llvm 团队和 @Qualcomm, 未表达投资方向.", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Wow! Congrats @clattner_llvm and team and @Qualcomm.", "raw_url": "https://x.com/austinsemis/status/2069756409957233045"}, {"post_id": "2069716948943007833", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T09:39:08+00:00", "direction": "neutral", "ticker": ["AAPL", "QCOM"], "company": ["Apple", "Qualcomm", "MediaTek"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者反问：非苹果手机品牌是否因无法获得高通和联发科旗舰芯片而无法制造手机？未明确表达多空立场，属质疑性反问。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@SKundojjala Apple benefits… Do you think non-Apple smartphone brands won’t be able to make smartphones because they won’t have access to Qualcomm and MediaTek flagship chips?", "raw_url": "https://x.com/jukan05/status/2069716948943007833"}, {"post_id": "2069713882827157993", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T09:26:57+00:00", "direction": "neutral", "ticker": [], "company": [], "bottleneck": "存储", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出多模态仍是内存需求的最大顺风，属于产业趋势陈述，未涉及具体股票或方向性建仓建议。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Multimodality is still the biggest memory demand tailwind", "raw_url": "https://x.com/zephyr_z9/status/2069713882827157993"}, {"post_id": "2069713577943150915", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T09:25:45+00:00", "direction": "neutral", "ticker": [], "company": ["Bytedance"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出多模态是 token 消耗大户，并披露字节跳动当前 token 用量已达每月 5.4Q 或每年 65Q，表达惊叹。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Multimodality is a token guzzler\n\nBytedance is already at 5.4Q tokens/month or 65Q tokens/yr\nDAMN", "raw_url": "https://x.com/zephyr_z9/status/2069713577943150915"}, {"post_id": "2069690452841054214", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T07:53:51+00:00", "direction": "neutral", "ticker": [], "company": ["SK Hynix"], "bottleneck": "存储", "attribution": "NA", "rebuts": null, "summary": "SK Hynix 董事会决议发行 1779 万股 ADR 于纳斯达克上市，募资约 45.5 万亿韩元，用于龙仁半导体集群一期、清州先进封装厂及 EUV 设备投资。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "SK Hynix Officially Decides on US Nasdaq ADR Issuance: 17.79 Million New Shares, Up to KRW 45.5 Trillion in Proceeds\n\n▶️ ADR Issuance Overview Board resolution date: June 24, 2026 (all six outside directors in attendance) Issuance type: New share DR (third party allotment method) Listing exchange: Nasdaq (Nasdaq Global Select Market) Scheduled listing date: July 10, 2026 Scheduled new share listing date: July 29, 2026 Subscription and payment date: July 14, 2026\n\n▶️ Issuance Scale Maximum new share issuance limit: 17,790,000 shares Reference issue price: KRW 2,555,000 per common share (based on the June 23 closing price) Total DR issuance value (reference): approximately KRW 45.4534 trillion Conversion ratio of underlying shares per DR: 0.1 share (1 DR = 0.1 common share) Final issue price to be confirmed after bookbuilding\n\n▶️ Use of Proceeds (entirely facility funds) Investment in the construction of the Yongin Semiconductor Cluster Phase 1 fab (Y1) Construction, equipment, and incidental costs for the Cheongju P&T7 advanced packaging fab EUV scanner construction and facility investment\n\n▶️ Underwriters BofA Securities Citigroup Global Markets Goldman Sachs (Asia) J.P. Morgan Securities\n\n▶️ Other Overseas depositary institution: Citibank, N.A. / Underlying share custodian: Korea Securities Depository Confirmed disclosure approximately seven months after the December 2025 inquiry disclosure", "raw_url": "https://x.com/jukan05/status/2069690452841054214"}, {"post_id": "2069689336258576813", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T07:49:25+00:00", "direction": "neutral", "ticker": [], "company": ["Apple", "Samsung Display", "Foxconn", "Shin Zu Shing", "Amphenol"], "bottleneck": "铰链", "attribution": "RELAYED", "rebuts": null, "summary": "转推 The Elec 报道：苹果折叠 iPhone 将于 7 月底量产，铰链问题已解决，9 月如期发布。三星显示供应 OLED 面板，铰链由新日兴和安费诺提供。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Exclusive: Apple to Begin Foldable iPhone Mass Production in July, Hinge Problem Resolved\n\nApple will begin mass production of its first foldable iPhone from late July. While speculation about a launch delay recently emerged due to hinge problems, it has been confirmed that Apple is pushing ahead with a September unveiling as originally planned.\n\nAccording to reporting by The Elec on the 24th, based on interviews with Apple supply chain sources in Korea and Taiwan, Apple has finalized the major specifications for the foldable iPhone, including the display, case, and mechanical components, and has entered the mass production preparation stage. Foxconn will handle production of the initial volume. A first round of trial production was carried out this past April, and mass production is expected to begin around late July. The September unveiling schedule is also expected to proceed without major issues.\n\nTrial production is the procedure of validating the design, components, assembly process, and quality standards under actual production conditions before a new product enters mass production. It signifies that product development has passed the final validation stage and moved into the mass production preparation stage. For products like the foldable iPhone, which require multiple components such as the panel, hinge, cover glass, and frame to be precisely joined together, trial production results are a key variable for the launch schedule.\n\nThe Apple foldable iPhone uses a foldable organic light emitting diode (OLED) panel supplied by Samsung Display, along with the hinge module, cover glass, and mechanical components. Samsung Display recently received approval from Apple for the initial volume of foldable OLED modules from its Vietnam plant. It has completed mass production preparation through the module stage, in which the driver circuit, flexible printed circuit board (FPCB), and protective components are attached to the OLED panel.\n\nThe hinge for the foldable iPhone is supplied by Taiwan's Shin Zu Shing and the United States' Amphenol. They supply hinge modules made using a 3D printing method. The hinge determines the opening and closing feel when the screen is folded and unfolded, as well as the crease at the fold and the durability. Since it is a component that does not exist in ordinary bar type smartphones, it determines the level of completion of the foldable product.\n\nIt has been reported that there were in fact hinge related problems during the development process. A Taiwan industry source said, \"After durability testing at the level of several million cycles, slight noise occurred in the hinge,\" adding that \"in some assembly processes, the tolerances were larger than expected, so the defect rate rose somewhat.\" The source went on to add that \"most of these problems have now been resolved.\"\n\nRecently, observations have emerged in the industry that the launch of the foldable iPhone could be delayed due to hinge problems. The analysis that Apple could push back the actual sales timing even if it holds the September unveiling event has gained traction. Since it is the first foldable smartphone, Apple may apply strict quality standards at the last moment.\n\nApple also appears likely to adjust its iPhone launch strategy somewhat. With the addition of the foldable model, the central axis of the September new product unveiling event is expected to shift toward the Pro lineup and the foldable model, and there is a possibility that the standard model will be split off into a separate launch schedule.\n\nAn Apple supply chain company source said, \"This year the unveiling will center on the Pro, Pro Max, and Ultra (foldable),\" adding that \"with the addition of the foldable iPhone, among the existing iPhone lineup, the standard model could see its launch pushed back to next spring.\"", "raw_url": "https://x.com/jukan05/status/2069689336258576813"}, {"post_id": "2069680390978027791", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T07:13:52+00:00", "direction": "neutral", "ticker": [], "company": ["Samsung Electronics", "SK Hynix", "NVIDIA", "Google", "Amazon", "Microsoft"], "bottleneck": "HBM", "attribution": "NA", "rebuts": null, "summary": "三星电子将一半HBM产能分配给HBM4，约7.5万片/月，剩余给12层HBM3E，8层HBM3E暂停。公司希望通过HBM4恢复竞争力，已出货并实现10亿美元收入。SK海力士在HBM3E领先，不急于HBM4。ASIC市场扩张为三星带来机会。市占率预测三星今年升至37%，SK海力士降至43%。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Samsung Electronics Allocates Half of HBM Capacity to HBM4\n\nSamsung Electronics has been found to have assigned half of its high bandwidth memory (HBM) production capacity to its sixth generation HBM4. After becoming the first in the world to ship HBM4 this past February, the company is now expanding production in earnest and moving to recover market share.\n\nAccording to the semiconductor industry on the 24th, Samsung Electronics is understood to have recently allocated roughly 75,000 wafers, half of its monthly HBM DRAM wafer input of 150,000, to HBM4. The remaining half has been assigned to 12 layer HBM3E, its fifth generation product. In the case of the relatively weaker demand 8 layer HBM3E product, production has reportedly been temporarily halted and redirected to HBM4. HBM3E goes into Blackwell, NVIDIA's current generation artificial intelligence (AI) accelerator, while HBM4 goes into Rubin, the next generation AI accelerator. Setting aside HBM3E production used to meet existing demand, the company has in effect concentrated all of its capabilities on HBM4 production.\n\nSamsung Electronics plans to ramp up HBM4 volume and thereby restore the HBM market competitiveness in which it had fallen behind. In HBM3E, SK Hynix effectively secured NVIDIA supply ahead of others, while Samsung Electronics, delayed in quality certification, was unable to win much volume. From Samsung Electronics' standpoint, concentrating on HBM4, where it began supply ahead of SK Hynix, is more advantageous than chasing as a latecomer in HBM3E. After its first mass production shipment of HBM4 this past February, Samsung Electronics recorded 1 billion dollars (about 1.54 trillion won) in revenue within four months. Total revenue this year is projected to reach 10 billion dollars.\n\nAnother backdrop to Samsung Electronics putting its weight behind HBM4 is the expansion of the application specific integrated circuit (ASIC) market. As large cloud companies such as Google, Amazon, and Microsoft increase development of their own AI accelerators to reduce dependence on NVIDIA GPUs, HBM demand going into these chips is also growing rapidly. Because base die and packaging competitiveness tailored to each customer's design requirements becomes important starting with HBM4, the analysis is that this could be an opportunity for Samsung Electronics, which holds memory, foundry, and advanced packaging together.\n\nBy contrast, SK Hynix has relatively little need to rush HBM4 mass production the way Samsung Electronics has. It has already secured a strong customer base and a volume advantage in HBM3E, and it is also projected to supply NVIDIA with the largest volume in HBM4. The point is that SK Hynix has more room than Samsung Electronics to keep taking existing HBM3E demand steadily while gradually shifting its center of gravity to HBM4. A semiconductor industry official said, \"With NVIDIA CEO Jensen Huang having already stated during his visit to Korea this month that SK Hynix is its largest supplier, there is no need to rush, and Hynix's HBM4 revenue will also grow in line with the timing of Rubin mass production.\"\n\nThe competitive structure between the two companies surrounding the HBM market is also expected to intensify further. According to market research firm TrendForce and investment bank Bernstein, Samsung Electronics' HBM market share is projected to rise from 27 percent last year to 37 percent this year. SK Hynix's share is expected to fall from 56 percent to 43 percent. There is also analysis suggesting that next year Samsung Electronics will overtake SK Hynix's share.", "raw_url": "https://x.com/jukan05/status/2069680390978027791"}, {"post_id": "2069675057300082728", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T06:52:41+00:00", "direction": "neutral", "ticker": ["JBL", "SIVE", "MRVL", "MXL", "TSEM", "300394.SZ"], "company": ["Jabil", "Sivers Semiconductors", "Marvell", "MaxLinear", "Tower Semiconductor", "TFC Optical"], "bottleneck": "光通信", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 OpenLight 私有公司规模不断扩大，并列举其公开生态合作伙伴：JBL（SIVE 合作伙伴）用于 PIC 规模化，MRVL 和 MXL 提供 DSP，TSEM 为代工厂，300394.SZ/TFC Optical 负责 OSAT/子组件。建议非合格投资者可通过这些公开股票间接参与私有增长。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "OpenLight (private) seems to get bigger and bigger every time I look at it.\n\nIf you’re curious about their public ecosystem outside of Advantest:\n\n$JBL ( $SIVE partner ) for scaling PICs\n$MRVL and $MXL for DSPs\n$TSEM for the foundry.\n$300394.SZ / TFC Optical (OSAT/subassembly)\n\nCan often get exposure into private growth through public equities if you’re not an accredited investor.\n\nSince optical players look very interconnected.", "raw_url": "https://x.com/aleabitoreddit/status/2069675057300082728"}, {"post_id": "2069655980456149142", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T05:36:52+00:00", "direction": "long", "ticker": ["AMZN", "TSLA", "GOOGL"], "company": ["Amazon", "Tesla", "Google"], "bottleneck": "AI 算力", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者认为 AMZN 是当前最看好的超大规模云商，因其 capex 用于自动化劳动力、物理 AI（自动驾驶、机器人）及 AWS 算力扩展，路径最清晰。TSLA 机器人用例太宽泛，GOOGL 次之，AI capex 用于防御搜索护城河和云业务。微软和 Meta 仍在说服市场 capex 必要性。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Don’t quite think “siphoned off” is the correct term. \n\nIt’s capex for massive revenue increase or margin increase down the line.\n\n$AMZN is probably my favorite hyperscaler right now and example to give.\n\nAmazon’s headcount is absurd, like ~1.57M. If the capex goes into automating their workforce with LLMs.\n\nThen transitioning into physical AI:\n\n- things from self driving (deliveries)\n- robotics (Amazon warehouses, shipping automation).\n\n+ revenue increase from building out AWS compute with Trainium and possibly selling chips too with the Neocloud strat.\n\nIt’s probably the clearest path forward compared to every hyperscaler out there. \n\n$TSLA optimus use case targets is extremely broad as a pitch, but Amazon already has a specific reason to scale robotics for internal opex optimization.\n\nAs for $GOOGL, probably 2nd right now, AI capex was necessary for defending its Google Search moat Gemini from ChatGPT\n\nThey also have Google Cloud revenue with efficient TPUs + can sell TPUs like Nvidia GPUs.\n\nGemini user volumes keep going up (despite the lack of contention in frontier benchmarks); and AI strategy to be working for ad optimization too.\n\nBut there’s less clear paths with physical AI stuff ig?\n\nMicrosoft and Meta are still trying to convince the market why capex is necessary, (we’re kinda seeing that in effect with Meta’s 30%+ Y/Y revenue growth), but doesn’t look like they’re convinced. \n\nAs for market narratives, Microsoft Maia seems to be behind, their AI development was stunted from OpenAi investments, so sentiment is kinda in the ground. \n\nBut think that will change down the road like the 180 with Google.\n\nI’m sure all the hyperscalers are seeing the leader effect right now:\n\nIf you have the leading LLM, people will keep using it. That LLM gets smarter from all the training data; and that gap might be structural.\n\nWhich is why everyone is kinda rushing the buildout right now, but for some the immediate incentives seem obvious.", "raw_url": "https://x.com/aleabitoreddit/status/2069655980456149142"}, {"post_id": "2069644880494862662", "kol": "zephyr", "source_id": "tw_zephyr_z9", "published_at": "2026-06-24T04:52:46+00:00", "direction": "neutral", "ticker": [], "company": ["Semco"], "bottleneck": "Substrate", "attribution": "ORIGINAL", "rebuts": null, "summary": "作者指出 Semco 除了 MLCC 外还有爆炸性增长的 IC 基板业务，属于客观陈述，无明确多空方向。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "@iammoisturized @labubu_trader Semco has a lot going for it apart from MLCC\nThey have an explosive IC substrate biz", "raw_url": "https://x.com/zephyr_z9/status/2069644880494862662"}, {"post_id": "2069633445903675865", "kol": "serenity", "source_id": "tw_aleabitoreddit", "published_at": "2026-06-24T04:07:20+00:00", "direction": "neutral", "ticker": ["RDDT", "WEN"], "company": ["Reddit", "Wendy's"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者发现 Reddit 上的散户发起拯救 Wendy's 的病毒式运动，WEN 股价一夜涨 20%。作者声明无持仓，仅觉得有趣，并反问是否真能成功。", "is_retro": 0, "is_disc": 1, "is_selfret": 0, "raw_text": "I find it interesting that the degens on $RDDT are starting a viral campaign to save Wendy’s ( $WEN ).\n\nThe US fast food burger chain.\n\nAnd the stock price is now up 20% overnight. \n\nJust for background: Wendy’s is a popular community meme, where people work behind the dumpsters after their portfolios go to 0 from 0DTE options.\n\n(No positions, just found it amusing) \n\nI wonder if it’s going to work?", "raw_url": "https://x.com/aleabitoreddit/status/2069633445903675865"}, {"post_id": "2069572863536021716", "kol": "jukan", "source_id": "tw_jukan05", "published_at": "2026-06-24T00:06:36+00:00", "direction": "neutral", "ticker": ["META"], "company": ["Meta"], "bottleneck": null, "attribution": "ORIGINAL", "rebuts": null, "summary": "作者提到 Meta 进入预测市场业务，并认为 Meta 重新涉足稳定币业务（类似过去的 Libra）不是坏主意。属于客观建议，无明确看多/看空关键词。", "is_retro": 0, "is_disc": 0, "is_selfret": 0, "raw_text": "Wow, Meta is apparently entering the prediction market business now…\n\nHonestly, I think it wouldn’t be a bad idea for Meta to get back into the stablecoin business at this point, similar to what it tried to do with Libra back in the day. https://t.co/tLaNbNtFIr", "raw_url": "https://x.com/jukan05/status/2069572863536021716"}]</script>
<script id="KOLS" type="application/json">{"jukan": {"key": "jukan", "name": "Jukan", "handle": "@jukan05", "type": "signal", "typeLabel": "信号源 · signal", "desc": "100% 推文带 ticker，会明确喊方向。胜率高，几乎不做空。", "strong": ["存储", "HBM", "代工", "卡点"], "weak": ["看多 AI 龙头(跑输板块)"]}, "serenity": {"key": "serenity", "name": "Serenity", "handle": "@aleabitoreddit", "type": "cognition", "typeLabel": "瓶颈专家 · cognition", "desc": "光通信/CPO 瓶颈专家，会喊标的，但顺势押龙头、易追高。", "strong": ["光通信", "CPO", "InP", "化合物半导体"], "weak": ["整体追高", "tier_B 清单=板块β"]}, "zephyr": {"key": "zephyr", "name": "zephyr", "handle": "@zephyr_z9", "type": "cognition", "typeLabel": "卡点雷达 · cognition", "desc": "产业卡点雷达，看多卡点极准(94.8%)，但看空系统性错。", "strong": ["存储", "光通信", "HBM", "电力", "卡点"], "weak": ["看空全错(0/22)", "AI 泡沫论盲区"]}, "austin": {"key": "austin", "name": "Austin", "handle": "@austinsemis", "type": "cognition", "typeLabel": "商业格局 · cognition", "desc": "AI 芯片商业格局分析，AMD/CUDA 护城河有洞察。认知源非信号源。", "strong": ["商业格局", "AMD/CUDA 护城河", "Foundry 模式"], "weak": ["看多龙头(跑输板块)", "看空全错(1/8)"]}}</script>
<script id="TICKERS" type="application/json">[{"ticker": "NVDA", "kol": "zephyr", "direction": "long", "called_at": "2026-06-25T17:02:06+00:00", "earliest_call": "2026-06-25T17:02:06+00:00", "days_since": 6, "call_price": 195.74, "now_price": 200.09, "raw_pct": 2.2, "excess_pct": -5.2, "in_field": true, "has_price": true, "n_calls": 1, "priority": 0}, {"ticker": "TSM", "kol": "serenity", "direction": "long", "called_at": "2026-06-25T03:45:23+00:00", "earliest_call": "2026-06-25T03:45:23+00:00", "days_since": 6, "call_price": 434.99, "now_price": 477.57, "raw_pct": 9.8, "excess_pct": 2.4, "in_field": true, "has_price": true, "n_calls": 1, "priority": 0}, {"ticker": "JBL", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T10:02:56+00:00", "earliest_call": "2026-06-25T16:15:27+00:00", "days_since": 5, "call_price": 358.6, "now_price": 385.48, "raw_pct": 7.5, "excess_pct": 0.1, "in_field": true, "has_price": true, "n_calls": 2, "priority": 0}, {"ticker": "AEVA", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T10:02:56+00:00", "earliest_call": "2026-06-26T10:02:56+00:00", "days_since": 5, "call_price": 20.89, "now_price": 28.72, "raw_pct": 37.5, "excess_pct": 30.1, "in_field": true, "has_price": true, "n_calls": 1, "priority": 0}, {"ticker": "MRVL", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T10:02:56+00:00", "earliest_call": "2026-06-26T10:02:56+00:00", "days_since": 5, "call_price": 266.77, "now_price": 297.89, "raw_pct": 11.7, "excess_pct": 4.3, "in_field": true, "has_price": true, "n_calls": 1, "priority": 0}, {"ticker": "AOSL", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T00:34:45+00:00", "earliest_call": "2026-06-26T00:34:45+00:00", "days_since": 5, "call_price": 43.99, "now_price": 47.33, "raw_pct": 7.6, "excess_pct": 0.2, "in_field": true, "has_price": true, "n_calls": 1, "priority": 0}, {"ticker": "POWI", "kol": "serenity", "direction": "long", "called_at": "2026-06-26T00:34:45+00:00", "ear