# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.mypy_cache/
.ruff_cache/

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Logs / cache
*.log
.cache/
.mavis/plans/draft/

# Build artifacts
dist/
build/
*.whl

# 项目缓存(可重建)
.cache_full/
.cache_full_v1_backup/
.cache_smoke/
.cache_rescrape/
.cache_rescrape_v2/
.data_full/
.data_smoke/

# 数据库 — 原始 DB 绝不入仓 (上次 reset 删库事故根源)
# 唯一例外: signalboard.db.gz (gzip 压缩版, ~16MB, GitHub 100MB 限制内, 每天自动 push)
data/*.db
data/*.db-wal
data/*.db-shm
!data/signalboard.db.gz

# Logs/ 太大 (418M), 暂不 push
logs/

# Secrets / tokens / credentials (硬规则: 绝不入仓)
.env
.env.*
*.token
*.key
.git-credentials
.netrc
secrets/
